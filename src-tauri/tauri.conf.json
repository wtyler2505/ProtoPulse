{
  "$schema": "https://raw.githubusercontent.com/nicoptere/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ProtoPulse",
  "version": "1.0.0",
  "identifier": "com.protopulse.app",
  "build": {
    "devUrl": "http://localhost:5000",
    "frontendDist": "../dist/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ProtoPulse",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
