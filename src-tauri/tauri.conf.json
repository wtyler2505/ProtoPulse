{
  "$schema": "https://raw.githubusercontent.com/nicoptere/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ProtoPulse",
  "version": "1.0.0",
  "identifier": "com.protopulse.app",
  "build": {
    "devUrl": "http://localhost:5000",
    "frontendDist": "../dist/public"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ProtoPulse",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://localhost:* https://*.googleapis.com https://*.anthropic.com; font-src 'self' data:; media-src 'self' blob:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
