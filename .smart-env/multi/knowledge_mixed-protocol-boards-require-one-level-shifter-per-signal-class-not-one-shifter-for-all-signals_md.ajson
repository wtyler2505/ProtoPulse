equire one level shifter per signal class not one shifter for all signals#{9}":[52,52],"#Mixed-protocol boards require one level shifter per signal class not one shifter for all signals#{10}":[53,53],"#Mixed-protocol boards require one level shifter per signal class not one shifter for all signals#{11}":[54,55]},"outlinks":[{"title":"eda-fundamentals","target":"eda-fundamentals","line":7},{"title":"shields","target":"shields","line":8},{"title":"communication","target":"communication","line":9},{"title":"signal-topology-not-voltage-alone-determines-level-shifter-selection","target":"signal-topology-not-voltage-alone-determines-level-shifter-selection","line":19},{"title":"open-drain-protocols-require-pull-up-based-level-shifters-because-auto-direction-sensors-cannot-distinguish-driver-from-pull-up","target":"open-drain-protocols-require-pull-up-based-level-shifters-because-auto-direction-sensors-cannot-distinguish-driver-from-pull-up","line":25},{"title":"i2s-timing-requirements-make-level-shifting-a-non-solution-for-voltage-incompatible-mcus","target":"i2s-timing-requirements-make-level-shifting-a-non-solution-for-voltage-incompatible-mcus","line":29},{"title":"hw-221-8-channel-bidirectional-level-shifter-bss138-based","target":"hw-221-8-channel-bidirectional-level-shifter-bss138-based","line":41},{"title":"signal-topology-not-voltage-alone-determines-level-shifter-selection","target":"signal-topology-not-voltage-alone-determines-level-shifter-selection","line":44},{"title":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","target":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","line":45},{"title":"open-drain-protocols-require-pull-up-based-level-shifters-because-auto-direction-sensors-cannot-distinguish-driver-from-pull-up","target":"open-drain-protocols-require-pull-up-based-level-shifters-because-auto-direction-sensors-cannot-distinguish-driver-from-pull-up","line":46},{"title":"74hct-buffers-are-p