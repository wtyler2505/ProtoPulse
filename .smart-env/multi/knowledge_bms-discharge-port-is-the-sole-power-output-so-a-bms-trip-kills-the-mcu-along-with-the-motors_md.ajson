32},{"title":"four-motor-bldc-systems-exceed-standard-hoverboard-bms-ratings-requiring-firmware-current-limiting","target":"four-motor-bldc-systems-exceed-standard-hoverboard-bms-ratings-requiring-firmware-current-limiting","line":33},{"title":"parallel-power-rails-from-battery-are-more-reliable-than-cascaded-regulators","target":"parallel-power-rails-from-battery-are-more-reliable-than-cascaded-regulators","line":34},{"title":"power-systems","target":"power-systems","line":37},{"title":"eda-fundamentals","target":"eda-fundamentals","line":38}],"metadata":{"description":"The BMS discharge port feeds the entire downstream power tree -- motor bus, buck converters, and MCU -- so an overcurrent or undervoltage trip cuts power to the ESP32 before firmware can log the event, which is intentional safety behavior but removes the possibility of a graceful shutdown","type":"claim","created":"2026-04-14","source":"docs/parts/wiring-36v-battery-power-distribution-4-tier-system.md","confidence":"proven","topics":["[[power-systems]]","[[eda-fundamentals]]"],"related_components":["hoverboard-10s-battery-pack","esp32"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:knowledge/bms-discharge-port-is-the-sole-power-output-so-a-bms-trip-kills-the-mcu-along-with-the-motors.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"oyq5l5","at":1776152919086},"key":"knowledge/bms-discharge-port-is-the-sole-power-output-so-a-bms-trip-kills-the-mcu-along-with-the-motors.md#---frontmatter---","lines":[1,13],"size":564,"outlinks":[{"title":"power-systems","target":"power-systems","line":8},{"title":"eda-fundamentals","target":"eda-fundamentals","line":9}],"class_name":"SmartBlock"},
