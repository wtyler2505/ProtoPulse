e":"dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb","target":"dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb","line":17},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":17},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":17},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":17},{"title":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","target":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","line":17},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":17},{"title":"hc-sr501-pir-motion-sensor-detects-up-to-7m-at-5v","target":"hc-sr501-pir-motion-sensor-detects-up-to-7m-at-5v","line":111},{"title":"generic-ir-receiver-module-38khz-demodulator","target":"generic-ir-receiver-module-38khz-demodulator","line":112},{"title":"sound-sensor-module-lm393-electret-mic-analog-digital-out","target":"sound-sensor-module-lm393-electret-mic-analog-digital-out","line":113},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":114},{"title":"sensors","target":"sensors","line":117}],"metadata":{"description":"IR flame detector module tuned to 760-1100nm — detects fire/flame via infrared emission. Dual output: D0 for threshold alarm (adjustable pot), A0 for flame intensity. Works at 3.3-5V, detection angle ~60 degrees","topics":["[[sensors]]"],"status":"needs-test","quantity":1,"voltage":[3.3,5],"interfaces":["Analog","GPIO"],"logic_level":"3.3-5V","manufacturer":"Generic","part_number":"","pinout":"4-pin header:\n  VCC → 3.3-5V supply\n  GND → Ground\n  D0  → Digital output (LOW when flame detected, adjustable threshold via pot)\n  A0  → Analog output (lower value = stronger flame signal)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v]]","[[dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"used_in":[],"warnings":["D0 output is active LOW — goes LOW when flame is detected, HIGH when no flame","Detects ANY strong IR source — sunlight, incandescent bulbs, and halogen lamps WILL trigger false positives","Detection range is limited to ~1m for a candle flame — not a replacement for a proper smoke detector","60-degree detection angle means you need multiple sensors for full coverage","NOT a safety device — do not rely on this as your only fire detection method"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[57,73],[77,98]],"key":"docs/parts/flame-sensor-module-ir-760-1100nm-fire-detector-analog-digital.md"},"smart_blocks:docs/parts/flame-sensor-module-ir-760-1100nm-fire-detector-analog-digital.md#---frontmatter---": {"path":null,"last_embed":{"hash":"18ptzuf","at":1776210211819},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.08949435,0.05322543,0.06643749,-0.02819086,0.02742036,0.02168144,0.07490147,0.06382004,-0.0024483,-0.01263402,0.03656174,-0.09294273,-0.01950443,0.0720308,0.03448023,-0.00686225,0.02743626,-0.02252582,0.02013421,0.03899743,0.07786813,-0.01421996,0.00952273,-0.03564235,0.03945776,0.07224632,0.00158168,0.01175876,-0.05033932,-0.19730775,0.00636014,-0.02040954,0.02471091,-0.07094711,-0.03487658,-0.05240818,-0.05000683,-0.01494418,-0.08600309,