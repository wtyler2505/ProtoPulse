g + Digital Output#Reducing False Positives#{4}":[105,105],"#Flame Sensor Module — IR 760-1100nm Fire Detector, Analog + Digital Output#Reducing False Positives#{5}":[106,107],"#Flame Sensor Module — IR 760-1100nm Fire Detector, Analog + Digital Output#Reducing False Positives#{6}":[108,110],"#Flame Sensor Module — IR 760-1100nm Fire Detector, Analog + Digital Output#Reducing False Positives#{7}":[111,111],"#Flame Sensor Module — IR 760-1100nm Fire Detector, Analog + Digital Output#Reducing False Positives#{8}":[112,112],"#Flame Sensor Module — IR 760-1100nm Fire Detector, Analog + Digital Output#Reducing False Positives#{9}":[113,113],"#Flame Sensor Module — IR 760-1100nm Fire Detector, Analog + Digital Output#Reducing False Positives#{10}":[114,115],"#Flame Sensor Module — IR 760-1100nm Fire Detector, Analog + Digital Output#Reducing False Positives#{11}":[116,116],"#Flame Sensor Module — IR 760-1100nm Fire Detector, Analog + Digital Output#Reducing False Positives#{12}":[117,118]},"outlinks":[{"title":"sensors","target":"sensors","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":17},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":17},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":17},{"title":"dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb","target":"dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb","line":17},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":17},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":17},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":17},{"title":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","target":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","line":17},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":17},{"title":"hc-sr501-pir-motion-sensor-detects-up-to-7m-at-5v","target":"hc-sr501-pir-motion-sensor-detects-up-to-7m-at-5v","line":111},{"title":"generic-ir-receiver-module-38khz-demodulator","target":"generic-ir-receiver-module-38khz-demodulator","line":112},{"title":"sound-sensor-module-lm393-electret-mic-analog-digital-out","target":"sound-sensor-module-lm393-electret-mic-analog-digital-out","line":113},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":114},{"title":"sensors","target":"sensors","line":117}],"metadata":{"description":"IR flame detector module tuned to 760-1100nm — detects fire/flame via infrared emission. Dual output: D0 for threshold alarm (adjustable pot), A0 for flame intensity. Works at 3.3-5V, detection angle ~60 degrees","topics":["[[sensors]]"],"status":"needs-test","quantity":1,"voltage":[3.3,5],"interfaces":["Analog","GPIO"],"logic_level":"3.3-5V","manufacturer":"Generic","part_number":"","pinout":"4-pin header:\n  VCC → 3.3-5V supply\n  GND → Ground\n  D0  → Digital output (LOW when flame detected, adjustable threshold via pot)\n  A0  → Analog output (lower value = stronger flame signal)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v]]","[[dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"used_in":[],"warnings":["D0 output is active LOW — goes LOW when flame is detected, HIGH when no flame","Detects ANY strong IR source — sunlight, incandescent bulbs, and halogen lamps WILL trigger false positives","Detection range is limited to ~1m for a candle flame — not a replacement for a proper smoke detector","60-degree detection angle means you need multiple sensors for full coverage","NOT a safety device — do not rely on this as your only fire detection method"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[57,73],[77,98]],"key":"docs/parts/flame-sensor-module-ir-760-1100nm-fire-detector-analog-digital.md"},
