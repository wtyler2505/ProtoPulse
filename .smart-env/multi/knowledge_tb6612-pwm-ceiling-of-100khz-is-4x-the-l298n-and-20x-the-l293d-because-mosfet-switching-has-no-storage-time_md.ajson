re microseconds to clear their bases, setting a hard frequency ceiling below the audible range","type":"claim","source":"docs/parts/osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel.md","confidence":"proven","topics":["[[actuators]]","[[eda-fundamentals]]"],"related_components":["osepp-tb6612-motor-shield","l293d-dual-h-bridge-ic","l298n-dual-h-bridge-motor-driver"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/tb6612-pwm-ceiling-of-100khz-is-4x-the-l298n-and-20x-the-l293d-because-mosfet-switching-has-no-storage-time.md"},"smart_blocks:knowledge/tb6612-pwm-ceiling-of-100khz-is-4x-the-l298n-and-20x-the-l293d-because-mosfet-switching-has-no-storage-time.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1hfx3pi","at":1776207997894},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.07765838,0.06775595,0.01079202,-0.054135,-0.00122542,0.00171703,-0.05959626,0.06240784,-0.04451884,-0.01408537,0.02021857,-0.06793579,-0.00908284,0.00086972,0.04450742,0.04787919,-0.00890091,-0.05177232,0.03238182,0.09482857,0.10352735,-0.03240062,0.0119453,0.04793614,0.10187194,0.00290453,0.03757818,0.00965318,-0.04293752,-0.25777265,-0.05351986,-0.044765,0.03622254,-0.00803435,-0.02816316,-0.03382285,-0.00682545,-0.03059661,0.0066448,0.01605995,0.02631641,0.00841794,0.0036292,-0.03080301,-0.02176879,-0.03686726,-0.03391329,-0.02959664,0.02432768,-0.04928302,-0.0012868,0.02840847,0.01979416,0.0058455,0.00714579,0.04014823,0.03686015,0.02392997,0.04605585,0.05275523,0.06427536,0.04146755,-0.22196347,0.10278466,0.03974747,0.0053026,0.03682832,-0.04939967,0.05036798,0.07699459,-0.04177654,0.01352942,0.0310146,-0.01484706,0.01183083,-0.02075466,-0.00082973,-0.03765957,-0.02971639,-0.02551349,0.01787436,-0.0036166,-0.0350667,-0.05591325,-0.07401799,-0.03288962,0.02505536,0.02763217,0.00066935,0.1143262,-0.02136586,0.03086797,-0.02552082,-0.05037932,-0.07770229,-0.03804998,0.03003074,0.09344572,-0.08043063,0.08817502,-0.00603819,0.00511924,0.00034946,-0.0