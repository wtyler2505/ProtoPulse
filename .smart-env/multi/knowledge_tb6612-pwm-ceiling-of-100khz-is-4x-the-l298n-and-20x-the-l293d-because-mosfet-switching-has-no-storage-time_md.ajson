"line":23},{"title":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","target":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","line":29},{"title":"tb6612-mosfet-h-bridge-drops-0-5v-versus-darlington-1-8-to-4-9v-because-rds-on-resistance-beats-saturation-voltage","target":"tb6612-mosfet-h-bridge-drops-0-5v-versus-darlington-1-8-to-4-9v-because-rds-on-resistance-beats-saturation-voltage","line":32},{"title":"74hc595-in-motor-shields-trades-gpio-savings-for-direction-change-latency-that-matters-at-high-switching-frequencies","target":"74hc595-in-motor-shields-trades-gpio-savings-for-direction-change-latency-that-matters-at-high-switching-frequencies","line":33},{"title":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","target":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","line":34},{"title":"hw-130-shield-consumes-both-timer0-and-timer2-leaving-only-timer1-free-for-other-libraries","target":"hw-130-shield-consumes-both-timer0-and-timer2-leaving-only-timer1-free-for-other-libraries","line":35},{"title":"actuators","target":"actuators","line":38},{"title":"eda-fundamentals","target":"eda-fundamentals","line":39}],"metadata":{"description":"The TB6612 can accept PWM up to 100kHz while the L298N caps at ~25kHz and the L293D at ~5kHz — MOSFETs have no minority-carrier storage time so they switch cleanly at radio frequencies, while Darlington BJTs require microseconds to clear their bases, setting a hard frequency ceiling below the audible range","type":"claim","source":"docs/parts/osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel.md","confidence":"proven","topics":["[[actuators]]","[[eda-fundamentals]]"],"related_components":["osepp-tb6612-motor-shield","l293d-dual-h-bridge-ic","l298n-dual-h-bridge-motor-driver"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},