"smart_sources:knowledge/tb6612-pwm-ceiling-of-100khz-is-4x-the-l298n-and-20x-the-l293d-because-mosfet-switching-has-no-storage-time.md": {"path":"knowledge/tb6612-pwm-ceiling-of-100khz-is-4x-the-l298n-and-20x-the-l293d-because-mosfet-switching-has-no-storage-time.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"1toiwma","at":1776152920610},"class_name":"SmartSource","last_import":{"mtime":1776149658933,"size":4275,"at":1776152920992,"hash":"1toiwma"},"blocks":{"#---frontmatter---":[1,13],"#TB6612 PWM ceiling of 100kHz is 4x the L298N and 20x the L293D because MOSFET switching has no storage time":[15,40],"#TB6612 PWM ceiling of 100kHz is 4x the L298N and 20x the L293D because MOSFET switching has no storage time#{1}":[17,31],"#TB6612 PWM ceiling of 100kHz is 4x the L298N and 20x the L293D because MOSFET switching has no storage time#{2}":[32,32],"#TB6612 PWM ceiling of 100kHz is 4x the L298N and 20x the L293D because MOSFET switching has no storage time#{3}":[33,33],"#TB6612 PWM ceiling of 100kHz is 4x the L298N and 20x the L293D because MOSFET switching has no storage time#{4}":[34,34],"#TB6612 PWM ceiling of 100kHz is 4x the L298N and 20x the L293D because MOSFET switching has no storage time#{5}":[35,36],"#TB6612 PWM ceiling of 100kHz is 4x the L298N and 20x the L293D because MOSFET switching has no storage time#{6}":[37,37],"#TB6612 PWM ceiling of 100kHz is 4x the L298N and 20x the L293D because MOSFET switching has no storage time#{7}":[38,38],"#TB6612 PWM ceiling of 100kHz is 4x the L298N and 20x the L293D because MOSFET switching has no storage time#{8}":[39,40]},"outlinks":[{"title":"actuators","target":"actuators","line":7},{"title":"eda-fundamentals","target":"eda-fundamentals","line":8},{"title":"tb6612-mosfet-h-bridge-drops-0-5v-versus-darlington-1-8-to-4-9v-because-rds-on-resistance-beats-saturation-voltage","target":"tb6612-mosfet-h-bridge-drops-0-5v-versus-darlington-1-8-to-4-9v-because-rds-on-resistance-beats-saturation-voltage","line":23},{"title":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","target":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","line":29},{"title":"tb6612-mosfet-h-bridge-drops-0-5v-versus-darlington-1-8-to-4-9v-because-rds-on-resistance-beats-saturation-voltage","target":"tb6612-mosfet-h-bridge-drops-0-5v-versus-darlington-1-8-to-4-9v-because-rds-on-resistance-beats-saturation-voltage","line":32},{"title":"74hc595-in-motor-shields-trades-gpio-savings-for-direction-change-latency-that-matters-at-high-switching-frequencies","target":"74hc595-in-motor-shields-trades-gpio-savings-for-direction-change-latency-that-matters-at-high-switching-frequencies","line":33},{"title":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","target":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","line":34},{"title":"hw-130-shield-consumes-both-timer0-and-timer2-leaving-only-timer1-free-for-other-libraries","target":"hw-130-shield-consumes-both-timer0-and-timer2-leaving-only-timer1-free-for-other-libraries","line":35},{"title":"actuators","target":"actuators","line":38},{"title":"eda-fundamentals","target":"eda-fundamentals","line":39}],"metadata":{"description":"The TB6612 can accept PWM up to 100kHz while the L298N caps at ~25kHz and the L293D at ~5kHz — MOSFETs have no minority-carrier storage time so they switch cleanly at radio frequencies, while Darlington BJTs require microseconds to clear their bases, setting a hard frequency ceiling below the audible range","type":"claim","source":"docs/parts/osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel.md","confidence":"proven","topics":["[[actuators]]","[[eda-fundamentals]]"],"related_components":["osepp-tb6612-motor-shield","l293d-dual-h-bridge-ic","l298n-dual-h-bridge-motor-driver"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/tb6612-pwm-ceiling-of-100khz-is-4x-the-l298n-and-20x-the-l293d-because-mosfet-switching-has-no-storage-time.md"},
