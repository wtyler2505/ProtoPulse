ors","line":3},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":21},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":21},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":21},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":22},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":22},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":22},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":22},{"title":"hc-sr501-pir-motion-sensor-detects-up-to-7m-at-5v","target":"hc-sr501-pir-motion-sensor-detects-up-to-7m-at-5v","line":149},{"title":"sharp-gp2y0a51sk0f-ir-proximity-sensor-2-to-15cm-analog","target":"sharp-gp2y0a51sk0f-ir-proximity-sensor-2-to-15cm-analog","line":150},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":151},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":152},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":153},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":154},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":155},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":156},{"title":"sensors","target":"sensors","line":159}],"metadata":{"description":"Budget ultrasonic rangefinder — Trig/Echo interface, 2cm-400cm range, ~3mm accuracy. 5V only and Echo pin outputs 5V, so you MUST level shift for 3.3V boards or you'll fry them","topics":["[[sensors]]"],"status":"verified","quantity":1,"voltage":[5],"interfaces":["Digital"],"logic_level":"5V","logic_notes":"Runs at 5V and drives a 5V Echo signal. The Trig input usually accepts 3.3V as HIGH, but Echo must be shifted before it reaches a 3.3V MCU.","manufacturer":"Generic","part_number":"HC-SR04","measurement_range":"2cm to 400cm","accuracy":"~3mm","beam_angle":"~15 degrees","pinout":"4-pin header (left to right, component side facing you):\nVCC  → 5V supply\nTrig → Digital output from Arduino (10us pulse to trigger measurement)\nEcho → Digital input to Arduino (pulse width encodes distance)\nGND  → Ground\n","level_shifter_needed":["[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]"],"used_in":[],"warnings":["Echo pin outputs 5V — do NOT connect directly to ESP8266/ESP32 3.3V boards without a voltage divider or level shifter","Minimum range is 2cm — readings below this are unreliable","Soft surfaces (fabric, foam) absorb sound and give weak/no return","Multiple HC-SR04s can interfere with each other if fired simultaneously"],"datasheet_url":"https://cdn.sparkfun.com/datasheets/Sensors/Proximity/HCSR04.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[57,66],[84,88],[112,120]],"key":"docs/parts/hc-sr04-ultrasonic-sensor-measures-2cm-to-400cm-at-5v.md"},
