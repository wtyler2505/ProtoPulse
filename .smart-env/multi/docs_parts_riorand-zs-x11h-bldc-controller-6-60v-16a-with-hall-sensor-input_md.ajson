,413],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings":[414,436],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{1}":[416,416],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{2}":[417,417],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{3}":[418,418],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{4}":[419,419],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{5}":[420,420],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{6}":[421,421],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{7}":[422,422],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{8}":[423,424],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{9}":[425,427],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{10}":[428,428],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{11}":[429,429],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{12}":[430,430],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{13}":[431,432],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{14}":[433,433],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{15}":[434,434],"#RioRand ZS-X11H BLDC Controller 6-60V 16A with Hall Sensor Input#Warnings#{16}":[435,436]},"outlinks":[{"title":"actuators","target":"actuators","line":3},{"title":"shields","target":"shields","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":41},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":41},{"title":"hoverboard-bldc-hub-motor-250w-36v-with-hall-sensors","target":"hoverboard-bldc-hub-motor-250w-36v-with-hall-sensors","line":41},{"title":"hoverboard-bldc-hub-motor-250w-36v-with-hall-sensors","target":"hoverboard-bldc-hub-motor-250w-36v-with-hall-sensors","line":51},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":297},{"title":"hoverboard-bldc-hub-motor-250w-36v-with-hall-sensors","target":"hoverboard-bldc-hub-motor-250w-36v-with-hall-sensors","line":428},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":429},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":430},{"title":"l298n-dual-h-bridge-motor-driver-drives-2-dc-motors-or-1-stepper-up-to-46v-2a","target":"l298n-dual-h-bridge-motor-driver-drives-2-dc-motors-or-1-stepper-up-to-46v-2a","line":431},{"title":"actuators","target":"actuators","line":434},{"title":"shields","target":"shields","line":435}],"metadata":{"description":"3-phase trapezoidal BLDC motor controller — 6-60V input, 16A continuous (20A peak), 200-400W. PWM speed control, direction/brake inputs, Hall sensor feedback. NO reverse polarity protection — will blow up if power is connected backwards","topics":["[[actuators]]","[[shields]]"],"status":"verified","quantity":4,"voltage":[6,12,24,36,48,60],"interfaces":["PWM","Digital","Hall","3-Phase"],"logic_level":"mixed","logic_notes":"Control inputs generally accept 3.3V PWM/TTL from MCUs, but the SC feedback output and Hall power rail are 5V. Shift or divide 5V outputs before feeding a 3.3V MCU.","manufacturer":"RioRand","part_number":"ZS-X11H","pinout":"Power Input:\n  V+ → Motor supply (6-60V)\n  V- → Ground (common with MCU ground!)\n\nMotor Output (3-phase):\n  MA → Motor Phase A (Yellow)\n  MB → Motor Phase B (Green)\n  MC → Motor Phase C (Blue)\n\nHall Sensor Input:\n  HA → Hall A (from motor, Yellow)\n  HB → Hall B (from motor, Green)\n  HC → Hall C (from motor, Blue)\n  5V → Hall sensor power (from onboard 78L05)\n  GND → Hall sensor ground\n\nControl Input:\n  EL   → Speed control PWM (5V, 50Hz-20kHz, active LOW: 0%=full, 100%=stop)\n  Z/F  → Direction (HIGH=CW, LOW=CCW, or motor-dependent)\n  STOP → Enable (LOW=stop, HIGH or float=run)\n  CT   → Brake (LOW=brake, HIGH or float=coast)\n\nFeedback Output:\n  SC → Speed pulse output (one pulse per Hall state change, 5V)\n\nJumper:\n  J1 → Start mode: OFF=start from stop, ON=continue from current speed\n","max_current_per_channel":"16A continuous, 20A peak","compatible_with":["[[hoverboard-bldc-hub-motor-250w-36v-with-hall-sensors]]","[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[hoverboard-10s-lithium-ion-battery-pack-36v-with-bms]]"],"used_in":[],"warnings":["NO REVERSE POLARITY PROTECTION — connecting V+/V- backwards destroys the controller instantly","EL (speed) is ACTIVE LOW — 0% duty cycle = FULL SPEED, 100% = STOP. This is counterintuitive!","V- MUST share common ground with the MCU — floating ground = erratic behavior","16A continuous at 36V = 576W — needs adequate ventilation and properly rated wiring","Hall sensor order (HA/HB/HC) must match motor phase order (MA/MB/MC) — wrong pairing = vibration, not rotation"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[116,142],[172,175],[179,183],[225,227],[230,232],[250,256],[312,374]],"key":"docs/parts/riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input.md"},"smart_blocks:docs/parts/riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1wu9s8t","at":1776210511055},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05712423,0.03626657,0.03231277,-0.04159983,-0.04532191,0.03912999,-0.02363012,0.05488697,0.00247131,-0.00449461,0.01763974,-0.09365483,0.02965191,0.02982513,-0.0339915,0.0