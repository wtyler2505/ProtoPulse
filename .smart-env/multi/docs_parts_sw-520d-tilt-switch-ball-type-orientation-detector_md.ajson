 Cases#{12}":[87,88]},"outlinks":[{"title":"input-devices","target":"input-devices","line":3},{"title":"sensors","target":"sensors","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":16},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":16},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":16},{"title":"hamlin-59030-reed-switch-magnetic-sensor-dry-contact","target":"hamlin-59030-reed-switch-magnetic-sensor-dry-contact","line":80},{"title":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","target":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","line":81},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":82},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":83},{"title":"sensors","target":"sensors","line":86},{"title":"input-devices","target":"input-devices","line":87}],"metadata":{"description":"Ball-type tilt switch — detects orientation changes by rolling a metal ball onto contacts, dead simple with INPUT_PULLUP, reads LOW when tilted","topics":["[[sensors]]","[[input-devices]]"],"status":"needs-test","quantity":3,"voltage":[3.3,5],"interfaces":["GPIO"],"logic_level":"5V","manufacturer":"Generic","part_number":"SW-520D","package":"Cylindrical can, 2 leads","pinout":"Pin 1 → GPIO (with INPUT_PULLUP)\nPin 2 → GND\n(Non-polarized — either pin works for either connection)\n","compatible_with":["[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[nodemcu-esp32s-is-a-dua