le":"power-systems","target":"power-systems","line":8},{"title":"eda-fundamentals","target":"eda-fundamentals","line":9},{"title":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","target":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","line":20},{"title":"l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path","target":"l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path","line":20},{"title":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","target":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","line":30},{"title":"l298n-saturation-voltage-drop-loses-up-to-5v-making-it-inefficient-at-high-current","target":"l298n-saturation-voltage-drop-loses-up-to-5v-making-it-inefficient-at-high-current","line":33},{"title":"l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path","target":"l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path","line":34},{"title":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","target":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","line":35},{"title":"logic-level-mosfet-gate-threshold-below-3v-eliminates-need-for-gate-driver-circuit","target":"logic-level-mosfet-gate-threshold-below-3v-eliminates-need-for-gate-driver-circuit","line":36},{"title":"motor-shield-current-ratings-form-a-graduated-selection-ladder","target":"motor-shield-current-ratings-form-a-graduated-selection-ladder","line":37},{"title":"actuators","target":"actuators","line":40},{"title":"power-systems","target":"power-systems","line":41},{"title":"eda-fundamentals","target":"eda-fundamentals","line":42}],"metadata":{"description":"MOSFET H-bridges like the TB6612 drop only ~0.5V total because RDS(on) is milliohm-scale resistance, while bipolar Darlington H-bridges like the L293D and L298N drop 1.4-4.9V because VCE(sat) is a fixed floor — this architectural difference, not current rating, is what makes modern drivers efficient","type":"claim","source":"docs/parts/osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel.md","confidence":"proven","topics":["[[actuators]]","[[power-systems]]","[[eda-fundamentals]]"],"related_components":["osepp-tb6612-motor-shield","l293d-dual-h-bridge-ic","l298n-dual-h-bridge-motor-driver"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/tb6612-mosfet-h-bridge-drops-0-5v-versus-darlington-1-8-to-4-9v-because-rds-on-resistance-beats-saturation-voltage.md"},
