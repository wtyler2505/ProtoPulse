ation voltage#{7}":[39,39],"#TB6612 MOSFET H-bridge drops 0.5V versus Darlington 1.8-4.9V because RDS(on) resistance beats saturation voltage#{8}":[40,40],"#TB6612 MOSFET H-bridge drops 0.5V versus Darlington 1.8-4.9V because RDS(on) resistance beats saturation voltage#{9}":[41,41],"#TB6612 MOSFET H-bridge drops 0.5V versus Darlington 1.8-4.9V because RDS(on) resistance beats saturation voltage#{10}":[42,43]},"outlinks":[{"title":"actuators","target":"actuators","line":7},{"title":"power-systems","target":"power-systems","line":8},{"title":"eda-fundamentals","target":"eda-fundamentals","line":9},{"title":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","target":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","line":20},{"title":"l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path","target":"l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path","line":20},{"title":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","target":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","line":30},{"title":"l298n-saturation-voltage-drop-loses-up-to-5v-making-it-inefficient-at-high-current","target":"l298n-saturation-voltage-drop-loses-up-to-5v-making-it-inefficient-at-high-current","line":33},{"title":"l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path","target":"l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path","line":34},{"title":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","target":"bjt-switching-tops-out-at-600ma-in-to-92-and-the-transition-to-mosfet-is-a-hard-architecture-boundary","line":35},{"title":"logic-level-mosfet-gate-threshold-below-3v-eliminates-need-for-gate-driver-circuit","target":"logic-level-mosfet-gate-threshold-below-3v-eliminates-need-for-gate-driver-circuit","line":36},{"title":"motor-shield-current-ratings-form-a-graduated-selection-ladder","target":"motor-shield-current-ratings-form-a-graduated-selection-ladder","line":37},{"title":"actuators","target":"actuators","line":40},{"title":"power-systems","target":"power-systems","line":41},{"title":"eda-fundamentals","target":"eda-fundamentals","line":42}],"metadata":{"description":"MOSFET H-bridges like the TB6612 drop only ~0.5V total because RDS(on) is milliohm-scale resistance, while bipolar Darlington H-bridges like the L293D and L298N drop 1.4-4.9V because VCE(sat) is a fixed floor — this architectural difference, not current rating, is what makes modern drivers efficient","type":"claim","source":"docs/parts/osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel.md","confidence":"proven","topics":["[[actuators]]","[[power-systems]]","[[eda-fundamentals]]"],"related_components":["osepp-tb6612-motor-shield","l293d-dual-h-bridge-ic","l298n-dual-h-bridge-motor-driver"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/tb6612-mosfet-h-bridge-drops-0-5v-versus-darlington-1-8-to-4-9v-because-rds-on-resistance-beats-saturation-voltage.md"},"smart_blocks:knowledge/tb6612-mosfet-h-bridge-drops-0-5v-versus-darlington-1-8-to-4-9v-because-rds-on-resistance-beats-saturation-voltage.md#---frontmatter---": {"path":null,"last_embed":{"hash":"dtx56v","at":1776207990319},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.10049274,0.05700666,-0.00587887,-0.02427373,-0.02196104,0.03204329,-0.04417515,0.08613116,-0.00142919,-0.00704025,0.0147719,-0.06070324,-0.01141898,0.00214201,0.00318247,-0.00356688,-0.03910637,-0.02624962,0.05927438,0.10080837,0.0632255,-0.0510036,0.03962311,0.03163732,0.04552422,0.0419295,0.03177451,-0.03689266,0.00135718,-0.24874516,0.0069151,-0.01830235,0.01085772,0.0152731,-0.06886844,-0.02079478,-0.04968023,0.00516434,0.00680927,-0.00332895,-0.00720515,0.00957458,0.04105715,-0.03277067,-0.00494455,-0.00564142,0.009313