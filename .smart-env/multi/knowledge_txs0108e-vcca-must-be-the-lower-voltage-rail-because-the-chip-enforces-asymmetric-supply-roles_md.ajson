
"smart_sources:knowledge/txs0108e-vcca-must-be-the-lower-voltage-rail-because-the-chip-enforces-asymmetric-supply-roles.md": {"path":"knowledge/txs0108e-vcca-must-be-the-lower-voltage-rail-because-the-chip-enforces-asymmetric-supply-roles.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"13me5im","at":1776152920611},"class_name":"SmartSource","last_import":{"mtime":1776148381475,"size":3582,"at":1776152920994,"hash":"13me5im"},"blocks":{"#---frontmatter---":[1,11],"#TXS0108E VCCA must be the lower voltage rail because the chip enforces asymmetric supply roles":[13,44],"#TXS0108E VCCA must be the lower voltage rail because the chip enforces asymmetric supply roles#{1}":[15,36],"#TXS0108E VCCA must be the lower voltage rail because the chip enforces asymmetric supply roles#{2}":[37,37],"#TXS0108E VCCA must be the lower voltage rail because the chip enforces asymmetric supply roles#{3}":[38,38],"#TXS0108E VCCA must be the lower voltage rail because the chip enforces asymmetric supply roles#{4}":[39,40],"#TXS0108E VCCA must be the lower voltage rail because the chip enforces asymmetric supply roles#{5}":[41,41],"#TXS0108E VCCA must be the lower voltage rail because the chip enforces asymmetric supply roles#{6}":[42,42],"#TXS0108E VCCA must be the lower voltage rail because the chip enforces asymmetric supply roles#{7}":[43,44]},"outlinks":[{"title":"shields","target":"shields","line":7},{"title":"eda-fundamentals","target":"eda-fundamentals","line":8},{"title":"active-level-shifters-use-one-shot-edge-accelerators-to-drive-rising-edges-breaking-the-bss138-rc-ceiling","target":"active-level-shifters-use-one-shot-edge-accelerators-to-drive-rising-edges-breaking-the-bss138-rc-ceiling","line":24},{"title":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","target":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","line":34},{"title":"active-level-shifters-use-one-shot-edge-accelerators-to-drive-rising-edges-breaking-the-bss138-rc-ceiling","target":"active-level-shifters-use-one-shot-edge-accelerators-to-drive-rising-edges-breaking-the-bss138-rc-ceiling","line":37},{"title":"signal-topology-not-voltage-alone-determines-level-shifter-selection","target":"signal-topology-not-voltage-alone-determines-level-shifter-selection","line":38},{"title":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","target":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","line":39},{"title":"shields","target":"shields","line":42},{"title":"eda-fundamentals","target":"eda-fundamentals","line":43}],"metadata":{"description":"The TXS0108E's A-side and B-side are not interchangeable — VCCA is spec'd 1.2-3.6V and VCCB is spec'd 1.65-5.5V with the hard constraint that VCCA must be less than or equal to VCCB, so swapping the rails puts the chip outside its operating envelope and produces undefined behavior even when both voltages are legal individually","type":"claim","source":"docs/parts/txs0108e-8-channel-bidirectional-level-shifter-auto-direction.md","confidence":"proven","topics":["[[shields]]","[[eda-fundamentals]]"],"related_components":["txs0108e-level-shifter"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},