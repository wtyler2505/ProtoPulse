8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]"],"used_in":[],"warnings":["NOT suitable for voice recognition or audio recording — too noisy and low-bandwidth","Analog output is an envelope, not a clean audio waveform","Digital threshold is sensitive to trimpot position — adjust carefully","Some modules have AO and DO labels swapped — verify with a multimeter"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[59,64],[72,76]]},