er gyroscope I2C 3.3V#DMP Configuration Notes#{1}":[101,102],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#DMP Configuration Notes#{2}":[103,103],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#DMP Configuration Notes#{3}":[104,104],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#DMP Configuration Notes#{4}":[105,105],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#DMP Configuration Notes#{5}":[106,119],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#DMP Configuration Notes#{6}":[108,119],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#MPU6050 vs BNO055 Comparison":[120,134],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#MPU6050 vs BNO055 Comparison#{1}":[122,134],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration":[135,155],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{1}":[137,138],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{2}":[139,139],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{3}":[140,140],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{4}":[141,141],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{5}":[142,143],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{6}":[144,148],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{7}":[149,149],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{8}":[150,150],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{9}":[151,152],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{10}":[153,153],"#MPU6050 GY-521 6DOF IMU accelerometer gyroscope I2C 3.3V#Calibration#{11}":[154,155]},"outlinks":[{"title":"sensors","target":"sensors","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":24},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":24},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":24},{"title":"ds3231-rtc-module-zs042-i2c-real-time-clock-with-battery","target":"ds3231-rtc-module-zs042-i2c-real-time-clock-with-battery","line":25},{"title":"ds3231-rtc-module-zs042-i2c-real-time-clock-with-battery","target":"ds3231-rtc-module-zs042-i2c-real-time-clock-with-battery","line":37},{"title":"ds3231-rtc-module-zs042-i2c-real-time-clock-with-battery","target":"ds3231-rtc-module-zs042-i2c-real-time-clock-with-battery","line":149},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":150},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":151},{"title":"sensors","target":"sensors","line":154}],"metadata":{"description":"6-axis IMU with onboard DMP — 3-axis accelerometer + 3-axis gyroscope on one chip, I2C interface. The DMP does sensor fusion onboard so your MCU doesn't have to. I2C address 0x68 (conflicts with DS3231 RTC!)","topics":["[[sensors]]"],"status":"verified","quantity":12,"voltage":[3.3],"interfaces":["I2C"],"logic_level":"mixed","logic_notes":"The MPU-6050 silicon is 3.3V, but common GY-521 breakouts accept 5V VCC and often work on mixed-voltage I2C buses depending on onboard pull-ups.","manufacturer":"InvenSense (TDK)","part_number":"MPU-6050","i2c_address":"0x68 (default), 0x69 (AD0 pin HIGH)","breakout_board":"GY-521","pinout":"GY-521 breakout board:\nVCC  → 3.3-5V (onboard 3.3V regulator)\nGND  → Ground\nSCL  → I2C clock\nSDA  → I2C data\nXDA  → Auxiliary I2C data (for external magnetometer)\nXCL  → Auxiliary I2C clock (for external magnetometer)\nAD0  → Address select (LOW=0x68, HIGH=0x69)\nINT  → Interrupt output (data ready, motion detect, etc.)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]"],"conflicts_with":["[[ds3231-rtc-module-zs042-i2c-real-time-clock-with-battery]] (I2C address 0x68 conflict — use AD0 pin to shift MPU6050 to 0x69)"],"used_in":[],"warnings":["I2C address 0x68 CONFLICTS with DS3231 RTC — if using both, pull AD0 HIGH to shift MPU6050 to 0x69","GY-521 breakout accepts 5V but the MPU-6050 is a 3.3V chip — the onboard regulator handles this","Accelerometer and gyro need calibration — raw readings have offset. Run calibration routine and store offsets","INT pin is open-drain — needs pull-up resistor if used"],"datasheet_url":"https://invensense.tdk.com/products/motion-tracking/6-axis/mpu-6050/"},"task_lines":[],"tasks":{},"codeblock_ranges":[[108,118]],"key":"docs/parts/mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3.md"},
