 System#Installation Notes#{2}":[98,98],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{3}":[99,99],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{4}":[100,100],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{5}":[101,101],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{6}":[102,103],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{7}":[104,106],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{8}":[107,107],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{9}":[108,108],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{10}":[109,109],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{11}":[110,110],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{12}":[111,112],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{13}":[113,113],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{14}":[114,115]},"outlinks":[{"title":"power","target":"power","line":3},{"title":"emergency-stop-nc-button-with-dc-contactor-for-36v","target":"emergency-stop-nc-button-with-dc-contactor-for-36v","line":21},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":21},{"title":"lm2596-adjustable-buck-converter-module-3a-step-down","target":"lm2596-adjustable-buck-converter-module-3a-step-down","line":21},{"title":"main-power-switch-anl-fuse-100a-disconnect-for-36v","target":"main-power-switch-anl-fuse-100a-disconnect-for-36v","line":21},{"title":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","target":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","line":21},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":107},{"title":"main-power-switch-anl-fuse-100a-disconnect-for-36v","target":"main-power-switch-anl-fuse-100a-disconnect-for-36v","line":108},{"title":"emergency-stop-nc-button-with-dc-contactor-for-36v","target":"emergency-stop-nc-button-with-dc-contactor-for-36v","line":109},{"title":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","target":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","line":110},{"title":"lm2596-adjustable-buck-converter-module-3a-step-down","target":"lm2596-adjustable-buck-converter-module-3a-step-down","line":111},{"title":"power","target":"power","line":114}],"metadata":{"description":"Central power distribution hub for 36V rover — fused terminal block with individual circuit protection per output. 100A input capacity, 6+ independent output circuits with blade fuses. Sits between main disconnect switch and all loads","topics":["[[power]]"],"status":"needs-test","quantity":1,"voltage":[36],"interfaces":["Terminal"],"logic_level":"N/A (power distribution, no logic)","manufacturer":"Various (Blue Sea Systems, Bussmann)","pinout":"Input:\n  +36V IN  → From main disconnect switch output (#4 AWG)\n  GND IN   → From battery negative (star ground)\nOutput circuits (6+ fused outputs):\n  Circuit 1 → RioRand MC1 (Front Left) - 20A fuse\n  Circuit 2 → RioRand MC2 (Front Right) - 20A fuse\n  Circuit 3 → RioRand MC3 (Rear Left) - 20A fuse\n  Circuit 4 → RioRand MC4 (Rear Right) - 20A fuse\n  Circuit 5 → LM2596 Buck #1 (12V out) - 5A fuse\n  Circuit 6 → LM2596 Buck #2 (5V out) - 5A fuse\n","compatible_with":["[[hoverboard-10s-lithium-ion-battery-pack-36v-with-bms]]","[[main-power-switch-anl-fuse-100a-disconnect-for-36v]]","[[emergency-stop-nc-button-with-dc-contactor-for-36v]]","[[riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input]]","[[lm2596-adjustable-buck-converter-module-3a-step-down]]"],"used_in":[],"warnings":["100A main input — use #4 AWG minimum for input wiring","Individual fuses MUST be rated for 36V DC — standard automotive blade fuses may only be rated for 32V","Use DC-rated fuses only — AC fuses cannot safely interrupt DC arcs","Torque all terminal screws to manufacturer spec — loose connections cause heating and fire","Label every circuit — you will thank yourself when troubleshooting at 2 AM","Keep total load below 80% of input capacity for derating"],"datasheet_url":"","tags":["#10-14"]},"task_lines":[],"tasks":{},"codeblock_ranges":[[60,75],[79,93]],"key":"docs/parts/power-distribution-board-fused-terminal-block-for-36v-system.md"},"smart_blocks:docs/parts/power-distribution-board-fused-terminal-block-for-36v-system.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1dd49","at":1776210477079},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03349156,0.00449736,0.05115258,-0.01725814,-0.0313441,0.03603346,0.00080139,0.06319502,0.02618766,0.02768645,0.03447051,-0.0762966,0.02870041,0.01157144,0.02276229,0.0409761,0.01586756,-0.01715949,0.01976471,-0.018198,0.07121813,-0.07291898,-0.03738242,-0.00471141,0.02530675,0.02863715,-0.00428803,-0.0565858,-0.06062296,-0.23683068,0.03779212,0.01793312,-0.02398076,-0.03756519,-0.01575071,-0.07785361,-0.03660619,-0.02177715,-0.03680814,-0.00528292,0.05384615,-0.00569506,-0.00030978,-0.04012945,-0.02192539,-0.03412966,-0.04234197,-0.000501,0.09946337,-0.07189245,0.04050977,-0.03546925,0.04586646,-0.05975083,0.00886669,-0.02216967,0.0158274,0.08834364,0.04970254,0.02573037,0.02765508,0.10393681,-0.19666186,0.05786945,0.11634111,0.02234557,-0.05845092,-0.02563162,0.0231049,0.04526355,-0.00065801,-0.02581496,0.00615856,0.02303327,-0.03402497,0.0116453,-0.01060038,-0.02999601,-0.01212152,-0.01719078,-0.04057663,-0.01323826,-0.05954297,0.00653374,-0.05594196,-0.00917273,0.06115486,0.03350866,-0.00793435,0.03765097,-0.02305208,0.0078252,0.04919453,0.02808299,-0.04883261,-0.0424435