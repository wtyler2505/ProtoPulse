oard — Fused Terminal Block for 36V System#Installation Notes#{7}":[104,106],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{8}":[107,107],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{9}":[108,108],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{10}":[109,109],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{11}":[110,110],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{12}":[111,112],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{13}":[113,113],"#Power Distribution Board — Fused Terminal Block for 36V System#Installation Notes#{14}":[114,115]},"outlinks":[{"title":"power","target":"power","line":3},{"title":"emergency-stop-nc-button-with-dc-contactor-for-36v","target":"emergency-stop-nc-button-with-dc-contactor-for-36v","line":21},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":21},{"title":"lm2596-adjustable-buck-converter-module-3a-step-down","target":"lm2596-adjustable-buck-converter-module-3a-step-down","line":21},{"title":"main-power-switch-anl-fuse-100a-disconnect-for-36v","target":"main-power-switch-anl-fuse-100a-disconnect-for-36v","line":21},{"title":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","target":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","line":21},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":107},{"title":"main-power-switch-anl-fuse-100a-disconnect-for-36v","target":"main-power-switch-anl-fuse-100a-disconnect-for-36v","line":108},{"title":"emergency-stop-nc-button-with-dc-contactor-for-36v","target":"emergency-stop-nc-button-with-dc-contactor-for-36v","line":109},{"title":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","target":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","line":110},{"title":"lm2596-adjustable-buck-converter-module-3a-step-down","target":"lm2596-adjustable-buck-converter-module-3a-step-down","line":111},{"title":"power","target":"power","line":114}],"metadata":{"description":"Central power distribution hub for 36V rover — fused terminal block with individual circuit protection per output. 100A input capacity, 6+ independent output circuits with blade fuses. Sits between main disconnect switch and all loads","topics":["[[power]]"],"status":"needs-test","quantity":1,"voltage":[36],"interfaces":["Terminal"],"logic_level":"N/A (power distribution, no logic)","manufacturer":"Various (Blue Sea Systems, Bussmann)","pinout":"Input:\n  +36V IN  → From main disconnect switch output (#4 AWG)\n  GND IN   → From battery negative (star ground)\nOutput circuits (6+ fused outputs):\n  Circuit 1 → RioRand MC1 (Front Left) - 20A fuse\n  Circuit 2 → RioRand MC2 (Front Right) - 20A fuse\n  Circuit 3 → RioRand MC3 (Rear Left) - 20A fuse\n  Circuit 4 → RioRand MC4 (Rear Right) - 20A fuse\n  Circuit 5 → LM2596 Buck #1 (12V out) - 5A fuse\n  Circuit 6 → LM2596 Buck #2 (5V out) - 5A fuse\n","compatible_with":["[[hoverboard-10s-lithium-ion-battery-pack-36v-with-bms]]","[[main-power-switch-anl-fuse-100a-disconnect-for-36v]]","[[emergency-stop-nc-button-with-dc-contactor-for-36v]]","[[riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input]]","[[lm2596-adjustable-buck-converter-module-3a-step-down]]"],"used_in":[],"warnings":["100A main input — use #4 AWG minimum for input wiring","Individual fuses MUST be rated for 36V DC — standard automotive blade fuses may only be rated for 32V","Use DC-rated fuses only — AC fuses cannot safely interrupt DC arcs","Torque all terminal screws to manufacturer spec — loose connections cause heating and fire","Label every circuit — you will thank yourself when troubleshooting at 2 AM","Keep total load below 80% of input capacity for derating"],"datasheet_url":"","tags":["#10-14"]},"task_lines":[],"tasks":{},"codeblock_ranges":[[60,75],[79,93]],"key":"docs/parts/power-distribution-board-fused-terminal-block-for-36v-system.md"},
