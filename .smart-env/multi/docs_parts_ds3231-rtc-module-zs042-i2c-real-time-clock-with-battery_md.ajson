-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":27},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":27},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":27},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":27},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":27},{"title":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","target":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","line":28},{"title":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","target":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","line":38},{"title":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","target":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","line":125},{"title":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","target":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","line":126},{"title":"ina219-high-side-current-sensor-26v-i2c-for-power-monitoring","target":"ina219-high-side-current-sensor-26v-i2c-for-power-monitoring","line":127},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":128},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":129},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":130},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":131},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":132},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":133},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":134},{"title":"sensors","target":"sensors","line":137}],"metadata":{"description":"Temperature-compensated RTC that keeps time to +/-2 minutes per year — I2C interface, CR2032 backup battery, and 4KB EEPROM on the ZS-042 board. I2C address 0x68 CONFLICTS with MPU6050!","topics":["[[sensors]]"],"status":"needs-test","quantity":1,"voltage":[3.3,5],"interfaces":["I2C"],"logic_level":"3.3V/5V (open-drain I2C with pull-ups)","manufacturer":"Maxim Integrated (Analog Devices)","part_number":"DS3231","breakout_board":"ZS-042","i2c_address":"0x68 (DS3231), 0x57 (AT24C32 EEPROM on board)","backup_battery":"CR2032","accuracy":"+/-2 ppm (about +/-1 minute per year)","pinout":"ZS-042 breakout board:\nVCC  → 3.3-5V supply\nGND  → Ground\nSCL  → I2C clock\nSDA  → I2C data\nSQW  → Square wave / interrupt output (1Hz, 1kHz, 4kHz, 8kHz, or alarm)\n32K  → 32.768kHz output (for external clock reference)\n\nOnboard components:\nCR2032 battery holder → backup power for timekeeping\nAT24C32 EEPROM → 4KB I2C storage at address 0x57\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"conflicts_with":["[[mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3]] (I2C address 0x68 conflict — shift MPU6050 to 0x69 via AD0 pin)"],"used_in":[],"warnings":["I2C address 0x68 CONFLICTS with MPU6050 — if using both, pull MPU6050 AD0 HIGH to shift it to 0x69","DS3231 address is FIXED at 0x68 — it cannot be changed","ZS-042 board has a charging circuit for the battery — if using non-rechargeable CR2032, REMOVE resistor R5 or the battery may leak/explode","The AT24C32 EEPROM at 0x57 may conflict with other I2C EEPROMs on the bus"],"datasheet_url":"https://datasheets.maximintegrated.com/en/ds/DS3231.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[95,112],[118,120]]},"smart_blocks:docs/parts/ds3231-rtc-module-zs042-i2c-real-time-clock-with-battery.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1icq3in","at":1776152925099},"key":"docs/parts/ds3231-rtc-module-zs042-i2c-real-time-clock-with-battery.md#---frontmatter---","lines":[1,32],"size":2059,"outlinks":[{"title":"sensors","target":"sensors","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":27},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":27},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":27},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":27},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":27},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":27},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":27},{"title":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","target":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","line":28}],"class_name":"SmartBlock"},
