V 2A#Warnings":[90,108],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{1}":[92,92],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{2}":[93,93],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{3}":[94,94],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{4}":[95,96],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{5}":[97,99],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{6}":[100,100],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{7}":[101,102],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{8}":[103,105],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{9}":[106,106],"#L298N dual H-bridge motor driver drives 2 DC motors or 1 stepper up to 46V 2A#Warnings#{10}":[107,108]},"outlinks":[{"title":"actuators","target":"actuators","line":3},{"title":"shields","target":"shields","line":3},{"title":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","target":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","line":31},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":31},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":31},{"title":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","target":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","line":100},{"title":"max7219-spi-led-driver-controls-8-digits-or-8x8-matrix-with-3-pins","target":"max7219-spi-led-driver-controls-8-digits-or-8x8-matrix-with-3-pins","line":101},{"title":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","target":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","line":103},{"title":"actuators","target":"actuators","line":106},{"title":"shields","target":"shields","line":107}],"metadata":{"description":"The go-to H-bridge for medium-power motor projects — 2A continuous per channel, 46V max, TTL inputs. Gets hot at higher currents, needs heatsink and flyback diodes","topics":["[[actuators]]","[[shields]]"],"status":"verified","quantity":2,"voltage":[5,7,12,24,36,46],"interfaces":["Digital","PWM"],"logic_level":"mixed","logic_notes":"Uses a 5V logic supply, but the IN/EN pins are TTL-threshold inputs so 3.3V MCU outputs usually work. It does not present MCU-safe logic outputs.","manufacturer":"STMicroelectronics","part_number":"L298N","pinout":"Multiwatt15 package:\nPin 1  → Current Sensing A (connect sense resistor to GND)\nPin 2  → Output 1 (motor A terminal 1)\nPin 3  → Output 2 (motor A terminal 2)\nPin 4  → VS (motor supply, up to 46V)\nPin 5  → Input 1 (TTL, bridge A direction)\nPin 6  → Enable A (TTL, PWM for speed control)\nPin 7  → Input 2 (TTL, bridge A direction)\nPin 8  → GND\nPin 9  → VSS (logic supply, 4.5-7V)\nPin 10 → Input 3 (TTL, bridge B direction)\nPin 11 → Enable B (TTL, PWM for speed control)\nPin 12 → Input 4 (TTL, bridge B direction)\nPin 13 → Output 3 (motor B terminal 1)\nPin 14 → Output 4 (motor B terminal 2)\nPin 15 → Current Sensing B (connect sense resistor to GND)\n","max_current_per_channel":"2A DC, 2.5A repetitive, 3A peak","total_current_limit":"4A total","compatible_with":["[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver]]"],"used_in":[],"warnings":["Needs external flyback diodes (fast recovery, trr < 200ns) on all motor outputs","High saturation voltage drop: 1.8-4.9V total — at 12V motor supply you lose up to 5V to the driver","25W max dissipation — NEEDS heatsink at currents above 0.5A","Separate logic supply (VSS) required: 4.5-7V with 100nF cap to GND","Motor supply (VS) needs 100nF cap to GND"],"datasheet_url":"Datasheets/l298n.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[56,69]],"key":"docs/parts/l298n-dual-h-bridge-motor-driver-drives-2-dc-motors-or-1-stepper-up-to-46v-2a.md"},
