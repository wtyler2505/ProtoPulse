ge-motor-driver-drives-2-dc-motors-or-1-stepper-up-to-46v-2a","target":"l298n-dual-h-bridge-motor-driver-drives-2-dc-motors-or-1-stepper-up-to-46v-2a","line":36},{"title":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","target":"riorand-zs-x11h-bldc-controller-6-60v-16a-with-hall-sensor-input","line":86},{"title":"dk-electronics-hw-130-motor-shield-uses-l293d-at-600ma","target":"dk-electronics-hw-130-motor-shield-uses-l293d-at-600ma","line":91},{"title":"osepp-motor-servo-shield-v1-drives-2-dc-motors-plus-servos","target":"osepp-motor-servo-shield-v1-drives-2-dc-motors-plus-servos","line":92},{"title":"l293d-dual-h-bridge-ic-600ma-per-channel-with-built-in-diodes","target":"l293d-dual-h-bridge-ic-600ma-per-channel-with-built-in-diodes","line":93},{"title":"l298n-dual-h-bridge-motor-driver-drives-2-dc-motors-or-1-stepper-up-to-46v-2a","target":"l298n-dual-h-bridge-motor-driver-drives-2-dc-motors-or-1-stepper-up-to-46v-2a","line":94},{"title":"f130s-small-dc-motor-3-5v-130-can-size","target":"f130s-small-dc-motor-3-5v-130-can-size","line":95},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":96},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":97},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":98},{"title":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","target":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","line":99},{"title":"actuators","target":"actuators","line":102},{"title":"shields","target":"shields","line":103}],"metadata":{"description":"Best motor shield in the inventory — TB6612FNG MOSFET driver is more efficient and cooler-running than L293D/L298N shields, with 1.2A continuous per channel","topics":["[[actuators]]","[[shields]]"],"status":"verified","quantity":1,"voltage":[5],"interfaces":["PWM","Digital"],"logic_level":"5V","logic_notes":"Shield is meant to stack on 5V Arduinos, but the TB6612FNG logic core itself is a lower-voltage MOSFET driver. Treat this inventory board as a 5V shield unless rewired off-board.","manufacturer":"OSEPP","part_number":"OSEPP-TBSHD-01","driver_ic":"TB6612FNG (Toshiba)","max_current_per_channel":"1.2A continuous, 3A peak","motor_supply_voltage":"4.5-13.5V","pinout":"Arduino shield format (stacks on Uno/Mega):\nAIN1 → Direction control motor A\nAIN2 → Direction control motor A\nBIN1 → Direction control motor B\nBIN2 → Direction control motor B\nPWMA → Speed control motor A (PWM)\nPWMB → Speed control motor B (PWM)\nSTBY → Standby (pull HIGH to enable)\nVM   → Motor supply (4.5-13.5V external)\nGND  → Common ground\n","compatible_with":["[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v]]"],"used_in":[],"warnings":["Motor supply (VM) is separate from logic — connect external 4.5-13.5V for motors","STBY pin must be pulled HIGH to enable outputs — some shields have a jumper for this"],"datasheet_url":"https://toshiba.semicon-storage.com/info/TB6612FNG_datasheet_en_20141001.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"docs/parts/osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel.md"},
