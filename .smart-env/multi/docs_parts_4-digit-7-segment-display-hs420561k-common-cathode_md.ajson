(MAX7219 or TM1637) or manual multiplexing with 12 pins","topics":["[[displays]]"],"status":"needs-test","quantity":1,"voltage":[5],"interfaces":["Digital"],"logic_level":"5V","manufacturer":"Generic","part_number":"HS420561K-32","pinout":"12-pin package (top, L-R): 1  A  F  2  3  B\n12-pin package (bot, L-R): E  D  DP C  G  4\nDigits: 1, 2, 3, 4 (common cathode per digit)\nSegments: A-G + DP (shared across all digits)\n","compatible_with":["[[max7219-spi-led-driver-controls-8-digits-or-8x8-matrix-with-3-pins]]","[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]"],"used_in":[],"warnings":["Common cathode — will NOT work with common-anode driver circuits","Without a driver IC, needs 12 pins and software multiplexing — use a MAX7219 or TM1637 instead","Current limiting resistors required on each segment line (220-330 ohm)"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:docs/parts/4-digit-7-segment-display-hs420561k-common-cathode.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"rmanb2","at":1776152925098},"key":"docs/parts/4-digit-7-segment-display-hs420561k-common-cathode.md#---frontmatter---","lines":[1,20],"size":1159,"outlinks":[{"title":"displays","target":"displays","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":16},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":16},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":16},