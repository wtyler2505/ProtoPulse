43,44]},"outlinks":[{"title":"actuators","target":"actuators","line":7},{"title":"eda-fundamentals","target":"eda-fundamentals","line":8},{"title":"dynamic-brake-must-be-pulsed-not-held-because-stationary-phase-shorting-overheats-mosfets","target":"dynamic-brake-must-be-pulsed-not-held-because-stationary-phase-shorting-overheats-mosfets","line":26},{"title":"wiring-dual-zs-x11h-for-hoverboard-robot","target":"wiring-dual-zs-x11h-for-hoverboard-robot","line":34},{"title":"tank-steering-replaces-mechanical-steering-with-differential-wheel-speed-control","target":"tank-steering-replaces-mechanical-steering-with-differential-wheel-speed-control","line":37},{"title":"dynamic-brake-must-be-pulsed-not-held-because-stationary-phase-shorting-overheats-mosfets","target":"dynamic-brake-must-be-pulsed-not-held-because-stationary-phase-shorting-overheats-mosfets","line":38},{"title":"h-bridge-brake-and-coast-are-distinct-stop-modes-that-beginners-conflate","target":"h-bridge-brake-and-coast-are-distinct-stop-modes-that-beginners-conflate","line":39},{"title":"actuators","target":"actuators","line":42},{"title":"eda-fundamentals","target":"eda-fundamentals","line":43}],"metadata":{"description":"On a tank-steered rover, applying brake to the inner wheel while letting the outer wheel coast creates a pivot-like deceleration that tightens the turning radius during the stop — a dual-motor-specific braking strategy that trades straight-line stopping distance for tighter maneuvering at the cost of that motor's brake thermal budget","type":"claim","source":"docs/parts/wiring-dual-zs-x11h-for-hoverboard-robot.md","confidence":"high","topics":["[[actuators]]","[[eda-fundamentals]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/asymmetric-braking-enables-tighter-turns-during-deceleration-by-braking-the-inner-wheel-while-coasting-the-outer.md"},