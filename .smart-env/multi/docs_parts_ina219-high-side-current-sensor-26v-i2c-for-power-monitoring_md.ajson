legoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":24},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":24},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":24},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":24},{"title":"power-distribution-board-fused-terminal-block-for-36v-system","target":"power-distribution-board-fused-terminal-block-for-36v-system","line":137},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":138},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":139},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":140},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":141},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":142},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":143},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":144},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":145},{"title":"sensors","target":"sensors","line":148},{"title":"power","target":"power","line":149}],"metadata":{"description":"TI high-side current/voltage sensor with 12-bit ADC — measures bus voltage (0-26V) AND current via shunt resistor simultaneously over I2C. 16 configurable addresses (0x40-0x4F) for multi-sensor setups. Essential for power monitoring on battery-powered rovers","topics":["[[sensors]]","[[power]]"],"status":"verified","quantity":2,"voltage":[3.3,5],"interfaces":["I2C"],"logic_level":"mixed","logic_notes":"The INA219 core is 3.3V-class, but common breakouts accept 3.3V or 5V VCC and expose I2C behavior that depends on the board pull-up arrangement.","manufacturer":"Texas Instruments","part_number":"INA219AIDCNR","i2c_address":"0x40 (default, A0=GND A1=GND), configurable 0x40-0x4F via A0/A1 pins","breakout_board":"Adafruit INA219 Breakout / Generic GY-INA219","pinout":"INA219 breakout module:\nVCC  → 3.3-5V (board power)\nGND  → Ground\nSCL  → I2C clock\nSDA  → I2C data\nVIN+ → High side of load (from power source)\nVIN- → Low side of load (to load)\nA0   → Address bit 0 (GND or VCC)\nA1   → Address bit 1 (GND or VCC)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"used_in":[],"warnings":["Maximum bus voltage is 26V — do NOT connect directly to a 36V battery! Use only on 12V or 5V rails, or use a voltage divider on the bus voltage pin","The shunt resistor gets HOT at high currents — 0.1 ohm at 3.2A = 1W dissipation. For higher currents, use lower shunt (0.01 ohm for up to 32A)","High-side measurement ONLY — VIN+ and VIN- are both above ground. Do not use for low-side sensing","Shunt resistor value determines current range and resolution — 0.1 ohm = +/-3.2A range, 0.01 ohm = +/-32A range","Bus voltage accuracy degrades above 26V — chip is spec'd for 26V max"],"datasheet_url":"https://www.ti.com/product/INA219"},"task_lines":[],"tasks":{},"codeblock_ranges":[[79,82],[99,124]]},"smart_blocks:docs/parts/ina219-high-side-current-sensor-26v-i2c-for-power-monitoring.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"hwfzbx","at":1776152925100},"key":"docs/parts/ina219-high-side-current-sensor-26v-i2c-for-power-monitoring.md#---frontmatter---","lines":[1,28],"size":2190,"outlinks":[{"title":"power","target":"power","line":3},{"title":"sensors","target":"sensors","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":24},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":24},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":24},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":24},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":24},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":24},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":24}],"class_name":"SmartBlock"},
