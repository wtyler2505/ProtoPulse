itle":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":24},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":24},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":24},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":24},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":24},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":24},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":24},{"title":"power-distribution-board-fused-terminal-block-for-36v-system","target":"power-distribution-board-fused-terminal-block-for-36v-system","line":137},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":138},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":139},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":140},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":141},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":142},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":143},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":144},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":145},{"title":"sensors","target":"sensors","line":148},{"title":"power","target":"power","line":149}],"metadata":{"description":"TI high-side current/voltage sensor with 12-bit ADC — measures bus voltage (0-26V) AND current via shunt resistor simultaneously over I2C. 16 configurable addresses (0x40-0x4F) for multi-sensor setups. Essential for power monitoring on battery-powered rovers","topics":["[[sensors]]","[[power]]"],"status":"verified","quantity":2,"voltage":[3.3,5],"interfaces":["I2C"],"logic_level":"mixed","logic_notes":"The INA219 core is 3.3V-class, but common breakouts accept 3.3V or 5V VCC and expose I2C behavior that depends on the board pull-up arrangement.","manufacturer":"Texas Instruments","part_number":"INA219AIDCNR","i2c_address":"0x40 (default, A0=GND A1=GND), configurable 0x40-0x4F via A0/A1 pins","breakout_board":"Adafruit INA219 Breakout / Generic GY-INA219","pinout":"INA219 breakout module:\nVCC  → 3.3-5V (board power)\nGND  → Ground\nSCL  → I2C clock\nSDA  → I2C data\nVIN+ → High side of load (from power source)\nVIN- → Low side of load (to load)\nA0   → Address bit 0 (GND or VCC)\nA1   → Address bit 1 (GND or VCC)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"used_in":[],"warnings":["Maximum bus voltage is 26V — do NOT connect directly to a 36V battery! Use only on 12V or 5V rails, or use a voltage divider on the bus voltage pin","The shunt resistor gets HOT at high currents — 0.1 ohm at 3.2A = 1W dissipation. For higher currents, use lower shunt (0.01 ohm for up to 32A)","High-side measurement ONLY — VIN+ and VIN- are both above ground. Do not use for low-side sensing","Shunt resistor value determines current range and resolution — 0.1 ohm = +/-3.2A range, 0.01 ohm = +/-32A range","Bus voltage accuracy degrades above 26V — chip is spec'd for 26V max"],"datasheet_url":"https://www.ti.com/product/INA219"},"task_lines":[],"tasks":{},"codeblock_ranges":[[79,82],[99,124]],"key":"docs/parts/ina219-high-side-current-sensor-26v-i2c-for-power-monitoring.md"},"smart_blocks:docs/parts/ina219-high-side-current-sensor-26v-i2c-for-power-monitoring.md#---frontmatter---": {"path":null,"last_embed":{"hash":"hwfzbx","at":1776210283592},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0677038,0.03509435,0.01273825,-0.06726699,0.01353892,-0.00413838,0.04053909,0.03555972,0.00087578,0.00068648,0.04388049,-0.1354478,0.04626853,0.01526159,0.0130348,-0.00282257,0.03120224,-0.03575389,0.07281914,0.05996701,0.02667969,-0.07859972,-0.01103084,-0.01166697,0.07086609,0.06873645,-0.00136742,-0.02322272,-0.03971611,-0.23630987,0.0252539,-0.0016359,-0.01759708,-0.00464762,-0.06340744,-0.07222325,-0.0091596,-0.04059265,-0.02847609,0.01408211,0.02031971,-0.00941707,-0.04601998,-0.01706058,-0.01906105,-0.07352285,-0.00558098,-0.03421234,0.04981378,0.00196059,0.02496438,-0.00349171,0.0531967,-0.00487103,0.01291687,0.05131968,0.00310128,0.05414756,0.06518624,-0.00392193,0.10534323,0.01659701,-0.19549565,0.07984524,0.06678732,0.02053889,-0.05118698,-0.04594479,0.07301588,0.03162394,-0.04290394,-0.02173007,-0.02762876,-0.00267665,-0.03688878,-0.01236488,0.0239058,-0.02231452,0.01533726,-0.0874