38 (HW-221) — When to Use Which#{4}":[114,114],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{5}":[115,115],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{6}":[116,116],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{7}":[117,117],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{8}":[118,118],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{9}":[119,119],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{10}":[120,120],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{11}":[121,122],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{12}":[123,123],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{13}":[124,124],"#HW-221 8-Channel Bidirectional Level Shifter — BSS138-Based#TXS0108E vs BSS138 (HW-221) — When to Use Which#{14}":[125,126]},"outlinks":[{"title":"passives","target":"passives","line":3},{"title":"shields","target":"shields","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":22},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":22},{"title":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","target":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","line":22},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":22},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":22},{"title":"hmc5883l-qmc5883l-3-axis-compass-magnetometer-i2c","target":"hmc5883l-qmc5883l-3-axis-compass-magnetometer-i2c","line":22},{"title":"ina219-high-side-current-sensor-26v-i2c-for-power-monitoring","target":"ina219-high-side-current-sensor-26v-i2c-for-power-monitoring","line":22},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":22},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":22},{"title":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","target":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","line":23},{"title":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","target":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","line":33},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":112},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":113},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":114},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":115},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":116},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":117},{"title":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","target":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","line":118},{"title":"ina219-high-side-current-sensor-26v-i2c-for-power-monitoring","target":"ina219-high-side-current-sensor-26v-i2c-for-power-monitoring","line":119},{"title":"hmc5883l-qmc5883l-3-axis-compass-magnetometer-i2c","target":"hmc5883l-qmc5883l-3-axis-compass-magnetometer-i2c","line":120},{"title":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","target":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","line":121},{"title":"shields","target":"shields","line":124},{"title":"passives","target":"passives","line":125}],"metadata":{"description":"8-channel BSS138-based bidirectional level shifter module — works reliably with I2C, SPI, and UART. Slower than TXS0108E but plays nice with open-drain I2C pull-ups. The go-to shifter for mixed-voltage I2C buses","topics":["[[shields]]","[[passives]]"],"status":"verified","quantity":2,"voltage":[1.8,3.3,5],"interfaces":["I2C","SPI","UART","Digital"],"logic_level":"mixed","logic_notes":"Bridge-style shifter. LV side follows the low-voltage domain, HV side follows the high-voltage domain. Best for open-drain buses like I2C.","manufacturer":"Generic (module designation HW-221)","part_number":"HW-221","pinout":"HW-221 module (8-channel):\nLV   → Low-voltage reference (1.8-3.3V)\nHV   → High-voltage reference (3.3-5V)\nGND  → Common ground (both sides)\nLV1-LV8 → Low-voltage side channels\nHV1-HV8 → High-voltage side channels\n\nEach channel uses one BSS138 N-MOSFET + two 10K pull-up resistors\n(one to LV, one to HV)\n","compatible_with":["[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c]]","[[ina219-high-side-current-sensor-26v-i2c-for-power-monitoring]]","[[hmc5883l-qmc5883l-3-axis-compass-magnetometer-i2c]]"],"alternative_to":["[[txs0108e-8-channel-bidirectional-level-shifter-auto-direction]] (TXS0108E — faster for push-pull signals but FAILS with I2C open-drain)"],"used_in":[],"warnings":["Maximum reliable speed is ~400kHz — fine for I2C standard/fast mode, too slow for SPI at high clock rates","Uses 10K pull-up resistors onboard — for I2C buses with many devices, the combined pull-up may be too strong (reduce bus capacitance tolerance). Check total pull-up resistance","All channels share common ground — LV GND and HV GND must be connected","Not suitable for high-speed signals (>1MHz) — use TXS0108E for fast push-pull signals","Do NOT connect high-voltage reference (HV) to anything above 5.5V — the BSS138 MOSFETs are rated for 50V Vds but the pull-ups reference HV voltage"],"datasheet_url":"https://cdn-shop.adafruit.com/datasheets/an97055.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[53,66],[82,96]]},"smart_blocks:docs/parts/hw-221-8-channel-bidirectional-level-shifter-bss138-based.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"bz4yv8","at":1776152925100},"key":"docs/parts/hw-221-8-channel-bidirectional-level-shifter-bss138-based.md#---frontmatter---","lines":[1,27],"size":2398,"outlinks":[{"title":"passives","target":"passives","line":3},{"title":"shields","target":"shields","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":22},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":22},{"title":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","target":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","line":22},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":22},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":22},{"title":"hmc5883l-qmc5883l-3-axis-compass-magnetometer-i2c","target":"hmc5883l-qmc5883l-3-axis-compass-magnetometer-i2c","line":22},{"title":"ina219-high-side-current-sensor-26v-i2c-for-power-monitoring","target":"ina219-high-side-current-sensor-26v-i2c-for-power-monitoring","line":22},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":22},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":22},{"title":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","target":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","line":23}],"class_name":"SmartBlock"},
