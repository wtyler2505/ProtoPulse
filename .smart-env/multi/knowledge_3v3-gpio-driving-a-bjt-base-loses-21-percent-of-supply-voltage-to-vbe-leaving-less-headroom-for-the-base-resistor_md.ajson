
"smart_sources:knowledge/3v3-gpio-driving-a-bjt-base-loses-21-percent-of-supply-voltage-to-vbe-leaving-less-headroom-for-the-base-resistor.md": {"path":"knowledge/3v3-gpio-driving-a-bjt-base-loses-21-percent-of-supply-voltage-to-vbe-leaving-less-headroom-for-the-base-resistor.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"12pp70k","at":1776152913893},"class_name":"SmartSource","last_import":{"mtime":1776034637759,"size":3548,"at":1776152915587,"hash":"12pp70k"},"blocks":{"#---frontmatter---":[1,10],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor":[12,69],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor#{1}":[14,27],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor#{2}":[28,28],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor#{3}":[29,30],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor#{4}":[31,62],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor#{5}":[63,63],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor#{6}":[64,65],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor#{7}":[66,66],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor#{8}":[67,67],"#3v3 GPIO driving a BJT base loses 21 percent of supply voltage to Vbe leaving less headroom for the base resistor#{9}":[68,69]},"outlinks":[{"title":"passives","target":"passives","line":6},{"title":"eda-fundamentals","target":"eda-fundamentals","line":7},{"title":"transistor-selection-trades-voltage-ceiling-for-gain-and-the-decision-boundary-is-load-voltage-plus-gpio-voltage","target":"transistor-selection-trades-voltage-ceiling-for-gain-and-the-decision-boundary-is-load-voltage-plus-gpio-voltage","line":54},{"title":"pn2222a-npn-transistor-40v-600ma-general-purpose-to92","target":"pn2222a-npn-transistor-40v-600ma-general-purpose-to92","line":60},{"title":"bjt-saturation-requires-base-current-above-collector-current-divided-by-minimum-hfe-making-base-resistor-calculation-a-forced-gain-problem","target":"bjt-saturation-requires-base-current-above-collector-current-divided-by-minimum-hfe-making-base-resistor-calculation-a-forced-gain-problem","line":63},{"title":"wireless-modules-are-overwhelmingly-3v3-making-level-shifting-the-default","target":"wireless-modules-are-overwhelmingly-3v3-making-level-shifting-the-default","line":64},{"title":"passives","target":"passives","line":67},{"title":"eda-fundamentals","target":"eda-fundamentals","line":68}],"metadata":{"description":"At 3.3V GPIO, Vbe=0.7V consumes 21% of the supply leaving only 2.6V across the base resistor -- versus 4.3V at 5V GPIO (14% loss) -- this reduced headroom constrains the base resistor to lower values (2.2K-3.3K) and shrinks the saturation overdrive margin","type":"knowledge-note","source":"docs/parts/pn2222a-npn-transistor-40v-600ma-general-purpose-to92.md","topics":["[[passives]]","[[eda-fundamentals]]"],"confidence":"high","verified":false},"task_lines":[],"tasks":{},"codeblock_ranges":[[16,18]]},