ontrollers","line":42},{"title":"power-systems","target":"power-systems","line":43}],"metadata":{"description":"JST PH 2-pin connectors are the de facto standard for LiPo batteries in dev boards, but manufacturers disagree on polarity. Connecting a reversed battery can destroy the onboard charger IC.","type":"claim","source":"docs/parts/adafruit-pygamer-samd51-handheld-gaming-board-with-tft.md","confidence":"proven","topics":["[[microcontrollers]]","[[power-systems]]"],"related_components":[]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/jst-ph-battery-connectors-have-no-universal-polarity-standard-so-reversed-connection-damages-charger-circuits.md"},"smart_blocks:knowledge/jst-ph-battery-connectors-have-no-universal-polarity-standard-so-reversed-connection-damages-charger-circuits.md#---frontmatter---": {"path":null,"last_embed":{"hash":"j4d8cf","at":1776207367569},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.08178618,0.07198686,0.0212333,-0.03393162,-0.04121771,-0.0024726,0.04669325,0.08376732,-0.03361841,-0.02849875,-0.010669,-0.06600901,0.07130437,0.05548769,0.040533,-0.01262057,-0.02038913,0.03958327,0.00999033,0.03184962,0.06732559,-0.05332838,-0.00176529,0.03226019,0.0243277,0.08056752,0.04943549,-0.04541612,-0.05424949,-0.20930296,0.00797648,-0.01791812,-0.0555641,0.03451198,-0.03980059,0.00441175,0.01145917,-0.06505897,-0.05293345,-0.01119567,-0.00936245,0.00850725,0.00525326,-0.06578802,-0.01006011,-0.03328034,-0.03807746,-0.04475579,0.05320586,-0.09026536,0.03575886,0.03278928,0.0832914,-0.02212169,0.02709881,0.03931893,0.02803901,0.03406765,0.06166288,0.02036427,0.02066863,0.01938079,-0.19217873,0.05819191,0.04869419,-0.00138107,-0.03781883,0.02827944,0.00200135,0.06495566,-0.04758374,0.01913793,-0.03043985,0.0136185,-0.08268582,-0.04294154,-0.01317468,0.00731449,-0.02605905,-0.03207486,-0.05118931,-0.09649454,-0.03594948,-0.00188496,0.01660707,0.012822,0.03346494,-0.01592563,0.02132382,0.03882364,-0.0303784,-0.00008333,0.0571196