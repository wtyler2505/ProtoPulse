8-inch TFT LCD Touch Shield — ILI9341 320x240 SPI#Libraries#{11}":[66,66],"#2.8-inch TFT LCD Touch Shield — ILI9341 320x240 SPI#Libraries#{12}":[67,68]},"outlinks":[{"title":"displays","target":"displays","line":3},{"title":"shields","target":"shields","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":21},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":21},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":21},{"title":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","target":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","line":21},{"title":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","target":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","line":58},{"title":"hd44780-1602a-16x2-lcd-character-display-runs-at-5v-parallel-or-i2c","target":"hd44780-1602a-16x2-lcd-character-display-runs-at-5v-parallel-or-i2c","line":59},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":60},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":61},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":62},{"title":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","target":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","line":63},{"title":"displays","target":"displays","line":66},{"title":"shields","target":"shields","line":67}],"metadata":{"description":"2.8-inch color TFT LCD with resistive touchscreen — ILI9341 driver, 320x240 pixels, Arduino shield form factor, SPI interface","topics":["[[displays]]","[[shields]]"],"status":"needs-test","quantity":1,"voltage":[3.3,5],"interfaces":["SPI","GPIO"],"logic_level":"mixed","logic_notes":"The ILI9341 controller is a 3.3V device, but this Arduino shield includes onboard level shifting and routing specifically for 5V Uno/Mega compatibility.","manufacturer":"Generic","part_number":"TFT-2.8-ILI9341","pinout":"Shield form factor — plugs directly into Arduino Uno/Mega headers\nUses SPI for display data\nTouch uses analog pins for resistive touch reading\nD10 → TFT CS\nD9  → TFT DC\nD8  → TFT Reset (some variants)\nICSP → SPI (MOSI, MISO, SCK)\nA0-A3 → Resistive touch (XP, XM, YP, YM)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v]]"],"used_in":[],"warnings":["Occupies most Arduino Uno pins when mounted as shield — limited remaining I/O","ILI9341 logic is 3.3V — shield has onboard level shifting for 5V Arduino compatibility","Resistive touch requires calibration — run a calibration sketch to get correct coordinate mapping","SPI bus is shared — if using with SD card or other SPI devices, manage CS pins carefully"],"datasheet_url":"https://cdn-shop.adafruit.com/datasheets/ILI9341.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[49,53]],"key":"docs/parts/2p8-inch-tft-lcd-touch-shield-ili9341-320x240-spi.md"},"smart_blocks:docs/parts/2p8-inch-tft-lcd-touch-shield-ili9341-320x240-spi.md#---frontmatter---": {"path":null,"last_embed":{"hash":"a859sy","at":1776209686439},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.07839702,0.00526021,0.00369449,-0.02548431,-0.05468617,-0.0151778,0.06894669,0.0837735,-0.01052471,0.01031157,0.0031502,-0.07619128,0.00180581,0.0390381,0.04406508,0.02070024,-0.00199238,-0.01953011,0.02420878,0.023159