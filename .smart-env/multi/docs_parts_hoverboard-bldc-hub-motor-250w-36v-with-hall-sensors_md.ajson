th-hall-sensor-input]]"],"used_in":[],"warnings":["36V system — dangerous voltage, observe safety precautions","Phase wire order matters — wrong order = motor spins backward or vibrates violently","Hall sensor cable is delicate — strain relief recommended","~15A peak draw — requires properly rated wiring (14AWG minimum for motor phases)"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"docs/parts/hoverboard-bldc-hub-motor-250w-36v-with-hall-sensors.md"},"smart_blocks:docs/parts/hoverboard-bldc-hub-motor-250w-36v-with-hall-sensors.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1em806m","at":1776210263968},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05574152,0.03396358,0.02795843,-0.07053148,-0.04931958,0.02827427,0.03285032,0.03386164,0.00897001,-0.00011853,0.0351144,-0.12696683,0.00574249,0.05442226,-0.02688579,0.01816419,0.01425546,0.05062908,0.08500024,0.06000356,0.02907939,-0.016308,0.01998527,0.00322571,0.04377373,0.03879309,0.00992464,-0.00393796,-0.07060859,-0.22949161,0.04775819,-0.02591349,0.01274607,-0.00093668,-0.01611682,-0.04673444,0.01907804,0.00062736,-0.01004895,-0.01730345,0.02411086,-0.03567072,-0.01793396,-0.01268701,-0.03908118,-0.0539257,0.01310586,-0.0415887,0.05807028,-0.02814746,0.00662907,-0.06309894,0.05039564,-0.09955896,0.01979698,0.04847319,-0.00001305,0.0486558,0.03979509,0.00858238,0.05763556,0.03668139,-0.166912,0.08141501,0.10080837,0.04842949,-0.07001941,-0.0404423,0.05437493,0.09264287,0.00802907,-0.06874924,-0.0321546,0.01258762,-0.00726983,-0.02983154,-0.01899764,-0.05295367,0.01170466,-0.02303871,-0.04287582,-0.00772459,-0.02583592,0.02193994,-0.01850955,-0.03163404,0.05083746,0.00852974,-0.00431606,0.01505913,-0.01365534,-0.04300907,-0.00151169,-0.04887871,-0.09085165,-0.02102189,0.0066499,0.00471171,-0.04377026,0.09777257,-0.04218129,-0.00975429,-0.0048498,-0.04315865,0.03294923,-0.04041965,0.02225048,-0.00284853,-0.03306203,-0.00392469,0.04248582,0.00375772,0.00636895,-0.02050752,0.0