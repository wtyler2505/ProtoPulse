
"smart_sources:knowledge/npo-c0g-dielectric-is-mandatory-for-crystal-load-capacitors-because-temperature-driven-capacitance-drift-shifts-oscillator-frequency.md": {"path":"knowledge/npo-c0g-dielectric-is-mandatory-for-crystal-load-capacitors-because-temperature-driven-capacitance-drift-shifts-oscillator-frequency.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"5hwtq","at":1776152919869},"class_name":"SmartSource","last_import":{"mtime":1776032219037,"size":2953,"at":1776152920222,"hash":"5hwtq"},"blocks":{"#---frontmatter---":[1,10],"#NPO/C0G dielectric is mandatory for crystal load capacitors because temperature-driven capacitance drift shifts oscillator frequency":[12,40],"#NPO/C0G dielectric is mandatory for crystal load capacitors because temperature-driven capacitance drift shifts oscillator frequency#{1}":[14,32],"#NPO/C0G dielectric is mandatory for crystal load capacitors because temperature-driven capacitance drift shifts oscillator frequency#{2}":[33,33],"#NPO/C0G dielectric is mandatory for crystal load capacitors because temperature-driven capacitance drift shifts oscillator frequency#{3}":[34,34],"#NPO/C0G dielectric is mandatory for crystal load capacitors because temperature-driven capacitance drift shifts oscillator frequency#{4}":[35,36],"#NPO/C0G dielectric is mandatory for crystal load capacitors because temperature-driven capacitance drift shifts oscillator frequency#{5}":[37,37],"#NPO/C0G dielectric is mandatory for crystal load capacitors because temperature-driven capacitance drift shifts oscillator frequency#{6}":[38,38],"#NPO/C0G dielectric is mandatory for crystal load capacitors because temperature-driven capacitance drift shifts oscillator frequency#{7}":[39,40]},"outlinks":[{"title":"passives","target":"passives","line":6},{"title":"eda-fundamentals","target":"eda-fundamentals","line":7},{"title":"crystal-load-capacitance-equals-the-series-combination-of-two-matched-caps-plus-stray-capacitance","target":"crystal-load-capacitance-equals-the-series-combination-of-two-matched-caps-plus-stray-capacitance","line":33},{"title":"78xx-regulators-require-input-and-output-capacitors-close-to-pins-for-stability","target":"78xx-regulators-require-input-and-output-capacitors-close-to-pins-for-stability","line":34},{"title":"ds3231-tcxo-accuracy-is-orders-of-magnitude-better-than-ds1307-crystal-drift-making-ds1307-obsolete-for-most-projects","target":"ds3231-tcxo-accuracy-is-orders-of-magnitude-better-than-ds1307-crystal-drift-making-ds1307-obsolete-for-most-projects","line":35},{"title":"passives","target":"passives","line":38},{"title":"eda-fundamentals","target":"eda-fundamentals","line":39}],"metadata":{"description":"NPO/C0G ceramic capacitors drift less than 1% across temperature, while X7R drifts ~15% and Y5V can lose up to 80% of rated capacitance -- since crystal oscillator frequency depends directly on load capacitance, using a temperature-unstable dielectric means the clock drifts with ambient temperature","type":"knowledge-note","source":"docs/parts/22pf-ceramic-capacitor-npo-50v-crystal-load-cap.md","topics":["[[passives]]","[[eda-fundamentals]]"],"confidence":"high","verified":false},"task_lines":[],"tasks":{},"codeblock_ranges":[]},