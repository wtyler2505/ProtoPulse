ned inrush from tripping shared BMS overcurrent protection#{8}":[52,52],"#staggered motor startup by 100ms prevents combined inrush from tripping shared BMS overcurrent protection#{9}":[53,53],"#staggered motor startup by 100ms prevents combined inrush from tripping shared BMS overcurrent protection#{10}":[54,54],"#staggered motor startup by 100ms prevents combined inrush from tripping shared BMS overcurrent protection#{11}":[55,56],"#staggered motor startup by 100ms prevents combined inrush from tripping shared BMS overcurrent protection#{12}":[57,57],"#staggered motor startup by 100ms prevents combined inrush from tripping shared BMS overcurrent protection#{13}":[58,58],"#staggered motor startup by 100ms prevents combined inrush from tripping shared BMS overcurrent protection#{14}":[59,59],"#staggered motor startup by 100ms prevents combined inrush from tripping shared BMS overcurrent protection#{15}":[60,61]},"outlinks":[{"title":"actuators","target":"actuators","line":7},{"title":"power-systems","target":"power-systems","line":8},{"title":"eda-fundamentals","target":"eda-fundamentals","line":9},{"title":"bms-discharge-port-is-the-sole-power-output-so-a-bms-trip-kills-the-mcu-along-with-the-motors","target":"bms-discharge-port-is-the-sole-power-output-so-a-bms-trip-kills-the-mcu-along-with-the-motors","line":14},{"title":"four-motor-bldc-systems-exceed-standard-hoverboard-bms-ratings-requiring-firmware-current-limiting","target":"four-motor-bldc-systems-exceed-standard-hoverboard-bms-ratings-requiring-firmware-current-limiting","line":26},{"title":"wiring-dual-zs-x11h-for-hoverboard-robot","target":"wiring-dual-zs-x11h-for-hoverboard-robot","line":49},{"title":"four-motor-bldc-systems-exceed-standard-hoverboard-bms-ratings-requiring-firmware-current-limiting","target":"four-motor-bldc-systems-exceed-standard-hoverboard-bms-ratings-requiring-firmware-current-limiting","line":52},{"title":"bms-discharge-port-is-the-sole-power-output-so-a-bms-trip-kills-the-mcu-alon