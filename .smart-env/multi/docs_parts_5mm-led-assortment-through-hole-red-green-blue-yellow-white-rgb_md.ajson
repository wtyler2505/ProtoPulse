hardware-uarts","line":23},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":23},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":23},{"title":"dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb","target":"dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb","line":23},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":23},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":23},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":23},{"title":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","target":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","line":23},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":23},{"title":"74hc595-8-bit-shift-register-serial-to-parallel-dip16","target":"74hc595-8-bit-shift-register-serial-to-parallel-dip16","line":145},{"title":"ws2812b-neopixel-ring-status-led-array-for-system-feedback","target":"ws2812b-neopixel-ring-status-led-array-for-system-feedback","line":146},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":147},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":148},{"title":"passives","target":"passives","line":151}],"metadata":{"description":"Assorted 5mm through-hole LEDs in 7 colors — Red, Green, Blue, Yellow, White, Clear, and common-cathode RGB. 20mA typical current. ALWAYS use a current limiting resistor or you'll fry the LED and possibly the GPIO pin","topics":["[[passives]]"],"status":"needs-test","quantity":35,"voltage":[1.8,2,2.2,3,3.4],"interfaces":["GPIO"],"logic_level":"N/A (passive component)","manufacturer":"Generic","part_number":"","pinout":"Standard LED (2 pins):\n  Long leg  → Anode (+) — connect to resistor → GPIO or VCC\n  Short leg → Cathode (-) — connect to GND\n  Flat side of lens = cathode side\n\nRGB LED (4 pins, common cathode):\n  Pin 1 (longest) → Common cathode → GND\n  Pin 2 → Red anode → resistor → GPIO\n  Pin 3 → Green anode → resistor → GPIO\n  Pin 4 → Blue anode → resistor → GPIO\n  (pin order varies — check with a coin cell battery)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v]]","[[dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"used_in":[],"warnings":["ALWAYS use current limiting resistor — direct connection to GPIO will damage LED and possibly the pin","Long leg = anode (+), short leg = cathode (-)","Blue and white LEDs have higher forward voltage (~3.0-3.4V) — may be dim at 3.3V without sufficient headroom","RGB LEDs need 3 resistors — one per color channel","Max forward current is typically 20mA — exceeding this shortens LED life or destroys it"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[49,61],[65,68],[72,77],[83,96],[100,133]],"key":"docs/parts/5mm-led-assortment-through-hole-red-green-blue-yellow-white-rgb.md"},"smart_blocks:docs/parts/5mm-led-assor