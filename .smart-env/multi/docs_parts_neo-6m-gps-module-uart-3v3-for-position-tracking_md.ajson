-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":20},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":20},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":20},{"title":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","target":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","line":118},{"title":"hmc5883l-qmc5883l-3-axis-compass-magnetometer-i2c","target":"hmc5883l-qmc5883l-3-axis-compass-magnetometer-i2c","line":119},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":120},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":121},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":122},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":123},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":124},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":125},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":126},{"title":"sensors","target":"sensors","line":129},{"title":"communication","target":"communication","line":130}],"metadata":{"description":"U-blox GPS receiver for outdoor position tracking — UART at 9600 baud default, 2.5m accuracy, 50-channel. Cold start 30-45s. 3.3V logic but most modules have 5V regulator. Essential for waypoint navigation, useless indoors","topics":["[[sensors]]","[[communication]]"],"status":"verified","quantity":1,"voltage":[3.3,5],"interfaces":["UART"],"logic_level":"mixed","logic_notes":"Most breakout boards accept 5V power through an onboard regulator, but the UART signals are still 3.3V and the GPS RX pin must not see a raw 5V TX signal.","manufacturer":"U-blox","part_number":"NEO-6M","pinout":"NEO-6M module (typical breakout):\nVCC  → 3.3-5V (module has onboard 3.3V regulator)\nGND  → Ground\nTX   → UART transmit (GPS → MCU) — 3.3V logic\nRX   → UART receive (MCU → GPS) — 3.3V logic\nPPS  → Pulse per second (optional, 1Hz timing)\n","level_shifter_needed":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]"],"compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"used_in":[],"warnings":["TX/RX are 3.3V logic — do NOT connect RX directly to a 5V TX pin without a voltage divider or level shifter","Requires clear sky view — will NOT work indoors, under dense tree canopy, or in urban canyons","Cold start takes 30-45 seconds for first fix — be patient, it's acquiring satellites","Antenna must face up (toward sky) — ceramic patch antenna is directional","GPS heading is ONLY valid when moving >0.5 m/s — stationary heading is random noise","Some modules have an EEPROM battery for hot start — if battery dies, every start is a cold start"],"datasheet_url":"https://www.u-blox.com/en/product/neo-6-series"},"task_lines":[],"tasks":{},"codeblock_ranges":[[83,107]],"key":"docs/parts/neo-6m-gps-module-uart-3v3-for-position-tracking.md"},"smart_blocks:docs/parts/neo-6m-gps-module-uart-3v3-for-position-tracking.md#---frontmatter---": {"path":null,"last_embed":{"hash":"2aynu","at":1776210371923},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03149762,0.01807936,0.04729659,-0.05387268,0.00434865,-0.00038234,-0.01043723,0.05567332,0.02375535,0.01660602,0.03766983,-0.10991613,0.02751217,0.03333947,0.02494616,-0.04358092,0.01140583,0.04136698,0.13134989,0.05005495,0.04751839,-0.03465396,-0.00964143,0.00502066,0.04371561,0.09212794,-0.03032695,-0.00992302,-0.01266508,-0.21100076,-0.00786121,-0.02330272,0.00211858,0.00710332,-0.07589378,-0.05759406,-0.04054229,-0.04993224,-0.02901833,0.00481116,0.04208613,-0.01560433,-0.05602498,-0.03644155,-0.01196029,-0.05973668,-0.01860484,-0.0415807,0.01920793,-0.03303255,0.02281324,0.00981547,0.01209939,-0.00934653,0.06235965,0.04819942,0.03651961,0.01736382,0.02607189,0.00672448,0.03186474,0.05164662,-0.21730757,0.0707026,0.03580384,0.0053854,-0.01078133,-0.02087922,0.03354803,0.04894368,-0.02646155,0.0023002,-0.03371246,0.04042694,-0.02004431,0.00586579,0.00023294,-0.02700407,-0.00612982,-0.02127315,-0.00186002,0.04387246,-0.0630773,0.01342449,-0.00487751,-0.06641499,0.04035885,0.00705521,-0.0146021,0.0747852,-0.00860015,-0.03268406,-0.01649447,0.02551405,-0.02073332,-0.04978859,0.0267667,-0.04061174,-0.06812415,0.08135363,0.02187921,0.06378893,0.01447146,0.02367012,0.0461072,-0.05998287,-0.0286159,-0.02423595,-0.06218252,0.00725874,0.0572058,-0.00964551,0.01602877,-0.0511447,0.00059182,0.08942333,0.00068766,0.02362678,0.01125097,0.02776861,-0.058478,-0.01259861,0.11247356,-0.00207511,0.04224761,-0.03503881,-0.00883744,0.08519481,-0.02469562,0.11644962,0.07085691,-0.01130255,-0.04230061,-0.00379559,-0.00566895,0.0109141,0.05168826,0.04037866,-0.01354559,0.00276731,-0.06170134,0.01671638,0.06535686,-0.07129196,-0.03146973,0.00818328,-0.09279049,-0.01781524,-0.01630417,-0.07772972,-0.02427331,0.04666729,0.02038785,-0.03843197,0.01343326,0.04273439,0.0032728,0.082