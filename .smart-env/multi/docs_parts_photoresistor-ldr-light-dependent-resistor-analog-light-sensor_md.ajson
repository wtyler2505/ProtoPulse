t Resistor, Analog Light Sensor#ESP32 Notes#{3}":[92,92],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#ESP32 Notes#{4}":[93,94],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases":[95,112],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{1}":[97,97],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{2}":[98,98],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{3}":[99,99],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{4}":[100,100],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{5}":[101,102],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{6}":[103,105],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{7}":[106,106],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{8}":[107,107],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{9}":[108,109],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{10}":[110,110],"#Photoresistor (LDR) — Light-Dependent Resistor, Analog Light Sensor#Use Cases#{11}":[111,112]},"outlinks":[{"title":"sensors","target":"sensors","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":15},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":15},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":15},{"title":"dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb","target":"dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb","line":15},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":15},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":15},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":15},{"title":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","target":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","line":15},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":15},{"title":"soil-moisture-sensor-capacitive-analog-3v3-5v","target":"soil-moisture-sensor-capacitive-analog-3v3-5v","line":101},{"title":"soil-moisture-sensor-capacitive-analog-3v3-5v","target":"soil-moisture-sensor-capacitive-analog-3v3-5v","line":106},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":107},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":108},{"title":"sensors","target":"sensors","line":111}],"metadata":{"description":"Cadmium sulfide LDR — resistance drops from ~1M ohm in darkness to ~100 ohm in bright light. Dead simple analog light sensor, but needs a 10K voltage divider to read with an ADC. No polarity, 2 pins","topics":["[[sensors]]"],"status":"needs-test","quantity":5,"voltage":[3.3,5],"interfaces":["Analog"],"logic_level":"N/A (passive resistive element)","manufacturer":"Generic","part_number":"","pinout":"2-pin (no polarity):\n  Pin 1 → VCC (3.3V or 5V)\n  Pin 2 → Analog input + 10K resistor to GND (voltage divider)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v]]","[[dccduino-nano-is-an-arduino-nano-clone-with-ch340-usb]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"used_in":[],"warnings":["Must use voltage divider — without the 10K pulldown resistor, ADC reads won't be useful","Not suitable for precision light measurement — response is logarithmic and varies between units","Contains cadmium sulfide (CdS) — RoHS restricted in some applications","Slow response time (~20-30ms rise, ~30ms fall) — not suitable for fast light changes or optical communication"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[42,52],[65,86]],"key":"docs/parts/photoresistor-ldr-light-dependent-resistor-analog-light-sensor.md"},"smart_blocks:docs/parts/photoresistor-ldr-light-dependent-resistor-analog-light-sensor.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1um14kg","at":1776210471181},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05517635,0.04048146,-0.01848504,0.00807403,-0.03254581,-0.00518102,0.03474253,0.05036207,-0.06145218,0.03213571,0.0155649,-0.09194208,-0.00840972,0.06523896,0.09323156,-0.0162904,-0.00372124,-0.02301835,0.05295425,0.01060036,0.10249975,-0.07950696,-0.04461472,-0.01334531,0.03463677,0.07034106,0.02872047,-0.04387645,-0.08276204,-0.23518232,-0.00230721,-0.03048914,0.00983363,-0.01600158,-0.05063455,-0.0439098,-0.02184641,-0.03883817,-0.0413135,0.01415236,-0.02060309,-0.06139785,0.00331447,-0.01465179,-0.01584111,-0.07522154,-0.02942875,-0.05754847,0.04248374,-0.07608846,0.015085,-0.01417648,0.07714519,-0.04466935,0.04049457,0.02878814,-0.00405501,0.06229888,0.11670896,0.01220355,0.04870725,0.08229735,-0.17444351,0.11293358,0.04836666,0.03209528,-0.01655514,-0.024241