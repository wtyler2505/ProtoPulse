
"smart_sources:knowledge/l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path.md": {"path":"knowledge/l293d-voltage-drop-is-1-4v-per-switch-totaling-2-8v-across-the-full-h-bridge-path.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"4sj4wl","at":1776152919867},"class_name":"SmartSource","last_import":{"mtime":1776012289407,"size":3101,"at":1776152920218,"hash":"4sj4wl"},"blocks":{"#---frontmatter---":[1,10],"#l293d voltage drop is 1-4v per switch totaling 2-8v across the full h-bridge path":[12,45],"#l293d voltage drop is 1-4v per switch totaling 2-8v across the full h-bridge path#{1}":[14,36],"#l293d voltage drop is 1-4v per switch totaling 2-8v across the full h-bridge path#{2}":[37,37],"#l293d voltage drop is 1-4v per switch totaling 2-8v across the full h-bridge path#{3}":[38,38],"#l293d voltage drop is 1-4v per switch totaling 2-8v across the full h-bridge path#{4}":[39,40],"#l293d voltage drop is 1-4v per switch totaling 2-8v across the full h-bridge path#{5}":[41,41],"#l293d voltage drop is 1-4v per switch totaling 2-8v across the full h-bridge path#{6}":[42,42],"#l293d voltage drop is 1-4v per switch totaling 2-8v across the full h-bridge path#{7}":[43,43],"#l293d voltage drop is 1-4v per switch totaling 2-8v across the full h-bridge path#{8}":[44,45]},"outlinks":[{"title":"actuators","target":"actuators","line":7},{"title":"power-systems","target":"power-systems","line":8},{"title":"eda-fundamentals","target":"eda-fundamentals","line":9},{"title":"l293d-dual-h-bridge-ic-600ma-per-channel-with-built-in-diodes","target":"l293d-dual-h-bridge-ic-600ma-per-channel-with-built-in-diodes","line":34},{"title":"l298n-saturation-voltage-drop-loses-up-to-5v-making-it-inefficient-at-high-current","target":"l298n-saturation-voltage-drop-loses-up-to-5v-making-it-inefficient-at-high-current","line":37},{"title":"motor-shield-current-ratings-form-a-graduated-selection-ladder","target":"motor-shield-current-ratings-form-a-graduated-selection-ladder","line":38},{"title":"actuator-voltage-tiers-map-to-distinct-power-supply-strategies","target":"actuator-voltage-tiers-map-to-distinct-power-supply-strategies","line":39},{"title":"actuators","target":"actuators","line":42},{"title":"power-systems","target":"power-systems","line":43},{"title":"eda-fundamentals","target":"eda-fundamentals","line":44}],"metadata":{"description":"Each L293D output transistor drops ~1.4V at rated current, and since the H-bridge has two in series (high-side + low-side), a 6V motor effectively gets only ~3.2V -- this is better than the L298N's 4.9V drop but still significant for low-voltage motors","type":"claim","source":"docs/parts/l293d-dual-h-bridge-ic-600ma-per-channel-with-built-in-diodes.md","confidence":"proven","topics":["[[actuators]]","[[power-systems]]","[[eda-fundamentals]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},