-level-shifter"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/txs0108e-oe-pin-is-active-high-and-floating-by-default-silently-disabling-all-outputs.md"},"smart_blocks:knowledge/txs0108e-oe-pin-is-active-high-and-floating-by-default-silently-disabling-all-outputs.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1v7ag2a","at":1776208066230},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03742423,-0.02283069,0.03346589,-0.03532473,-0.01696411,-0.03033294,-0.01348869,0.02184176,-0.01641494,0.04127549,0.02265188,-0.0426199,0.02635435,0.03472422,-0.02222648,-0.00922536,0.03574288,-0.00447933,0.08784527,0.01041573,0.08155459,-0.03677709,-0.01766288,-0.01773567,0.07014611,0.03870349,0.01340123,-0.00859336,-0.05801399,-0.24855427,-0.02309076,-0.00815937,0.0050495,-0.02239916,0.01231734,-0.04196604,-0.03659542,-0.01344534,-0.00068705,0.0026427,0.04281393,-0.02038888,0.02978737,-0.09504466,-0.01060737,-0.04708687,-0.00047034,0.00368696,0.05885717,-0.06078701,0.00056848,0.01870831,0.04060173,-0.02742148,0.05496277,0.03617034,0.01304648,0.07801734,0.02687906,0.01537825,0.056858,0.04123081,-0.17775814,0.09475233,0.09116352,0.00950563,0.02627903,0.01576602,0.05387328,-0.00825169,0.04070309,-0.06400436,-0.03018287,0.00565342,0.00677947,0.04370032,0.08285776,0.03492783,-0.04082396,-0.03669303,-0.01836215,-0.02539018,0.00013656,-0.02478958,-0.04503255,-0.0194215,0.00430324,0.04793669,-0.01897376,0.01435978,-0.08175198,-0.0847393,0.00372136,-0.02338446,-0.02544039,0.02990679,0.032957,-0.02320218,-0.09143477,0.08332312,-0.01062713,0.01754274,-0.00048135,-0.02502939,0.08742536,-0.03191028,-0.01559924,0.02272885,-0.06530614,-0.03119562,0.03578267,-0.04176229,0.03209952,-0.00325461,0.02883887,0.03514903,0.00438241,0.0261741,-0.00146037,0.02411129,0.00099134,0.03049342,0.0380408,0.03881256,0.0141963,-0.04972775,0.01680803,0.05083375,-0.005197,0.06757665,0.05741274,0.01517837,0.03213147,0.01611599,-0.06755538,0.01818518,0.00524646,0.02014367,0.04010566,-0.02