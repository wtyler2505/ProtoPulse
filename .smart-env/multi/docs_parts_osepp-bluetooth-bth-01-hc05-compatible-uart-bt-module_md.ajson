
"smart_sources:docs/parts/osepp-bluetooth-bth-01-hc05-compatible-uart-bt-module.md": {"path":"docs/parts/osepp-bluetooth-bth-01-hc05-compatible-uart-bt-module.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"1pn44ws","at":1776152926648},"class_name":"SmartSource","last_import":{"mtime":1773570606436,"size":3291,"at":1776152928649,"hash":"1pn44ws"},"blocks":{"#---frontmatter---":[1,24],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module":[26,73],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#{1}":[28,29],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#Specifications":[30,42],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#Specifications#{1}":[32,42],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#Wiring to Arduino (5V board)":[43,53],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#Wiring to Arduino (5V board)#{1}":[45,53],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode":[54,73],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{1}":[56,58],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{2}":[59,59],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{3}":[60,60],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{4}":[61,61],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{5}":[62,62],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{6}":[63,64],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{7}":[65,67],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{8}":[68,68],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{9}":[69,70],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{10}":[71,71],"#OSEPP Bluetooth BTH-01 — HC-05 Compatible UART BT Module#AT Command Mode#{11}":[72,73]},"outlinks":[{"title":"communication","target":"communication","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":19},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":20},{"title":"osepp-bluetooth-btm-01-hc06-compatible-uart-bt-slave","target":"osepp-bluetooth-btm-01-hc06-compatible-uart-bt-slave","line":20},{"title":"osepp-bluetooth-btm-01-hc06-compatible-uart-bt-slave","target":"osepp-bluetooth-btm-01-hc06-compatible-uart-bt-slave","line":68},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":69},{"title":"communication","target":"communication","line":72}],"metadata":{"description":"HC-05 compatible Bluetooth 4.0 module — master OR slave mode, AT command configurable, 3.3V logic but 5V VCC safe via onboard regulator","topics":["[[communication]]"],"status":"verified","quantity":1,"voltage":[3.3,5],"interfaces":["UART","Bluetooth"],"logic_level":"mixed","logic_notes":"Module power can come from 5V through the onboard regulator, but UART TX/RX are 3.3V logic. Protect RXD from raw 5V TX signals.","manufacturer":"OSEPP","part_number":"BTH-01","pinout":"VCC  → 5V (onboard 3.3V regulator)\nGND  → GND\nTXD  → MCU RX (3.3V logic out)\nRXD  → MCU TX (3.3V logic in — use voltage divider from 5V boards)\nSTATE → HIGH when connected (optional)\nEN/KEY → HIGH to enter AT command mode (optional)\n","level_shifter_needed":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]"],"compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[osepp-bluetooth-btm-01-hc06-compatible-uart-bt-slave]]"],"used_in":[],"warnings":["RXD is 3.3V — do NOT feed 5V directly from Arduino TX. Use a voltage divider (1K + 2K) or level shifter","Default baud rate is typically 9600 or 38400 — check with AT commands","EN/KEY pin must be HIGH before power-on to enter AT command mode"],"datasheet_url":"https://cdn.sparkfun.com/datasheets/Wireless/Bluetooth/HC_Serial_Blue.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:docs/parts/osepp-bluetooth-bth-01-hc05-compatible-uart-bt-module.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1t0tl7q","at":1776152926648},"key":"docs/parts/osepp-bluetooth-bth-01-hc05-compatible-uart-bt-module.md#---frontmatter---","lines":[1,24],"size":1325,"outlinks":[{"title":"communication","target":"communication","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":19},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":20},{"title":"osepp-bluetooth-btm-01-hc06-compatible-uart-bt-slave","target":"osepp-bluetooth-btm-01-hc06-compatible-uart-bt-slave","line":20}],"class_name":"SmartBlock"},
