one-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":18},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":18},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":59},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":60},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":61},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":62},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":63},{"title":"ky-040-rotary-encoder-module-incremental-with-pushbutton","target":"ky-040-rotary-encoder-module-incremental-with-pushbutton","line":64},{"title":"membrane-switch-keypad-module-tactile-button-array","target":"membrane-switch-keypad-module-tactile-button-array","line":65},{"title":"input-devices","target":"input-devices","line":68}],"metadata":{"description":"Dual-axis analog joystick with pushbutton — two potentiometers (X/Y) output 0-1023 on analog pins, center press is digital input","topics":["[[input-devices]]"],"status":"needs-test","quantity":2,"voltage":[3.3,5],"interfaces":["Analog","GPIO"],"logic_level":"mixed","logic_notes":"Passive potentiometer outputs and switch contacts follow whatever VCC you supply. Run it at 3.3V for 3.3V MCUs or 5V for 5V ADC ranges.","manufacturer":"Generic","part_number":"KY-023","pinout":"GND → GND\n+5V → VCC (3.3 or 5V)\nVRx → Analog pin (X axis)\nVRy → Analog pin (Y axis)\nSW  → Digital pin (pushbutton, active-LOW with pull-up)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]"],"used_in":[],"warnings":["SW pin needs INPUT_PULLUP — no onboard pull-up on most modules","Center position reads ~512 but varies — calibrate in software","At 3.3V VCC, analog range scales proportionally (0-675 instead of 0-1023 on 5V ADC)"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[49,54]]},"smart_blocks:docs/parts/analog-joystick-module-xy-axes-plus-pushbutton.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"r5nt39","at":1776152925098},"key":"docs/parts/analog-joystick-module-xy-axes-plus-pushbutton.md#---frontmatter---","lines":[1,22],"size":1255,"outlinks":[{"title":"input-devices","target":"input-devices","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":18},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":18},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":18},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":18},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":18}],"class_name":"SmartBlock"},
