ds","line":8},{"title":"l298n-has-no-internal-flyback-diodes-unlike-l293d-making-external-protection-mandatory","target":"l298n-has-no-internal-flyback-diodes-unlike-l293d-making-external-protection-mandatory","line":17},{"title":"the-d-suffix-on-l293d-denotes-built-in-clamp-diodes-and-the-non-d-variant-is-a-destructive-substitution","target":"the-d-suffix-on-l293d-denotes-built-in-clamp-diodes-and-the-non-d-variant-is-a-destructive-substitution","line":17},{"title":"inductive-motor-loads-require-bypass-capacitor-to-absorb-voltage-spikes-above-supply-rail","target":"inductive-motor-loads-require-bypass-capacitor-to-absorb-voltage-spikes-above-supply-rail","line":25},{"title":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","target":"osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel","line":29},{"title":"l298n-has-no-internal-flyback-diodes-unlike-l293d-making-external-protection-mandatory","target":"l298n-has-no-internal-flyback-diodes-unlike-l293d-making-external-protection-mandatory","line":32},{"title":"the-d-suffix-on-l293d-denotes-built-in-clamp-diodes-and-the-non-d-variant-is-a-destructive-substitution","target":"the-d-suffix-on-l293d-denotes-built-in-clamp-diodes-and-the-non-d-variant-is-a-destructive-substitution","line":33},{"title":"inductive-motor-loads-require-bypass-capacitor-to-absorb-voltage-spikes-above-supply-rail","target":"inductive-motor-loads-require-bypass-capacitor-to-absorb-voltage-spikes-above-supply-rail","line":34},{"title":"drc-should-flag-direct-gpio-to-inductive-load-connections-and-suggest-driver-plus-flyback-subcircuit","target":"drc-should-flag-direct-gpio-to-inductive-load-connections-and-suggest-driver-plus-flyback-subcircuit","line":35},{"title":"actuators","target":"actuators","line":38},{"title":"shields","target":"shields","line":39}],"metadata":{"description":"The TB6612 includes internal clamp diodes on all four outputs, matching the L293D and unlike the L298N — this changes the selection calculus because the L298N's 2A advantage over the TB6612 is partially consumed by the need to add four external fast-recovery diodes, a cost the TB6612 eliminates","type":"claim","source":"docs/parts/osepp-tb6612-motor-shield-drives-2-dc-motors-at-1p2a-per-channel.md","confidence":"proven","topics":["[[actuators]]","[[shields]]"],"related_components":["osepp-tb6612-motor-shield","l298n-dual-h-bridge-motor-driver","l293d-dual-h-bridge-ic"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/tb6612-internal-flyback-diodes-eliminate-the-external-protection-burden-that-l298n-requires.md"},"smart_blocks:knowledge/tb6612-internal-flyback-diodes-eliminate-the-external-protection-burden-that-l298n-requires.md#---frontmatter---": {"path":null,"last_embed":{"hash":"zu3bnj","at":1776207985920},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.11142322,-0.01189784,-0.00577164,-0.04465902,0.02709461,-0.00759742,-0.02407145,0.08622736,-0.04334522,-0.03010533,0.01474317,-0.01510333,0.01601737,-0.01305585,0.01416192,0.00703496,-0.01795868,-0.0382344,0.01807558,0.06885624,0.05059058,-0.09132466,0.02502567,-0.02286774,0.06829117,0.04750694,0.02637961,-0.01464118,-0.0052761,-0.27705613,-0.03392114,0.04083421,-0.02474713,-0.02490757,-0.04123605,-0.01935204,-0.04178405,-0.03383896,-0.013229,-0.00647428,0.04640017,0.03430633,0.00339692,-0.08312753,0.00816707,-0.0512705,-0.00773113,0.0048542,0.04369553,-0.0758385,0.0438571,-0.03493726,0.03820521,-0.01818991,0.00994064,0.03565956,0.025323,0.10573797,-0.01750972,-0.0004681,0.06472364,0.06044449,-0.19595945,0.08557102,0.00666539,0.02344055,-0.02325584,-0.04188719,0.09128468,0.06346617,0.01256746,-0.0199073,0.07786973,-0.00491656,-0.01440356,-0.01821167,0.00093833,-0.04145254,-0.00948262,-0.02136652,0.03339998,0.04105452,-0.04187398,0.00503764,-0.00170116,-0.03531971,0.05517615,-0.01631965,0.05313722,0.04614095,-0.01946311,-0.03353892,-0.00598284,-0.00797272,-0.04505361,-0.00254447,0.01744294,0.00873808,-0.04713424,0.10182726,-0.01