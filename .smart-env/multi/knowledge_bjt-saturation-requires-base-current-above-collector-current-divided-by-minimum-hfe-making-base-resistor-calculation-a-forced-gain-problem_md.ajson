e":"passives","target":"passives","line":72},{"title":"eda-fundamentals","target":"eda-fundamentals","line":73}],"metadata":{"description":"To fully saturate a BJT switch, the base current must exceed Ic/hFE_min -- a 1K resistor from 5V GPIO gives ~4.3mA base current, which with hFE_min=100 saturates for loads up to 430mA; this forced-gain math is the fundamental design step for any BJT switching circuit","type":"knowledge-note","source":"docs/parts/pn2222a-npn-transistor-40v-600ma-general-purpose-to92.md","topics":["[[passives]]","[[eda-fundamentals]]"],"confidence":"high","verified":false},"task_lines":[],"tasks":{},"codeblock_ranges":[[16,18],[27,29]]},"smart_blocks:knowledge/bjt-saturation-requires-base-current-above-collector-current-divided-by-minimum-hfe-making-base-resistor-calculation-a-forced-gain-problem.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1krkbqg","at":1776152919086},"key":"knowledge/bjt-saturation-requires-base-current-above-collector-current-divided-by-minimum-hfe-making-base-resistor-calculation-a-forced-gain-problem.md#---frontmatter---","lines":[1,10],"size":476,"outlinks":[{"title":"passives","target":"passives","line":6},{"title":"eda-fundamentals","target":"eda-fundamentals","line":7}],"class_name":"SmartBlock"},
