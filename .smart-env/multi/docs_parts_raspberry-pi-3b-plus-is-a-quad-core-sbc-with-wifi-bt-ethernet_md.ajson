-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":110},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":137},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":138},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":139},{"title":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","target":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","line":140},{"title":"raspberry-pi-7-inch-touchscreen-800x480-dsi","target":"raspberry-pi-7-inch-touchscreen-800x480-dsi","line":141},{"title":"dht11-temperature-humidity-sensor-single-wire-0-50c","target":"dht11-temperature-humidity-sensor-single-wire-0-50c","line":142},{"title":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","target":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","line":143},{"title":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","target":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","line":144},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":145},{"title":"microcontrollers","target":"microcontrollers","line":148},{"title":"communication","target":"communication","line":149}],"metadata":{"description":"Full Linux single-board computer — quad-core 1.4GHz ARM, 1GB RAM, WiFi, Bluetooth 4.2, Gigabit Ethernet (over USB 2.0), 40-pin GPIO header. For when a microcontroller isn't enough and you need an OS","topics":["[[microcontrollers]]","[[communication]]"],"status":"needs-test","quantity":1,"voltage":[5,3.3],"interfaces":["GPIO","I2C","SPI","UART","USB","HDMI","WiFi","Bluetooth","Ethernet","Analog"],"logic_level":"3.3V","manufacturer":"Raspberry Pi Foundation","soc":"BCM2837B0 (ARM Cortex-A53 quad-core)","clock_mhz":1400,"ram_mb":1024,"flash_kb":0,"storage":"microSD card (not included)","pinout":"40-pin GPIO header (BCM numbering):\nGPIO2  (SDA1)     — I2C data\nGPIO3  (SCL1)     — I2C clock\nGPIO4  (GPCLK0)   — general purpose clock\nGPIO5              — general purpose\nGPIO6              — general purpose\nGPIO7  (CE1)      — SPI chip enable 1\nGPIO8  (CE0)      — SPI chip enable 0\nGPIO9  (MISO)     — SPI MISO\nGPIO10 (MOSI)     — SPI MOSI\nGPIO11 (SCLK)     — SPI clock\nGPIO12 (PWM0)     — hardware PWM channel 0\nGPIO13 (PWM1)     — hardware PWM channel 1\nGPIO14 (TXD)      — UART TX\nGPIO15 (RXD)      — UART RX\nGPIO16-GPIO27     — general purpose\nPower: 5V (2 pins), 3.3V (2 pins), GND (8 pins)\n","compatible_with":["[[sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi]]","[[raspberry-pi-7-inch-touchscreen-800x480-dsi]]","[[dht11-temperature-humidity-sensor-single-wire-0-50c]]","[[mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3]]","[[bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c]]"],"level_shifter_needed":["[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]"],"used_in":[],"warnings":["3.3V GPIO — connecting 5V signals to ANY GPIO pin will damage the SoC permanently","Requires 5V 2.5A power supply via micro-USB — underpowering causes crashes and SD card corruption","No built-in ADC — need external ADC (MCP3008, ADS1115) for analog inputs","Gigabit Ethernet is throttled to ~300Mbps because it runs through the USB 2.0 bus","Not a microcontroller — no real-time guarantees, Linux kernel preempts your code"],"datasheet_url":"https://www.raspberrypi.com/products/raspberry-pi-3-model-b-plus/"},"task_lines":[],"tasks":{},"codeblock_ranges":[[73,96]]},"smart_blocks:docs/parts/raspberry-pi-3b-plus-is-a-quad-core-sbc-with-wifi-bt-ethernet.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1kli441","at":1776152926649},"key":"docs/parts/raspberry-pi-3b-plus-is-a-quad-core-sbc-with-wifi-bt-ethernet.md#---frontmatter---","lines":[1,38],"size":2269,"outlinks":[{"title":"communication","target":"communication","line":3},{"title":"microcontrollers","target":"microcontrollers","line":3},{"title":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","target":"bno055-9dof-absolute-orientation-imu-with-sensor-fusion-i2c","line":33},{"title":"dht11-temperature-humidity-sensor-single-wire-0-50c","target":"dht11-temperature-humidity-sensor-single-wire-0-50c","line":33},{"title":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","target":"mpu6050-gy521-6dof-imu-accelerometer-gyroscope-i2c-3v3","line":33},{"title":"raspberry-pi-7-inch-touchscreen-800x480-dsi","target":"raspberry-pi-7-inch-touchscreen-800x480-dsi","line":33},{"title":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","target":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","line":33},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":34},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":34}],"class_name":"SmartBlock"},
