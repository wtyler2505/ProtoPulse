l-up","line":38},{"title":"hall-sensor-wiring-order-matters-for-bldc","target":"hall-sensor-wiring-order-matters-for-bldc","line":39},{"title":"78l05-regulator-failure-kills-hall-power-making-motor-appear-dead-when-only-the-regulator-failed","target":"78l05-regulator-failure-kills-hall-power-making-motor-appear-dead-when-only-the-regulator-failed","line":40},{"title":"shields","target":"shields","line":43},{"title":"actuators","target":"actuators","line":44},{"title":"eda-fundamentals","target":"eda-fundamentals","line":45}],"metadata":{"description":"BLDC motor controllers like the RioRand ZS-X11H buffer the raw Hall-sensor lines through active digital logic and output push-pull 5V signals — not open-drain — which means bridging those outputs to a 3.3V MCU requires a TXS-class active shifter rather than the BSS138-class pull-up shifter typically used for I2C, and the topology of the downstream signal (not the upstream sensor) drives the choice","type":"claim","source":"docs/parts/txs0108e-8-channel-bidirectional-level-shifter-auto-direction.md","confidence":"proven","topics":["[[shields]]","[[actuators]]","[[eda-fundamentals]]"],"related_components":["txs0108e-level-shifter","riorand-zs-x11h","hoverboard-bldc-motor"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},