evices","target":"input-devices","line":5},{"title":"membrane-switch-keypad-module-tactile-button-array","target":"membrane-switch-keypad-module-tactile-button-array","line":6},{"title":"input-devices","target":"input-devices","line":33},{"title":"4x4-matrix-keypad-consumes-8-gpio-pins-making-io-expander-mandatory-on-pin-constrained-mcus","target":"4x4-matrix-keypad-consumes-8-gpio-pins-making-io-expander-mandatory-on-pin-constrained-mcus","line":36},{"title":"membrane-keypad-has-no-built-in-debouncing-requiring-software-scan-timing","target":"membrane-keypad-has-no-built-in-debouncing-requiring-software-scan-timing","line":37},{"title":"direct-driving-an-8x8-led-matrix-consumes-16-io-pins-and-locks-the-cpu-to-display-refresh","target":"direct-driving-an-8x8-led-matrix-consumes-16-io-pins-and-locks-the-cpu-to-display-refresh","line":38}],"metadata":{"description":"Matrix keypad scanning sets row pins as OUTPUT (driven LOW one at a time) and column pins as INPUT_PULLUP — when a key is pressed, the active row's LOW propagates to the pressed column, allowing key position detection from the row/column intersection","type":"knowledge","topics":["[[input-devices]]"],"source":"[[membrane-switch-keypad-module-tactile-button-array]]"},"task_lines":[],"tasks":{},"codeblock_ranges":[]},