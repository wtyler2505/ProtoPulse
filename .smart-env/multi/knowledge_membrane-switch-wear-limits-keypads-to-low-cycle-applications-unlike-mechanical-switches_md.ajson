echanical switches#{14}":[41,42]},"outlinks":[{"title":"input-devices","target":"input-devices","line":5},{"title":"membrane-switch-keypad-module-tactile-button-array","target":"membrane-switch-keypad-module-tactile-button-array","line":6},{"title":"input-devices","target":"input-devices","line":37},{"title":"membrane-keypad-is-a-passive-switch-matrix-with-no-active-logic-so-it-operates-at-any-mcu-voltage-without-level-shifting","target":"membrane-keypad-is-a-passive-switch-matrix-with-no-active-logic-so-it-operates-at-any-mcu-voltage-without-level-shifting","line":40},{"title":"membrane-keypad-has-no-built-in-debouncing-requiring-software-scan-timing","target":"membrane-keypad-has-no-built-in-debouncing-requiring-software-scan-timing","line":41}],"metadata":{"description":"Membrane keypad conductive traces degrade with repeated presses — typical rated for 1 million cycles per key, which sounds high but is reached quickly in gaming or industrial HMI applications, making mechanical switches or capacitive touch appropriate for high-cycle use cases","type":"knowledge","topics":["[[input-devices]]"],"source":"[[membrane-switch-keypad-module-tactile-button-array]]"},"task_lines":[],"tasks":{},"codeblock_ranges":[]},