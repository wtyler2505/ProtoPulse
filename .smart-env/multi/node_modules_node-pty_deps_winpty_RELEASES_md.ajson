"smart_blocks:node_modules/node-pty/deps/winpty/RELEASES.md#Version 0.2.1 (2015-12-19)": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"hz40n7","at":1776152969051},"key":"node_modules/node-pty/deps/winpty/RELEASES.md#Version 0.2.1 (2015-12-19)","lines":[173,202],"size":1501,"outlinks":[{"title":"#51","target":"https://github.com/rprichard/winpty/issues/51","line":5},{"title":"#40","target":"https://github.com/rprichard/winpty/issues/40","line":8},{"title":".\n * Added support for mouse input.  The UNIX adapter has a `--mouse` argument\n   that puts the terminal into mouse mode, but the agent recognizes mouse\n   input even without the argument.  The agent recognizes double-clicks using\n   Windows' double-click interval setting (i.e. GetDoubleClickTime).\n   [#57","target":"https://github.com/rprichard/winpty/issues/57","line":11}],"class_name":"SmartBlock"},
"smart_blocks:node_modules/node-pty/deps/winpty/RELEASES.md#Version 0.2.1 (2015-12-19)#{1}": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"b3eadb","at":1776152969051},"key":"node_modules/node-pty/deps/winpty/RELEASES.md#Version 0.2.1 (2015-12-19)#{1}","lines":[175,202],"size":1471,"outlinks":[{"title":"#51","target":"https://github.com/rprichard/winpty/issues/51","line":3},{"title":"#40","target":"https://github.com/rprichard/winpty/issues/40","line":6},{"title":".\n * Added support for mouse input.  The UNIX adapter has a `--mouse` argument\n   that puts the terminal into mouse mode, but the agent recognizes mouse\n   input even without the argument.  The agent recognizes double-clicks using\n   Windows' double-click interval setting (i.e. GetDoubleClickTime).\n   [#57","target":"https://github.com/rprichard/winpty/issues/57","line":9}],"class_name":"SmartBlock"},
