rs with near-zero idle draw#{11}":[50,51]},"outlinks":[{"title":"shields","target":"shields","line":7},{"title":"power","target":"power","line":8},{"title":"eda-fundamentals","target":"eda-fundamentals","line":9},{"title":"esp32-deep-sleep-draws-only-10-microamps-enabling-battery-iot","target":"esp32-deep-sleep-draws-only-10-microamps-enabling-battery-iot","line":21},{"title":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","target":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","line":37},{"title":"active-level-shifters-use-one-shot-edge-accelerators-to-drive-rising-edges-breaking-the-bss138-rc-ceiling","target":"active-level-shifters-use-one-shot-edge-accelerators-to-drive-rising-edges-breaking-the-bss138-rc-ceiling","line":40},{"title":"signal-topology-not-voltage-alone-determines-level-shifter-selection","target":"signal-topology-not-voltage-alone-determines-level-shifter-selection","line":41},{"title":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","target":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","line":42},{"title":"esp32-deep-sleep-draws-only-10-microamps-enabling-battery-iot","target":"esp32-deep-sleep-draws-only-10-microamps-enabling-battery-iot","line":43},{"title":"nodemcu-board-draws-8-20ma-in-deep-sleep-defeating-chip-level-20ua-spec","target":"nodemcu-board-draws-8-20ma-in-deep-sleep-defeating-chip-level-20ua-spec","line":44},{"title":"passive-mechanical-switches-draw-zero-quiescent-current-making-them-ideal-battery-wake-triggers","target":"passive-mechanical-switches-draw-zero-quiescent-current-making-them-ideal-battery-wake-triggers","line":45},{"title":"shields","target":"shields","line":48},{"title":"power","target":"power","line":49},{"title":"eda-fundamentals","target":"eda-fundamentals","line":50}],"metadata":{"description":"Auto-direction level shifters like the TXS0108E draw around 100uA of quiescent supply current per side even with no signal activity because their edge-detection logic runs continuously, while BSS138-based pull-up shifters draw essentially zero quiescent current from the supply rails because the shifter is passive MOSFETs and the only current flow is through pull-up resistors when a line is driven LOW — this makes the shifter class a battery-life decision, not just a speed decision","type":"claim","source":"docs/parts/txs0108e-8-channel-bidirectional-level-shifter-auto-direction.md","confidence":"proven","topics":["[[shields]]","[[power]]","[[eda-fundamentals]]"],"related_components":["txs0108e-level-shifter","hw-221-level-shifter"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:knowledge/active-level-shifters-draw-continuous-quiescent-current-unlike-passive-bss138-shifters-with-near-zero-idle-draw.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"jwomg0","at":1776152919085},"key":"knowledge/active-level-shifters-draw-continuous-quiescent-current-unlike-passive-bss138-shifters-with-near-zero-idle-draw.md#---frontmatter---","lines":[1,13],"size":770,"outlinks":[{"title":"shields","target":"shields","line":7},{"title":"power","target":"power","line":8},{"title":"eda-fundamentals","target":"eda-fundamentals","line":9}],"class_name":"SmartBlock"},
