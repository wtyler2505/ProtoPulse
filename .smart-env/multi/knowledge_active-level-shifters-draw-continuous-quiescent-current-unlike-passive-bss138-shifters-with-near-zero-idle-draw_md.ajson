:[45,46],"#Active level shifters draw continuous quiescent current unlike passive BSS138 shifters with near-zero idle draw#{8}":[47,47],"#Active level shifters draw continuous quiescent current unlike passive BSS138 shifters with near-zero idle draw#{9}":[48,48],"#Active level shifters draw continuous quiescent current unlike passive BSS138 shifters with near-zero idle draw#{10}":[49,49],"#Active level shifters draw continuous quiescent current unlike passive BSS138 shifters with near-zero idle draw#{11}":[50,51]},"outlinks":[{"title":"shields","target":"shields","line":7},{"title":"power","target":"power","line":8},{"title":"eda-fundamentals","target":"eda-fundamentals","line":9},{"title":"esp32-deep-sleep-draws-only-10-microamps-enabling-battery-iot","target":"esp32-deep-sleep-draws-only-10-microamps-enabling-battery-iot","line":21},{"title":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","target":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","line":37},{"title":"active-level-shifters-use-one-shot-edge-accelerators-to-drive-rising-edges-breaking-the-bss138-rc-ceiling","target":"active-level-shifters-use-one-shot-edge-accelerators-to-drive-rising-edges-breaking-the-bss138-rc-ceiling","line":40},{"title":"signal-topology-not-voltage-alone-determines-level-shifter-selection","target":"signal-topology-not-voltage-alone-determines-level-shifter-selection","line":41},{"title":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","target":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","line":42},{"title":"esp32-deep-sleep-draws-only-10-microamps-enabling-battery-iot","target":"esp32-deep-sleep-draws-only-10-microamps-enabling-battery-iot","line":43},{"title":"nodemcu-board-draws-8-20ma-in-deep-sleep-defeating-chip-level-20ua-spec","target":"nodemcu-board-draws-8-20ma-in-deep-sleep-defeating-chip-level-20ua-spec","line":44},{"title":"passive-mechanical-switches-draw-zero-quiescent-current-making-them-ideal-battery-wake-triggers","target":"passive-mechanical-switches-draw-zero-quiescent-current-making-them-ideal-battery-wake-triggers","line":45},{"title":"shields","target":"shields","line":48},{"title":"power","target":"power","line":49},{"title":"eda-fundamentals","target":"eda-fundamentals","line":50}],"metadata":{"description":"Auto-direction level shifters like the TXS0108E draw around 100uA of quiescent supply current per side even with no signal activity because their edge-detection logic runs continuously, while BSS138-based pull-up shifters draw essentially zero quiescent current from the supply rails because the shifter is passive MOSFETs and the only current flow is through pull-up resistors when a line is driven LOW — this makes the shifter class a battery-life decision, not just a speed decision","type":"claim","source":"docs/parts/txs0108e-8-channel-bidirectional-level-shifter-auto-direction.md","confidence":"proven","topics":["[[shields]]","[[power]]","[[eda-fundamentals]]"],"related_components":["txs0108e-level-shifter","hw-221-level-shifter"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/active-level-shifters-draw-continuous-quiescent-current-unlike-passive-bss138-shifters-with-near-zero-idle-draw.md"},"smart_blocks:knowledge/active-level-shifters-draw-continuous-quiescent-current-unlike-passive-bss138-shifters-with-near-zero-idle-draw.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1mgppff","at":1776206796451},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.11100908,0.01923273,0.01986926,0.004346,-0.04843529,0.04226461,-0.00980101,0.06111515,0.00735825,0.04794327,0.02149709,-0.03139668,0.00103767,0.04993962,0.01091619,0.0164778,0.01334403,-0.01655103,0.03716134,0.054192,0.07531615,-0.04851947,-0.00584932,0.01915606,0.06827877,0.04496115,0.04645067,0.01924413,0.002044,-0.24943647,0.00199824,-0.01701184,0.00979367,-0.03730706,-0.04950338,-0.04661987,-0.04788007,0.02109533,0.03957028,-0.01680112