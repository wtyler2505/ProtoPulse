
"smart_sources:knowledge/driver-ic-selection-follows-from-actuator-type-not-power-rating-alone.md": {"path":"knowledge/driver-ic-selection-follows-from-actuator-type-not-power-rating-alone.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"icpk49","at":1776152919519},"class_name":"SmartSource","last_import":{"mtime":1775993987412,"size":2451,"at":1776152919848,"hash":"icpk49"},"blocks":{"#---frontmatter---":[1,10],"#driver IC selection follows from actuator type not power rating alone":[12,42],"#driver IC selection follows from actuator type not power rating alone#{1}":[14,17],"#driver IC selection follows from actuator type not power rating alone#{2}":[18,18],"#driver IC selection follows from actuator type not power rating alone#{3}":[19,19],"#driver IC selection follows from actuator type not power rating alone#{4}":[20,21],"#driver IC selection follows from actuator type not power rating alone#{5}":[22,39],"#driver IC selection follows from actuator type not power rating alone#{6}":[40,40],"#driver IC selection follows from actuator type not power rating alone#{7}":[41,42]},"outlinks":[{"title":"actuators","target":"actuators","line":6},{"title":"eda-fundamentals","target":"eda-fundamentals","line":7},{"title":"actuators","target":"actuators","line":40},{"title":"eda-fundamentals","target":"eda-fundamentals","line":41}],"metadata":{"description":"Choosing a motor driver by current/voltage rating alone is a common beginner mistake -- the actuator type determines the driver architecture (H-bridge, Darlington sink, 3-phase bridge, direct GPIO), and only then do you filter by power rating","type":"knowledge-note","source":"docs/parts/actuators.md","topics":["[[actuators]]","[[eda-fundamentals]]"],"confidence":"high","verified":false},"task_lines":[],"tasks":{},"codeblock_ranges":[]},