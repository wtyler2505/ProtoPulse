e 28BYJ-48?#{5}":[78,79],"#ULN2003APG stepper driver board for 28BYJ-48 at 5V#Why Not Use a L298N or TB6612 for the 28BYJ-48?#{6}":[80,84],"#ULN2003APG stepper driver board for 28BYJ-48 at 5V#Why Not Use a L298N or TB6612 for the 28BYJ-48?#{7}":[85,85],"#ULN2003APG stepper driver board for 28BYJ-48 at 5V#Why Not Use a L298N or TB6612 for the 28BYJ-48?#{8}":[86,86],"#ULN2003APG stepper driver board for 28BYJ-48 at 5V#Why Not Use a L298N or TB6612 for the 28BYJ-48?#{9}":[87,88],"#ULN2003APG stepper driver board for 28BYJ-48 at 5V#Why Not Use a L298N or TB6612 for the 28BYJ-48?#{10}":[89,89],"#ULN2003APG stepper driver board for 28BYJ-48 at 5V#Why Not Use a L298N or TB6612 for the 28BYJ-48?#{11}":[90,91]},"outlinks":[{"title":"actuators","target":"actuators","line":3},{"title":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","target":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","line":23},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":23},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":23},{"title":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","target":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","line":31},{"title":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","target":"28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver","line":85},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":86},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":87},{"title":"actuators","target":"actuators","line":90}],"metadata":{"description":"Dedicated driver board for the 28BYJ-48 stepper — 7 Darlington transistor pairs sink up to 500mA each, status LEDs show active coils. The only driver you need for this motor","topics":["[[actuators]]"],"status":"needs-test","quantity":1,"voltage":[5],"interfaces":["Digital"],"logic_level":"5V (inputs accept 3.3V)","manufacturer":"Generic","part_number":"ULN2003APG","package":"DIP-16 (on breakout board)","max_current_per_channel":"500mA per Darlington pair","total_channels":7,"pinout":"Breakout board connections:\nIN1 → Arduino digital GPIO (coil 1 - Blue wire)\nIN2 → Arduino digital GPIO (coil 2 - Pink wire)\nIN3 → Arduino digital GPIO (coil 3 - Yellow wire)\nIN4 → Arduino digital GPIO (coil 4 - Orange wire)\nVCC → External 5V supply (motor power)\nGND → Common ground\nMotor connector → 5-pin JST to 28BYJ-48\n","compatible_with":["[[28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver]]","[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]"],"used_in":[],"warnings":["Power the motor from external 5V, not Arduino 5V pin — motor draws ~240mA","ULN2003 is a SINK driver only — it pulls outputs LOW, it does NOT source current","Only 4 of the 7 channels are used for the 28BYJ-48"],"datasheet_url":"https://www.ti.com/lit/ds/symlink/uln2003a.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"docs/parts/uln2003apg-stepper-driver-board-for-28byj-48-at-5v.md"},
