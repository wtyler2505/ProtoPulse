tle":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":86},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":87},{"title":"actuators","target":"actuators","line":90}],"metadata":{"description":"Dedicated driver board for the 28BYJ-48 stepper — 7 Darlington transistor pairs sink up to 500mA each, status LEDs show active coils. The only driver you need for this motor","topics":["[[actuators]]"],"status":"needs-test","quantity":1,"voltage":[5],"interfaces":["Digital"],"logic_level":"5V (inputs accept 3.3V)","manufacturer":"Generic","part_number":"ULN2003APG","package":"DIP-16 (on breakout board)","max_current_per_channel":"500mA per Darlington pair","total_channels":7,"pinout":"Breakout board connections:\nIN1 → Arduino digital GPIO (coil 1 - Blue wire)\nIN2 → Arduino digital GPIO (coil 2 - Pink wire)\nIN3 → Arduino digital GPIO (coil 3 - Yellow wire)\nIN4 → Arduino digital GPIO (coil 4 - Orange wire)\nVCC → External 5V supply (motor power)\nGND → Common ground\nMotor connector → 5-pin JST to 28BYJ-48\n","compatible_with":["[[28byj-48-5v-unipolar-stepper-motor-with-uln2003-driver]]","[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]"],"used_in":[],"warnings":["Power the motor from external 5V, not Arduino 5V pin — motor draws ~240mA","ULN2003 is a SINK driver only — it pulls outputs LOW, it does NOT source current","Only 4 of the 7 channels are used for the 28BYJ-48"],"datasheet_url":"https://www.ti.com/lit/ds/symlink/uln2003a.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"docs/parts/uln2003apg-stepper-driver-board-for-28byj-48-at-5v.md"},"smart_blocks:docs/parts/uln2003apg-stepper-driver-board-for-28byj-48-at-5v.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1bnw3