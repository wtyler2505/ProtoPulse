"smart_sources:docs/parts/main-power-switch-anl-fuse-100a-disconnect-for-36v.md": {"path":"docs/parts/main-power-switch-anl-fuse-100a-disconnect-for-36v.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"1ysde9y","at":1776152926648},"class_name":"SmartSource","last_import":{"mtime":1773554254415,"size":5707,"at":1776152928649,"hash":"1ysde9y"},"blocks":{"#---frontmatter---":[1,29],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V":[31,127],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#{1}":[33,34],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#{2}":[35,36],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#{3}":[37,38],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#{4}":[39,40],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Component Specifications":[41,88],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Component Specifications#ANL-100 Fuse":[43,54],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Component Specifications#ANL-100 Fuse#{1}":[45,54],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Component Specifications#Time-Current Characteristics":[55,65],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Component Specifications#Time-Current Characteristics#{1}":[57,65],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Component Specifications#Fuse Sizing Calculation":[66,75],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Component Specifications#Fuse Sizing Calculation#{1}":[68,75],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Component Specifications#Main Disconnect Switch":[76,88],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Component Specifications#Main Disconnect Switch#{1}":[78,88],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#System Wiring":[89,108],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#System Wiring#{1}":[91,108],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Wire Specifications":[109,127],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Wire Specifications#{1}":[111,120],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Wire Specifications#{2}":[121,121],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Wire Specifications#{3}":[122,122],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Wire Specifications#{4}":[123,124],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Wire Specifications#{5}":[125,125],"#Main Power Switch + ANL Fuse 100A Disconnect for 36V#Wire Specifications#{6}":[126,127]},"outlinks":[{"title":"power","target":"power","line":3},{"title":"emergency-stop-nc-button-with-dc-contactor-for-36v","target":"emergency-stop-nc-button-with-dc-contactor-for-36v","line":25},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":25},{"title":"power-distribution-board-fused-terminal-block-for-36v-system","target":"power-distribution-board-fused-terminal-block-for-36v-system","line":25},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":121},{"title":"emergency-stop-nc-button-with-dc-contactor-for-36v","target":"emergency-stop-nc-button-with-dc-contactor-for-36v","line":122},{"title":"power-distribution-board-fused-terminal-block-for-36v-system","target":"power-distribution-board-fused-terminal-block-for-36v-system","line":123},{"title":"power","target":"power","line":126}],"metadata":{"description":"Battery disconnect switch + ANL-100 slow-blow fuse — the first protection between 36V battery and everything else. Fuse must be within 6 inches of battery positive per NEC. Switch must be DC-rated for 100A with arc suppression. NEVER use AC-rated switches for DC","topics":["[[power]]"],"status":"needs-test","quantity":1,"voltage":[36],"interfaces":["Terminal"],"logic_level":"N/A (power switching, no logic)","manufacturer":"Various (Blue Sea Systems, Bussmann, Eaton, Renogy)","pinout":"Power flow (series circuit):\nBattery (+) ──[6\" max]──→ ANL Fuse Holder IN\nANL Fuse Holder OUT ──[12\" max]──→ Main Switch IN\nMain Switch OUT ──→ Power Distribution Board\n\nANL-100 Fuse:\n  Terminal 1 → From battery positive (#4 AWG, M8 ring terminal)\n  Terminal 2 → To main switch input (#4 AWG, M8 ring terminal)\n\nMain Disconnect Switch:\n  IN+  → From fuse output (#4 AWG)\n  OUT+ → To power distribution board (#4 AWG)\n  Coil+ → 12V from buck converter (if DC contactor type)\n  Coil- → GND (if DC contactor type)\n","compatible_with":["[[hoverboard-10s-lithium-ion-battery-pack-36v-with-bms]]","[[power-distribution-board-fused-terminal-block-for-36v-system]]","[[emergency-stop-nc-button-with-dc-contactor-for-36v]]"],"used_in":[],"warnings":["Fuse MUST be within 6 inches of battery positive terminal — NEC requirement, fire prevention","NEVER use AC-rated switches for DC — AC switches cannot safely interrupt DC arcs (fire/explosion hazard)","DC interrupt rating must be >500A — battery short-circuit current can exceed 500A","Use slow-blow (time-delay) fuse — fast-blow fuses will nuisance-trip on motor startup inrush","NEVER fuse the negative/ground wire — always fuse the positive side only","All wire connections must use properly crimped ring terminals — never solder high-current connections","Torque all terminal bolts to spec — loose connections cause arcing and fire"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[68,74],[91,107]],"key":"docs/parts/main-power-switch-anl-fuse-100a-disconnect-for-36v.md"},
