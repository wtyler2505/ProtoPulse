],"#High voltage rating on a small capacitor does not imply danger because stored energy depends on capacitance times voltage squared#{10}":[47,48]},"outlinks":[{"title":"passives","target":"passives","line":6},{"title":"power-systems","target":"power-systems","line":7},{"title":"753j-400v-polyester-film-capacitor-75nf","target":"753j-400v-polyester-film-capacitor-75nf","line":40},{"title":"high-voltage-capacitors-store-dangerous-energy-that-persists-after-circuit-power-off","target":"high-voltage-capacitors-store-dangerous-energy-that-persists-after-circuit-power-off","line":43},{"title":"passives","target":"passives","line":46},{"title":"power-systems","target":"power-systems","line":47}],"metadata":{"description":"A 75nF/400V film cap stores only 6mJ despite its 400V rating -- 1500x less energy than a 470uF/200V electrolytic at 9.4J -- because E=0.5CV^2 and four orders of magnitude less capacitance overwhelms twice the voltage; safety warnings should key on stored energy, not voltage rating alone","type":"knowledge-note","source":"docs/parts/753j-400v-polyester-film-capacitor-75nf.md","topics":["[[passives]]","[[power-systems]]"],"confidence":"high","verified":false},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:knowledge/high-voltage-rating-on-a-small-capacitor-does-not-imply-danger-because-stored-energy-depends-on-capacitance-times-voltage-squared.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"mtl1nn","at":1776152919520},"key":"knowledge/high-voltage-rating-on-a-small-capacitor-does-not-imply-danger-because-stored-energy-depends-on-capacitance-times-voltage-squared.md#---frontmatter---","lines":[1,10],"size":479,"outlinks":[{"title":"passives","target":"passives","line":6},{"title":"power-systems","target":"power-systems","line":7}],"class_name":"SmartBlock"},
