isplays","target":"displays","line":43},{"title":"shields","target":"shields","line":44},{"title":"microcontrollers","target":"microcontrollers","line":45}],"metadata":{"description":"The ILI9341 TFT touch shield uses SPI (MOSI/MISO/SCK via ICSP), D8-D10 for display control, and A0-A3 for resistive touch — on an Uno this leaves almost no free pins, making the Mega 2560 the practical host for projects needing sensors or actuators alongside the display","type":"claim","source":"docs/parts/2p8-inch-tft-lcd-touch-shield-ili9341-320x240-spi.md","confidence":"high","verified":false,"topics":["[[displays]]","[[shields]]","[[microcontrollers]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/tft-shield-form-factor-consumes-most-uno-pins-making-mega-the-practical-host-board-for-projects-needing-additional-io.md"},"smart_blocks:knowledge/tft-shield-form-factor-consumes-most-uno-pins-making-mega-the-practical-host-board-for-projects-needing-additional-io.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1tkp19z","at":1776208007972},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05107358,0.03780611,0.0282093,-0.02788843,0.00850607,-0.056292,0.03129895,0.09688833,-0.04225046,0.00261935,0.01587681,-0.04472432,0.01744057,0.05996555,0.05760156,0.01951047,0.01543361,-0.02478496,0.0401455,0.05791645,0.1477246,-0.07294474,0.05667797,-0.01749575,0.02261489,0.07299794,-0.02949375,-0.06692263,0.0190606,-0.22683744,-0.00725364,-0.02384224,0.0314894,0.04441875,-0.01143118,-0.04386869,-0.04545458,-0.03108172,-0.04983039,-0.0080034,-0.01514312,0.01542289,0.00124378,-0.04180007,0.03032914,-0.03499871,-0.05076434,-0.07347792,0.0117449,-0.01752695,0.02560413,0.01011915,0.05774812,0.02368519,-0.00040659,-0.01434456,0.0430084,0.04679354,0.02723586,0.00858665,0.07849605,0.0263348,-0.17169774,0.13130762,0.07804654,0.02324752,-0.01129553,-0.00958717,0.07779561,0.04022014,-0.04144749,-0.00520641,-0.01486554,0.04276213,0.01602711,-0.0099422,0.00066404,-0.03923772,-0.03707