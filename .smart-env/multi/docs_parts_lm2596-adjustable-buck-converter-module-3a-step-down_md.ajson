ut voltage)","The pot is fragile — don't force it past its stops"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[84,91]]},"smart_blocks:docs/parts/lm2596-adjustable-buck-converter-module-3a-step-down.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1iafibh","at":1776152926648},"key":"docs/parts/lm2596-adjustable-buck-converter-module-3a-step-down.md#---frontmatter---","lines":[1,19],"size":1078,"outlinks":[{"title":"power","target":"power","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":15},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":15},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":15}],"class_name":"SmartBlock"},
