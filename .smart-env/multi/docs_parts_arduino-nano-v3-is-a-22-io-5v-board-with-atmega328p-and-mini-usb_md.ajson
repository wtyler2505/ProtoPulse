h ATmega328P and mini-USB#Clone Variant: DCCduino Nano#{4}":[97,97],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Clone Variant: DCCduino Nano#{5}":[98,99],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Clone Variant: DCCduino Nano#{6}":[100,101],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings":[102,118],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{1}":[104,104],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{2}":[105,105],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{3}":[106,106],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{4}":[107,108],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{5}":[109,111],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{6}":[112,112],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{7}":[113,113],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{8}":[114,115],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{9}":[116,116],"#Arduino Nano V3 is a 22-I/O 5V board with ATmega328P and mini-USB#Warnings#{10}":[117,118]},"outlinks":[{"title":"microcontrollers","target":"microcontrollers","line":3},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":34},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":112},{"title":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","target":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","line":113},{"title":"hd44780-1602a-16x2-lcd-character-display-runs-at-5v-parallel-or-i2c","target":"hd44780-1602a-16x2-lcd-character-display-runs-at-5v-parallel-or-i2c","line":114},{"title":"microcontrollers","target":"microcontrollers","line":117}],"metadata":{"description":"Compact Arduino board — same ATmega328P as the Uno but in a breadboard-friendly mini form factor with mini-USB. Best for space-constrained projects and breadboard prototyping","topics":["[[microcontrollers]]"],"status":"verified","quantity":1,"voltage":[5],"interfaces":["GPIO","I2C","SPI","UART","USB","Analog"],"logic_level":"5V","logic_notes":"5V GPIO. Many 3.3V outputs read as HIGH, but Nano outputs drive 5V and are not safe to connect directly to 3.3V-only inputs.","manufacturer":"Arduino (clone)","mcu":"ATmega328P","clock_mhz":16,"flash_kb":32,"sram_kb":2,"eeprom_kb":1,"part_number":"A000005","dimensions_mm":"45.0 x 18.0 (0.70in x 1.70in)","weight_g":7,"mounting_holes":"4x 1.78mm (0.07in) diameter","pin_pitch":"2.54mm (0.100in)","pinout":"Digital Pins: D0(RX), D1(TX), D2, D3(PWM), D4, D5(PWM), D6(PWM),\n              D7, D8, D9(PWM), D10(PWM/SS), D11(PWM/MOSI), D12(MISO), D13(SCK/LED)\nAnalog Pins:  A0, A1, A2, A3, A4(SDA), A5(SCL), A6, A7 (A6-A7 analog input only)\nPower Pins:   Vin, GND, GND, 5V, 3.3V, RESET\nI2C:          A4(SDA), A5(SCL)\nSPI:          D11(MOSI), D12(MISO), D13(SCK), D10(SS)\nUART:         D0(RX), D1(TX)\nPWM:          D3, D5, D6, D9, D10, D11\nInterrupts:   D2(INT0), D3(INT1)\n","pwm_pins":[3,5,6,9,10,11],"interrupt_pins":[2,3],"i2c_address":"","compatible_with":["[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]"],"used_in":[],"warnings":["A6 and A7 are analog INPUT ONLY — cannot be used as digital pins","Mini-USB connector is fragile — avoid repeated plugging/unplugging","Some clones use CH340 USB chip instead of FTDI — may need driver install"],"datasheet_url":"Datasheets/arduino-nano-v3-0--atmega328p-.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[62,80]],"key":"docs/parts/arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb.md"},
