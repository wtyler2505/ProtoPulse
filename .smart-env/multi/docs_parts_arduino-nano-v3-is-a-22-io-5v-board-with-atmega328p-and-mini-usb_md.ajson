b-b","line":34},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":112},{"title":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","target":"sh1106-1p3-inch-oled-128x64-display-module-runs-on-3v3-or-5v-via-i2c-or-spi","line":113},{"title":"hd44780-1602a-16x2-lcd-character-display-runs-at-5v-parallel-or-i2c","target":"hd44780-1602a-16x2-lcd-character-display-runs-at-5v-parallel-or-i2c","line":114},{"title":"microcontrollers","target":"microcontrollers","line":117}],"metadata":{"description":"Compact Arduino board — same ATmega328P as the Uno but in a breadboard-friendly mini form factor with mini-USB. Best for space-constrained projects and breadboard prototyping","topics":["[[microcontrollers]]"],"status":"verified","quantity":1,"voltage":[5],"interfaces":["GPIO","I2C","SPI","UART","USB","Analog"],"logic_level":"5V","logic_notes":"5V GPIO. Many 3.3V outputs read as HIGH, but Nano outputs drive 5V and are not safe to connect directly to 3.3V-only inputs.","manufacturer":"Arduino (clone)","mcu":"ATmega328P","clock_mhz":16,"flash_kb":32,"sram_kb":2,"eeprom_kb":1,"part_number":"A000005","dimensions_mm":"45.0 x 18.0 (0.70in x 1.70in)","weight_g":7,"mounting_holes":"4x 1.78mm (0.07in) diameter","pin_pitch":"2.54mm (0.100in)","pinout":"Digital Pins: D0(RX), D1(TX), D2, D3(PWM), D4, D5(PWM), D6(PWM),\n              D7, D8, D9(PWM), D10(PWM/SS), D11(PWM/MOSI), D12(MISO), D13(SCK/LED)\nAnalog Pins:  A0, A1, A2, A3, A4(SDA), A5(SCL), A6, A7 (A6-A7 analog input only)\nPower Pins:   Vin, GND, GND, 5V, 3.3V, RESET\nI2C:          A4(SDA), A5(SCL)\nSPI:          D11(MOSI), D12(MISO), D13(SCK), D10(SS)\nUART:         D0(RX), D1(TX)\nPWM:          D3, D5, D6, D9, D10, D11\nInterrupts:   D2(INT0), D3(INT1)\n","pwm_pins":[3,5,6,9,10,11],"interrupt_pins":[2,3],"i2c_address":"","compatible_with":["[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]"],"used_in":[],"warnings":["A6 and A7 are analog INPUT ONLY — cannot be used as digital pins","Mini-USB connector is fragile — avoid repeated plugging/unplugging","Some clones use CH340 USB chip instead of FTDI — may need driver install"],"datasheet_url":"Datasheets/arduino-nano-v3-0--atmega328p-.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[62,80]],"key":"docs/parts/arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb.md"},"smart_blocks:docs/parts/arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1ddz9ub","at":1776210103637},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04576988,-0.03326362,0.03051084,-0.04061054,-0.0475725,-0.01228614,0.01339297,0.02903428,0.01820333,0.04495202,0.00957373,-0.07181847,0.01742936,0.01876226,0.06253889,-0.04269931,-0.01456874,-0.02877413,0.02905392,0.02257694,0.09921791,-0.05414346,0.00386279,0.02560521,0.04425498,0.06575033,0.03226367,-0.02016254,-0.03326283,-0.23315974,-0.04006885,-0.01877225,0.03281354,-0.0402028,-0.01361306,-0.03681078,0.00625154,-0.00690536,-0.07135616,0.02049612,0.01435527,-0.06090703,-0.02715834,-0.04550186,0.00668759,-0.05226451,-0.0257481,-0.10200119,0.04502925,-0.01935812,0.01849553,0.02181999,0.04783368,-0.04072979,0.01147061,0.05144894,0.01253343,0.02842225,0.03792864,0.04421844,0.07728807,0.09905735,-0.15644653,0.10209481,0.07489958,0.00472416,-0.02610215,0.01638923,0.02749224,0.03727353,-0.01914638,-0.00753487,0.02540289,0.03421852,0.00064854,-0.01421068,0.04280912,-0.05662751,-0.03457878,-0.03989623,-0.06621841,0.0288313,-0.08793825,0.02163213,-0.00398581,-0.06918499,-0.00899773,0.01654198,-0.01466041,-0.00984993,-0.0657718,-0.06271265,0.00241521,-0.02217847,-0.04344087,-0.03649475,0.06329864,-0.04763393,-0.11942228,0.09329138,-0.00927721,0.01273935,0.01571544,-0.02376057,0.02178356,0.01681517,0.00279634,-0.01842321,-0.05570984,-0.00755935,0.02270456,-0.0006388,0.00273709,-0.0372695,0.03412895,0.04731276,0.0