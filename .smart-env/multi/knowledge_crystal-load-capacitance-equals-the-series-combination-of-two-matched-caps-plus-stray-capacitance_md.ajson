uency","target":"npo-c0g-dielectric-is-mandatory-for-crystal-load-capacitors-because-temperature-driven-capacitance-drift-shifts-oscillator-frequency","line":54},{"title":"unmarked-small-ceramic-capacitors-are-a-practical-inventory-hazard-requiring-physical-separation-or-labeling","target":"unmarked-small-ceramic-capacitors-are-a-practical-inventory-hazard-requiring-physical-separation-or-labeling","line":55},{"title":"passives","target":"passives","line":58},{"title":"eda-fundamentals","target":"eda-fundamentals","line":59}],"metadata":{"description":"Two matched caps (one per XTAL pin to GND) form a series combination that, plus 5-10pF stray capacitance, must equal the crystal's specified load capacitance -- for a 20pF load spec, two 22pF caps yield ~11pF + ~5-10pF stray = 16-21pF, matching the target","type":"knowledge-note","source":"docs/parts/22pf-ceramic-capacitor-npo-50v-crystal-load-cap.md","topics":["[[passives]]","[[eda-fundamentals]]"],"confidence":"high","verified":false},"task_lines":[],"tasks":{},"codeblock_ranges":[[16,20],[24,26],[30,32]]},"smart_blocks:knowledge/crystal-load-capacitance-equals-the-series-combination-of-two-matched-caps-plus-stray-capacitance.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"jhxnr0","at":1776152919087},"key":"knowledge/crystal-load-capacitance-equals-the-series-combination-of-two-matched-caps-plus-stray-capacitance.md#---frontmatter---","lines":[1,10],"size":458,"outlinks":[{"title":"passives","target":"passives","line":6},{"title":"eda-fundamentals","target":"eda-fundamentals","line":7}],"class_name":"SmartBlock"},
