
"smart_sources:knowledge/crystal-load-capacitance-equals-the-series-combination-of-two-matched-caps-plus-stray-capacitance.md": {"path":"knowledge/crystal-load-capacitance-equals-the-series-combination-of-two-matched-caps-plus-stray-capacitance.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"1qclxj4","at":1776152919087},"class_name":"SmartSource","last_import":{"mtime":1776032243086,"size":2657,"at":1776152919505,"hash":"1qclxj4"},"blocks":{"#---frontmatter---":[1,10],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance":[12,60],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{1}":[14,44],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{2}":[45,45],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{3}":[46,46],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{4}":[47,48],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{5}":[49,53],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{6}":[54,54],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{7}":[55,56],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{8}":[57,57],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{9}":[58,58],"#Crystal load capacitance equals the series combination of two matched caps plus stray capacitance#{10}":[59,60]},"outlinks":[{"title":"passives","target":"passives","line":6},{"title":"eda-fundamentals","target":"eda-fundamentals","line":7},{"title":"npo-c0g-dielectric-is-mandatory-for-crystal-load-capacitors-because-temperature-driven-capacitance-drift-shifts-oscillator-frequency","target":"npo-c0g-dielectric-is-mandatory-for-crystal-load-capacitors-because-temperature-driven-capacitance-drift-shifts-oscillator-frequency","line":54},{"title":"unmarked-small-ceramic-capacitors-are-a-practical-inventory-hazard-requiring-physical-separation-or-labeling","target":"unmarked-small-ceramic-capacitors-are-a-practical-inventory-hazard-requiring-physical-separation-or-labeling","line":55},{"title":"passives","target":"passives","line":58},{"title":"eda-fundamentals","target":"eda-fundamentals","line":59}],"metadata":{"description":"Two matched caps (one per XTAL pin to GND) form a series combination that, plus 5-10pF stray capacitance, must equal the crystal's specified load capacitance -- for a 20pF load spec, two 22pF caps yield ~11pF + ~5-10pF stray = 16-21pF, matching the target","type":"knowledge-note","source":"docs/parts/22pf-ceramic-capacitor-npo-50v-crystal-load-cap.md","topics":["[[passives]]","[[eda-fundamentals]]"],"confidence":"high","verified":false},"task_lines":[],"tasks":{},"codeblock_ranges":[[16,20],[24,26],[30,32]]},