"smart_sources:docs/parts/dht11-temperature-humidity-sensor-single-wire-0-50c.md": {"path":"docs/parts/dht11-temperature-humidity-sensor-single-wire-0-50c.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"esxrxc","at":1776152925099},"class_name":"SmartSource","last_import":{"mtime":1773554234022,"size":5865,"at":1776152926058,"hash":"esxrxc"},"blocks":{"#---frontmatter---":[1,26],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C":[28,121],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#{1}":[30,35],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#Specifications":[36,53],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#Specifications#{1}":[38,53],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#Wiring":[54,63],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#Wiring#{1}":[56,63],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#Arduino Code":[64,94],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#Arduino Code#{1}":[66,94],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280":[95,121],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{1}":[97,110],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{2}":[111,111],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{3}":[112,112],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{4}":[113,113],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{5}":[114,114],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{6}":[115,115],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{7}":[116,116],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{8}":[117,118],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{9}":[119,119],"#DHT11 Temperature + Humidity Sensor — Single-Wire, 0-50C#DHT11 vs DHT22 vs BME280#{10}":[120,121]},"outlinks":[{"title":"sensors","target":"sensors","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":22},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":22},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":22},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":22},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":22},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":22},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":22},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":111},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":112},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":113},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":114},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":115},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":116},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":117},{"title":"sensors","target":"sensors","line":120}],"metadata":{"description":"Basic temperature (0-50C, +/-2C) and humidity (20-90% RH, +/-5%) sensor with proprietary single-wire protocol — NOT I2C despite similar wiring. 1Hz max sample rate. Cheap and simple but low accuracy. Good enough for ambient monitoring, not for precision","topics":["[[sensors]]"],"status":"needs-test","quantity":1,"voltage":[3.3,5],"interfaces":["Digital"],"logic_level":"3.3-5V (single-wire protocol, voltage-tolerant)","manufacturer":"Aosong (ASAIR)","part_number":"DHT11","pinout":"DHT11 (4-pin package, pin 3 is NC):\nPin 1 (VCC)  → 3.3-5V power\nPin 2 (DATA) → Single-wire data (needs 10K pull-up to VCC)\nPin 3 (NC)   → Not connected\nPin 4 (GND)  → Ground\n\nDHT11 module (3-pin breakout, pull-up onboard):\nVCC  → 3.3-5V\nDATA → Digital GPIO\nGND  → Ground\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]"],"used_in":[],"warnings":["Maximum 1Hz sampling rate — do NOT poll faster than once per second or you get stale/error data","NOT I2C — uses a proprietary single-wire protocol that looks similar but is incompatible. Cannot share an I2C bus","Low accuracy (+/-2C temperature, +/-5% RH) — use DHT22/AM2302 or BME280 if you need better","Operating range is only 0-50C — will not work in freezing conditions","The bare 4-pin component needs an external 10K pull-up resistor on DATA. Module breakouts include it onboard","Slow response time — takes 6-15 seconds to respond to temperature changes"],"datasheet_url":"https://www.mouser.com/datasheet/2/758/DHT11-Technical-Data-Sheet-Translated-Version-1143054.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[66,93]],"key":"docs/parts/dht11-temperature-humidity-sensor-single-wire-0-50c.md"},
