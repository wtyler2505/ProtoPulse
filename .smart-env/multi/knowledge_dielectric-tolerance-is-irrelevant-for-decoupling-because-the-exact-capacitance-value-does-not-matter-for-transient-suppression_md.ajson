":"knowledge-note","source":"docs/parts/100nf-ceramic-capacitor-104-50v-decoupling-bypass.md","topics":["[[passives]]","[[eda-fundamentals]]"],"confidence":"high","verified":false},"task_lines":[],"tasks":{},"codeblock_ranges":[[20,22]],"key":"knowledge/dielectric-tolerance-is-irrelevant-for-decoupling-because-the-exact-capacitance-value-does-not-matter-for-transient-suppression.md"},"smart_blocks:knowledge/dielectric-tolerance-is-irrelevant-for-decoupling-because-the-exact-capacitance-value-does-not-matter-for-transient-suppression.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1hstx5g","at":1776207067952},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.10438072,0.05838928,0.05383648,-0.03718804,-0.00449341,0.00637203,0.03007339,0.03556892,0.01046072,-0.04260382,0.01595156,-0.0941545,0.08464587,0.0201193,0.02479204,0.04914618,0.01322001,-0.01749254,0.0341614,0.08300865,0.09537226,-0.01003158,0.05486015,-0.04862659,0.08593669,0.00435052,0.0736316,-0.00741027,-0.00483138,-0.27548873,-0.00331645,-0.01660481,0.00795579,-0.01806114,-0.00117314,-0.00589222,-0.01339676,-0.02722888,0.00082463,0.03231381,-0.00279447,0.0507864,-0.00304604,-0.01497548,-0.03024859,-0.02574153,-0.06896342,-0.07783677,-0.03157876,-0.03021852,0.02459765,0.03503513,0.01779194,0.0108243,-0.05128581,0.06751513,0.03175129,0.02057615,0.0758023,0.05477428,0.01583799,0.03491795,-0.15808228,0.10471613,0.05884546,-0.00963185,0.01530593,-0.07060084,0.00772289,0.03960711,-0.03687365,-0.01505222,-0.02541371,0.03160798,0.0272806,-0.01714658,0.02783695,-0.03401469,0.00590105,-0.01081679,0.03074281,-0.05867075,-0.02943982,-0.01223557,-0.02948026,-0.04320521,0.04474607,0.02878582,0.00367444,0.00481136,0.00573011,-0.00826684,0.02434174,0.01521702,-0.02986557,0.03680699,0.05043238,0.07324439,-0.11316583,0.08887052,-0.02011589,0.03678084,-0.07129139,-0.03391759,0.00057447,-0.01419096,0.03507123,0.01241688,0.00573749,-0.03137334,0.05557035,-0.06332441,0.00475532,-0.0137462,0.01756962,0.06137829,0.0313852