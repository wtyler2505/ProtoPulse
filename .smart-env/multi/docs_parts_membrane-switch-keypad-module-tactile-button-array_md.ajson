,"target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":67},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":68},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":69},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":70},{"title":"analog-joystick-module-xy-axes-plus-pushbutton","target":"analog-joystick-module-xy-axes-plus-pushbutton","line":71},{"title":"ky-040-rotary-encoder-module-incremental-with-pushbutton","target":"ky-040-rotary-encoder-module-incremental-with-pushbutton","line":72},{"title":"input-devices","target":"input-devices","line":75}],"metadata":{"description":"Matrix membrane keypad — row/column scanning over GPIO, supports 4x3 or 4x4 layouts, thin flexible overlay for panel mounting","topics":["[[input-devices]]"],"status":"needs-test","quantity":2,"voltage":[3.3,5],"interfaces":["GPIO"],"logic_level":"mixed","logic_notes":"Passive switch matrix with no active logic. Row and column voltages simply follow the MCU pull-ups and scan voltage you apply.","manufacturer":"Generic","part_number":"MEM-SW","pinout":"7 or 8 pins depending on 4x3 or 4x4 layout\n4x4: R1 R2 R3 R4 C1 C2 C3 C4 (8 pins)\n4x3: R1 R2 R3 R4 C1 C2 C3 (7 pins)\nRows → OUTPUT (scan one row LOW at a time)\nColumns → INPUT_PULLUP (read which column goes LOW)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"used_in":[],"warnings":["Uses 7-8 GPIO pins — consider I2C I/O expander (PCF8574) for pin-constrained projects","Membrane keys wear out with heavy use — not for high-cycle applications","No debouncing built in — use Keypad library which handles debounce in software"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[48,59]],"key":"docs/parts/membrane-switch-keypad-module-tactile-button-array.md"},"smart_blocks:docs/parts/membrane-switch-keypad-module-tactile-button-array.md#---frontmatter---": {"path":null,"last_embed":{"hash":"13whw0","at":1776210358178},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04554299,0.00191842,0.0248299,-0.02300003,-0.11163313,0.01601391,0.03681604,0.06279376,0.02225824,0.01976529,-0.00558717,-0.10910083,0.04093796,0.04279445,0.06096734,0.00320855,-0.01632929,0.02362572,-0.01176991,-0.00416279,0.06326469,-0.03696973,-0.01393545,-0.02377068,0.04177371,0.06900693,0.01534949,-0.02021096,-0.07524601,-0.22177224,-0.00644924,-0.01305814,0.03460369,-0.03893399,-0.01346336,-0.05182538,-0.04904438,-0.05593525,-0.04307644,-0.01013751,-0.0135245,-0.02654182,-0.02102396,-0.02813391,0.00286702,-0.08765424,-0.06333338,-0.02908261,0.09922822,-0.01912485,0.00099756,0.06686128,0.05094771,-0.01913457,0.05870532,-0.00093507,-0.01533962,0.02079746,0.05706744,-0.00435992,0.0660372,0.0438001,-0.16450919,0.17538053,0.07369591,0.00542795,-0.00329889,-0.01520356,0.06713246,0.05157241,-0.03326778,0.0381064,-0.03255982,0.04754747,0.03431248,-0.05207407,0.00131687,-0.03177773,-0.02766308,-0.05166225,-0.01281682,-0.00231005,-0.02146567,0.00431929,-0.01574515,0.01804566,-0.0201479,-0.00105964,-0.00741756,-0.00634414,-0.05325648,-0.03765509,-0.00627665,0.03964443,-0.07156345,-0.01781433,0.04111753,0.0317447,-0.11306769,0.08618363,-0.00827715,-0.00075403,0.02013496,-0.03832906,-0.01894031,-0.03748318,0.01964671,0.01643457,-0.04918692,-0.00036881,0.06914787,0.01322786,-0.01894547,-0.03650005,0.01564365,0.013350