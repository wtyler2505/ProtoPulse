":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":18},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":18},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":18},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":18},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":18},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":18},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":18},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":64},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":65},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":66},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":67},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":68},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":69},{"title":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","target":"raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3","line":70},{"title":"analog-joystick-module-xy-axes-plus-pushbutton","target":"analog-joystick-module-xy-axes-plus-pushbutton","line":71},{"title":"ky-040-rotary-encoder-module-incremental-with-pushbutton","target":"ky-040-rotary-encoder-module-incremental-with-pushbutton","line":72},{"title":"input-devices","target":"input-devices","line":75}],"metadata":{"description":"Matrix membrane keypad — row/column scanning over GPIO, supports 4x3 or 4x4 layouts, thin flexible overlay for panel mounting","topics":["[[input-devices]]"],"status":"needs-test","quantity":2,"voltage":[3.3,5],"interfaces":["GPIO"],"logic_level":"mixed","logic_notes":"Passive switch matrix with no active logic. Row and column voltages simply follow the MCU pull-ups and scan voltage you apply.","manufacturer":"Generic","part_number":"MEM-SW","pinout":"7 or 8 pins depending on 4x3 or 4x4 layout\n4x4: R1 R2 R3 R4 C1 C2 C3 C4 (8 pins)\n4x3: R1 R2 R3 R4 C1 C2 C3 (7 pins)\nRows → OUTPUT (scan one row LOW at a time)\nColumns → INPUT_PULLUP (read which column goes LOW)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[raspberry-pi-pico-is-an-rp2040-mcu-with-26-gpio-at-3v3]]"],"used_in":[],"warnings":["Uses 7-8 GPIO pins — consider I2C I/O expander (PCF8574) for pin-constrained projects","Membrane keys wear out with heavy use — not for high-cycle applications","No debouncing built in — use Keypad library which handles debounce in software"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[48,59]],"key":"docs/parts/membrane-switch-keypad-module-tactile-button-array.md"},
