ng it dissipate twice the switching power#{10}":[43,44],"#S8050 Vce saturation voltage is double that of PN2222A at equivalent current making it dissipate twice the switching power#{11}":[45,45],"#S8050 Vce saturation voltage is double that of PN2222A at equivalent current making it dissipate twice the switching power#{12}":[46,47]},"outlinks":[{"title":"passives","target":"passives","line":6},{"title":"s8050-npn-transistor-25v-500ma-medium-power-to92","target":"s8050-npn-transistor-25v-500ma-medium-power-to92","line":39},{"title":"to-92-package-limits-power-dissipation-to-625mw-and-requires-derating-above-25c-making-thermal-math-mandatory-for-high-current-switching","target":"to-92-package-limits-power-dissipation-to-625mw-and-requires-derating-above-25c-making-thermal-math-mandatory-for-high-current-switching","line":42},{"title":"bjt-saturation-requires-base-current-above-collector-current-divided-by-minimum-hfe-making-base-resistor-calculation-a-forced-gain-problem","target":"bjt-saturation-requires-base-current-above-collector-current-divided-by-minimum-hfe-making-base-resistor-calculation-a-forced-gain-problem","line":43},{"title":"passives","target":"passives","line":46}],"metadata":{"description":"S8050 Vce(sat) is ~0.6V at 500mA versus PN2222A's ~0.3V at comparable current -- this 2x difference means S8050 dissipates twice the power in the ON state (300mW vs 150mW), consuming nearly half the TO-92's 625mW thermal budget","type":"knowledge-note","source":"docs/parts/s8050-npn-transistor-25v-500ma-medium-power-to92.md","topics":["[[passives]]"],"confidence":"high","verified":false},"task_lines":[],"tasks":{},"codeblock_ranges":[]},