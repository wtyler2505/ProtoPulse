ts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":93},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":94},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":95},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":96},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":97},{"title":"sensors","target":"sensors","line":100}],"metadata":{"description":"Short-range IR proximity sensor with analog voltage output — best for detecting objects within 2-15cm, non-contact. Voltage curve is nonlinear so use a lookup table, not linear math","topics":["[[sensors]]"],"status":"needs-test","quantity":2,"voltage":[3.3,5],"interfaces":["Analog"],"logic_level":"Analog output (0.4-3.1V typical)","manufacturer":"Sharp","part_number":"GP2Y0A51SK0F","measurement_range":"2cm to 15cm","output_type":"Analog voltage (inversely proportional to distance)","pinout":"3-pin JST connector:\nPin 1 → VO (Analog voltage output)\nPin 2 → GND\nPin 3 → VCC (3.3-5V)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]"],"used_in":[],"warnings":["Output voltage is NOT linear with distance — use a lookup table or inverse curve fit","Below 2cm the output voltage DROPS (ambiguous zone) — objects too close read as far away","IR sensors are affected by surface color and reflectivity — dark/black surfaces give weak returns","Add 10uF cap across VCC-GND close to sensor to reduce supply noise"],"datasheet_url":"https://global.sharp/products/device/lineup/data/pdf/datasheet/gp2y0a51sk_e.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[65,69],[75,79]]},"smart_blocks:docs/parts/sharp-gp2y0a51sk0f-ir-proximity-sensor-2-to-15cm-analog.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"ourch0","at":1776152926650},"key":"docs/parts/sharp-gp2y0a51sk0f-ir-proximity-sensor-2-to-15cm-analog.md#---frontmatter---","lines":[1,22],"size":1496,"outlinks":[{"title":"sensors","target":"sensors","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":18},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":18},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":18},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":18},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":18},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":18}],"class_name":"SmartBlock"},
