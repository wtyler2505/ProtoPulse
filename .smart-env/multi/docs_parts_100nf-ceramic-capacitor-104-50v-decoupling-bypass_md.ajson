r-470uf-200v-radial","line":70},{"title":"passives","target":"passives","line":73}],"metadata":{"description":"The universal decoupling capacitor — every IC needs one, place 100nF as close to VCC/GND pins as possible to suppress noise and prevent brownout resets","topics":["[[passives]]"],"status":"needs-test","quantity":3,"voltage":[3.3,5],"interfaces":["Passive"],"logic_level":"N/A","manufacturer":"Generic","capacitance":"100nF (0.1uF)","dielectric":"X7R or Y5V","tolerance":"10-20%","voltage_rating":"50V","package":"Through-hole radial","compatible_with":[],"used_in":[],"warnings":["Essential for every IC — place as close to VCC/GND pins as possible","Marking '104' means 10 x 10^4 pF = 100,000pF = 100nF","Without decoupling caps, MCUs will randomly reset, ADC readings will be noisy, and I2C/SPI will glitch"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[40,43]],"key":"docs/parts/100nf-ceramic-capacitor-104-50v-decoupling-bypass.md"},
