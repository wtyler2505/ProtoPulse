
"smart_sources:docs/parts/emergency-stop-nc-button-with-dc-contactor-for-36v.md": {"path":"docs/parts/emergency-stop-nc-button-with-dc-contactor-for-36v.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"1pi232t","at":1776152925099},"class_name":"SmartSource","last_import":{"mtime":1773554249766,"size":6518,"at":1776152926058,"hash":"1pi232t"},"blocks":{"#---frontmatter---":[1,27],"#Emergency Stop — NC Button with DC Contactor for 36V":[29,133],"#Emergency Stop — NC Button with DC Contactor for 36V#{1}":[31,33],"#Emergency Stop — NC Button with DC Contactor for 36V#{2}":[34,34],"#Emergency Stop — NC Button with DC Contactor for 36V#{3}":[35,35],"#Emergency Stop — NC Button with DC Contactor for 36V#{4}":[36,36],"#Emergency Stop — NC Button with DC Contactor for 36V#{5}":[37,38],"#Emergency Stop — NC Button with DC Contactor for 36V#{6}":[39,40],"#Emergency Stop — NC Button with DC Contactor for 36V#E-Stop Button Specifications (Schneider XB5AS8442)":[41,56],"#Emergency Stop — NC Button with DC Contactor for 36V#E-Stop Button Specifications (Schneider XB5AS8442)#{1}":[43,56],"#Emergency Stop — NC Button with DC Contactor for 36V#DC Contactor Specifications (Albright SW200-92)":[57,76],"#Emergency Stop — NC Button with DC Contactor for 36V#DC Contactor Specifications (Albright SW200-92)#{1}":[59,76],"#Emergency Stop — NC Button with DC Contactor for 36V#Circuit Diagram":[77,107],"#Emergency Stop — NC Button with DC Contactor for 36V#Circuit Diagram#{1}":[79,107],"#Emergency Stop — NC Button with DC Contactor for 36V#Control Circuit Wiring":[108,115],"#Emergency Stop — NC Button with DC Contactor for 36V#Control Circuit Wiring#{1}":[110,115],"#Emergency Stop — NC Button with DC Contactor for 36V#Power Circuit Wiring":[116,133],"#Emergency Stop — NC Button with DC Contactor for 36V#Power Circuit Wiring#{1}":[118,125],"#Emergency Stop — NC Button with DC Contactor for 36V#Power Circuit Wiring#{2}":[126,126],"#Emergency Stop — NC Button with DC Contactor for 36V#Power Circuit Wiring#{3}":[127,127],"#Emergency Stop — NC Button with DC Contactor for 36V#Power Circuit Wiring#{4}":[128,128],"#Emergency Stop — NC Button with DC Contactor for 36V#Power Circuit Wiring#{5}":[129,130],"#Emergency Stop — NC Button with DC Contactor for 36V#Power Circuit Wiring#{6}":[131,131],"#Emergency Stop — NC Button with DC Contactor for 36V#Power Circuit Wiring#{7}":[132,133]},"outlinks":[{"title":"power","target":"power","line":3},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":23},{"title":"main-power-switch-anl-fuse-100a-disconnect-for-36v","target":"main-power-switch-anl-fuse-100a-disconnect-for-36v","line":23},{"title":"power-distribution-board-fused-terminal-block-for-36v-system","target":"power-distribution-board-fused-terminal-block-for-36v-system","line":23},{"title":"main-power-switch-anl-fuse-100a-disconnect-for-36v","target":"main-power-switch-anl-fuse-100a-disconnect-for-36v","line":126},{"title":"power-distribution-board-fused-terminal-block-for-36v-system","target":"power-distribution-board-fused-terminal-block-for-36v-system","line":127},{"title":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","target":"hoverboard-10s-lithium-ion-battery-pack-36v-with-bms","line":128},{"title":"lm2596-adjustable-buck-converter-module-3a-step-down","target":"lm2596-adjustable-buck-converter-module-3a-step-down","line":129},{"title":"power","target":"power","line":132}],"metadata":{"description":"Red mushroom e-stop button (Schneider XB5AS, NC contact) that breaks a DC contactor coil circuit to kill all 36V power. Albright SW200 contactor handles 250A with magnetic blowout arc suppression. Pressing e-stop de-energizes contactor coil, opening main power contacts — fail-safe design","topics":["[[power]]"],"status":"needs-test","quantity":1,"voltage":[12,24,36],"interfaces":["Terminal"],"logic_level":"N/A (electromechanical safety system)","manufacturer":"Schneider Electric (e-stop button), Albright (DC contactor)","part_number":"XB5AS8442 (e-stop), SW200-92 (contactor)","pinout":"E-Stop Button (Schneider XB5AS):\n  Terminal 11 → +12/24V from buck converter (NC input)\n  Terminal 12 → To DC contactor coil (+) (NC output)\n  Terminal 21 → NO input (not used for safety function)\n  Terminal 22 → NO output (not used for safety function)\n\nDC Contactor (Albright SW200):\n  Main IN (+)  → From main power switch output (#4 AWG, M10 ring)\n  Main OUT (+) → To power distribution board (#4 AWG, M10 ring)\n  Coil (+)     → From e-stop button terminal 12 (6.3mm spade)\n  Coil (-)     → GND return to buck converter (6.3mm spade)\n","compatible_with":["[[hoverboard-10s-lithium-ion-battery-pack-36v-with-bms]]","[[power-distribution-board-fused-terminal-block-for-36v-system]]","[[main-power-switch-anl-fuse-100a-disconnect-for-36v]]"],"used_in":[],"warnings":["E-stop MUST use Normally Closed (NC) contacts — wire fails open = safe shutdown. NEVER use NO contacts for safety stop","DC contactor MUST have arc suppression (magnetic blowout) — without it, contacts will weld under DC load and the e-stop won't work","E-stop button is for CONTROL circuit only (12/24V, <2A) — it does NOT directly switch 36V/100A power","Mount e-stop in accessible exterior location — you need to reach it in an emergency","System must NOT restart when e-stop is released — twist-to-release requires deliberate action","Test e-stop function monthly — press, verify all power cuts, verify no restart until released"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[79,106]]},