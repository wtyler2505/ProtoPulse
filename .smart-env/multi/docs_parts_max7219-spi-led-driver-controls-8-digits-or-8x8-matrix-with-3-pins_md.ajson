r 8x8 matrix with 3 pins#Warnings#{5}":[112,114],"#MAX7219 SPI LED driver controls 8 digits or 8x8 matrix with 3 pins#Warnings#{6}":[115,115],"#MAX7219 SPI LED driver controls 8 digits or 8x8 matrix with 3 pins#Warnings#{7}":[116,116],"#MAX7219 SPI LED driver controls 8 digits or 8x8 matrix with 3 pins#Warnings#{8}":[117,118],"#MAX7219 SPI LED driver controls 8 digits or 8x8 matrix with 3 pins#Warnings#{9}":[119,119],"#MAX7219 SPI LED driver controls 8 digits or 8x8 matrix with 3 pins#Warnings#{10}":[120,120],"#MAX7219 SPI LED driver controls 8 digits or 8x8 matrix with 3 pins#Warnings#{11}":[121,122]},"outlinks":[{"title":"displays","target":"displays","line":3},{"title":"shields","target":"shields","line":3},{"title":"1088as-8x8-red-led-dot-matrix-common-cathode-3mm","target":"1088as-8x8-red-led-dot-matrix-common-cathode-3mm","line":38},{"title":"5161as-single-digit-7-segment-led-display-red-common-cathode","target":"5161as-single-digit-7-segment-led-display-red-common-cathode","line":38},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":38},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":38},{"title":"1088as-8x8-red-led-dot-matrix-common-cathode-3mm","target":"1088as-8x8-red-led-dot-matrix-common-cathode-3mm","line":115},{"title":"5161as-single-digit-7-segment-led-display-red-common-cathode","target":"5161as-single-digit-7-segment-led-display-red-common-cathode","line":116},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":117},{"title":"displays","target":"displays","line":120},{"title":"shields","target":"shields","line":121}],"metadata":{"description":"THE driver IC for LED displays — controls 8 seven-segment digits or an 8x8 matrix over SPI with just 3 pins. Daisy-chainable via DOUT, built-in BCD decoder, 16-level PWM brightness","topics":["[[displays]]","[[shields]]"],"status":"needs-test","quantity":1,"voltage":[4,5,5.5],"interfaces":["SPI"],"logic_level":"5V","manufacturer":"Maxim Integrated (Analog Devices)","part_number":"MAX7219CNG","pinout":"24-pin DIP package:\nPin 1  → DIN (serial data in from MCU MOSI)\nPin 2  → DIG 0 (digit/column 0 sink driver)\nPin 3  → DIG 4\nPin 4  → GND\nPin 5  → DIG 6\nPin 6  → DIG 2\nPin 7  → DIG 3\nPin 8  → DIG 7\nPin 9  → GND\nPin 10 → DIG 5\nPin 11 → DIG 1\nPin 12 → LOAD/CS (latch data on rising edge)\nPin 13 → CLK (serial clock, 10MHz max)\nPin 14 → SEG A (segment source driver)\nPin 15 → SEG F\nPin 16 → SEG B\nPin 17 → SEG G\nPin 18 → ISET (connect RSET resistor to V+)\nPin 19 → V+ (4.0-5.5V supply)\nPin 20 → SEG C\nPin 21 → SEG E\nPin 22 → SEG DP (decimal point)\nPin 23 → SEG D\nPin 24 → DOUT (serial data out — daisy chain to next MAX7219 DIN)\n","i2c_address":"","compatible_with":["[[1088as-8x8-red-led-dot-matrix-common-cathode-3mm]]","[[5161as-single-digit-7-segment-led-display-red-common-cathode]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]"],"used_in":[],"warnings":["Common-cathode displays ONLY — will not work with common-anode","RSET resistor sets segment current for ALL segments — use 9.53k for ~40mA (max brightness), higher values for less current","Both GND pins (4 and 9) must be connected","100nF + 10uF caps required between V+ and GND close to the chip"],"datasheet_url":"Datasheets/max7219cng.pdf"},"task_lines":[],"tasks":{},"codeblock_ranges":[[65,80]]},"smart_blocks:docs/parts/max7219-spi-led-driver-controls-8-digits-or-8x8-matrix-with-3-pins.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"13hlake","at":1776152926648},"key":"docs/parts/max7219-spi-led-driver-controls-8-digits-or-8x8-matrix-with-3-pins.md#---frontmatter---","lines":[1,42],"size":1759,"outlinks":[{"title":"displays","target":"displays","line":3},{"title":"shields","target":"shields","line":3},{"title":"1088as-8x8-red-led-dot-matrix-common-cathode-3mm","target":"1088as-8x8-red-led-dot-matrix-common-cathode-3mm","line":38},{"title":"5161as-single-digit-7-segment-led-display-red-common-cathode","target":"5161as-single-digit-7-segment-led-display-red-common-cathode","line":38},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":38},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":38}],"class_name":"SmartBlock"},
