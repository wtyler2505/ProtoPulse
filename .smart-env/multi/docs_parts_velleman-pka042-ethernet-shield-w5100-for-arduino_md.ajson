n","line":3},{"title":"shields","target":"shields","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":20},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":20},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":20},{"title":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","target":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","line":20},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":63},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":64},{"title":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","target":"elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb","line":65},{"title":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","target":"osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v","line":66},{"title":"rc522-mfrc522-rfid-reader-13mhz-spi-3v3","target":"rc522-mfrc522-rfid-reader-13mhz-spi-3v3","line":67},{"title":"communication","target":"communication","line":70},{"title":"shields","target":"shields","line":71}],"metadata":{"description":"W5100-based Ethernet shield — adds wired 10/100 Mbps networking to Arduino via SPI, includes micro-SD card slot, standard Arduino shield form factor","topics":["[[communication]]","[[shields]]"],"status":"needs-test","quantity":1,"voltage":[5],"interfaces":["SPI","Ethernet"],"logic_level":"5V","manufacturer":"Velleman","part_number":"PKA042","chip":"WIZnet W5100","pinout":"Uses SPI via ICSP header (compatible with Uno and Mega)\nD10 → Ethernet SS (chip select)\nD4  → SD card SS (if using SD slot)\nD11/MOSI → SPI data (via ICSP on Mega)\nD12/MISO → SPI data (via ICSP on Mega)\nD13/SCK  → SPI clock (via ICSP on Mega)\nD2  → Optional interrupt (W5100 INT)\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[elegoo-mega-2560-r3-is-an-arduino-mega-clone-with-ch340-usb]]","[[osepp-uno-r3-plus-is-an-arduino-uno-clone-at-5v]]"],"used_in":[],"warnings":["Uses D10 (Ethernet CS) and D4 (SD CS) — cannot use these pins for other purposes when shield is mounted","W5100 supports max 4 simultaneous socket connections","Uses SPI via ICSP header, so it works on both Uno and Mega without rewiring","Draws significant current (~150mA) — don't power from USB alone if also driving other loads"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[54,58]],"key":"docs/parts/velleman-pka042-ethernet-shield-w5100-for-arduino.md"},"smart_blocks:docs/parts/velleman-pka042-ethernet-shield-w5100-for-arduino.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1f2nyp9","at":1776210637668},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.13053022,0.0112281,0.00785365,-0.0405961,-0.02567001,-0.02378953,-0.01218493,0.05014329,0.00767435,0.00711166,0.02781481,-0.08163218,0.05180819,0.0257167,0.04306202,-0.00443044,0.00618321,-0.00925706,0.00081175,0.00411849,0.09237745,-0.06892338,-0.00305356,-0.00904611,0.04767005,0.05040326,0.01994951,-0.01602971,-0.02276162,-0.24369229,0.00768969,-0.05239309,0.03166015,-0.00668228,-0.0658858,-0.09429143,0.00279187,-0.03061539,-0.09468268,0.0418001,-0.00863493,-0.00848132,0.01602839,-0.0318294,0.02381536,-0.04740437,-0.033462,-0.06856252,0.08073023,-0.04563864,0.05502725,0.02589102,0.03446576,0.014913,0.02064925,0.03684521,0.05437747,0.04964735,0.08285486,0.05164559,0.0339153,0.05044905,-0.17344928,0.12879536,0.02620205,0.03868631,-0.0459629,0.03046505,0.0674463,0.02230331,-0.05773607,0.01722162,-0.04271721,0.02137733,0.00802545,0.01031646,-