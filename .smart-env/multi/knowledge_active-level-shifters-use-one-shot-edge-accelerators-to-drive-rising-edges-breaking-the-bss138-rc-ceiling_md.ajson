ndamentals","line":9},{"title":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","target":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","line":19},{"title":"bss138-switching-speed-caps-at-400khz-making-it-unsuitable-for-fast-spi-and-high-speed-push-pull-signals","target":"bss138-switching-speed-caps-at-400khz-making-it-unsuitable-for-fast-spi-and-high-speed-push-pull-signals","line":19},{"title":"open-drain-protocols-require-pull-up-based-level-shifters-because-auto-direction-sensors-cannot-distinguish-driver-from-pull-up","target":"open-drain-protocols-require-pull-up-based-level-shifters-because-auto-direction-sensors-cannot-distinguish-driver-from-pull-up","line":23},{"title":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","target":"txs0108e-8-channel-bidirectional-level-shifter-auto-direction","line":29},{"title":"bss138-switching-speed-caps-at-400khz-making-it-unsuitable-for-fast-spi-and-high-speed-push-pull-signals","target":"bss138-switching-speed-caps-at-400khz-making-it-unsuitable-for-fast-spi-and-high-speed-push-pull-signals","line":32},{"title":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","target":"bss138-body-diode-makes-level-shifting-bidirectional-without-direction-control","line":33},{"title":"open-drain-protocols-require-pull-up-based-level-shifters-because-auto-direction-sensors-cannot-distinguish-driver-from-pull-up","target":"open-drain-protocols-require-pull-up-based-level-shifters-because-auto-direction-sensors-cannot-distinguish-driver-from-pull-up","line":34},{"title":"signal-topology-not-voltage-alone-determines-level-shifter-selection","target":"signal-topology-not-voltage-alone-determines-level-shifter-selection","line":35},{"title":"74hct-buffers-are-purpose-built-3v3-to-5v-level-shifters-for-timing-critical-signals","target":"74hct-buffers-are-purpose-built-3v3-to-5v-level-shifters-for-timing-critical-signals","line":36},{"title":"shields","target":"shields","line":39},{"title":"communication","target":"communication","line":40},{"title":"eda-fundamentals","target":"eda-fundamentals","line":41}],"metadata":{"description":"Active level shifters like the TXS0108E detect a rising edge on either side and fire a brief one-shot pulse that actively drives the opposite rail, replacing the passive RC charge path that caps BSS138 shifters near 400kHz — this is the mechanism that enables 110Mbps push-pull operation on a chip otherwise similar in footprint to a BSS138 module","type":"claim","source":"docs/parts/txs0108e-8-channel-bidirectional-level-shifter-auto-direction.md","confidence":"proven","topics":["[[shields]]","[[communication]]","[[eda-fundamentals]]"],"related_components":["txs0108e-level-shifter","hw-221-level-shifter"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"knowledge/active-level-shifters-use-one-shot-edge-accelerators-to-drive-rising-edges-breaking-the-bss138-rc-ceiling.md"},
