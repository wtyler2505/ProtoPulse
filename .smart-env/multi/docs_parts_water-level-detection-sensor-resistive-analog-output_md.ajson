02],"#Water level detection sensor resistive analog output#Limitations#{6}":[103,103],"#Water level detection sensor resistive analog output#Limitations#{7}":[104,104],"#Water level detection sensor resistive analog output#Limitations#{8}":[105,105],"#Water level detection sensor resistive analog output#Limitations#{9}":[106,106],"#Water level detection sensor resistive analog output#Limitations#{10}":[107,108],"#Water level detection sensor resistive analog output#Limitations#{11}":[109,109],"#Water level detection sensor resistive analog output#Limitations#{12}":[110,111]},"outlinks":[{"title":"sensors","target":"sensors","line":3},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":23},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":23},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":23},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":23},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":23},{"title":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","target":"arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b","line":103},{"title":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","target":"arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts","line":104},{"title":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","target":"arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb","line":105},{"title":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","target":"nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3","line":106},{"title":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","target":"esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3","line":107},{"title":"sensors","target":"sensors","line":110}],"metadata":{"description":"Trace-based resistive water level sensor — analog output drops as water covers more traces. Dead simple but corrodes quickly if powered continuously. Use intermittent readings to extend life","topics":["[[sensors]]"],"status":"needs-test","quantity":2,"voltage":[3.3,5],"interfaces":["Analog"],"logic_level":"Analog output (voltage varies with water level)","manufacturer":"Generic","part_number":"YL-69 (variant)","pinout":"2-pin sensor + companion board (some modules):\nSensor board:\n  S  → Signal (to analog input or companion board)\n  -  → GND\n  +  → VCC (3.3-5V)\n\nIf companion board present (LM393-based):\n  AO → Analog output (proportional to water level)\n  DO → Digital output (threshold triggered)\n  GND → Ground\n  VCC → 3.3-5V\n","compatible_with":["[[arduino-mega-2560-is-a-54-io-5v-board-with-4-hardware-uarts]]","[[arduino-nano-v3-is-a-22-io-5v-board-with-atmega328p-and-mini-usb]]","[[esp8266-nodemcu-amica-is-a-wifi-mcu-with-11-io-at-3v3]]","[[arduino-uno-r3-is-a-14-io-5v-board-with-atmega328p-and-usb-b]]","[[nodemcu-esp32s-is-a-dual-core-wifi-bt-mcu-with-34-gpio-at-3v3]]"],"used_in":[],"warnings":["Traces corrode via electrolysis if powered continuously — use GPIO to power it ON only during readings","Not food-safe — do not use in drinking water applications","Output is relative (more water = lower resistance) — calibrate for your specific setup","Conductive liquids other than water will give different readings"],"datasheet_url":""},"task_lines":[],"tasks":{},"codeblock_ranges":[[56,72]]},"smart_blocks:docs/parts/water-level-detection-sensor-resistive-analog-output.md#---frontmatter---": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"99po06","at