{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "timeout": 60000
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${DATABASE_URL}"
      ],
      "timeout": 60000
    },
    "desktop-commander": {
      "command": "desktop-commander",
      "args": [],
      "timeout": 30000
    },
    "qmd": {
      "command": "qmd",
      "args": ["mcp"],
      "timeout": 30000
    }
  }
}
