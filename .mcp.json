{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "timeout": 60000
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://protopulse:protopulse@localhost:5432/protopulse"
      ],
      "timeout": 60000
    },
    "desktop-commander": {
      "command": "desktop-commander",
      "args": [],
      "timeout": 30000
    }
  }
}
