{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|replace",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/hardware-enforcement.sh"
          }
        ]
      },
      {
        "matcher": "Read|Edit|MultiEdit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run file-guard"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/protected-files.sh"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/file-freshness.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/dangerous-bash-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/enforce-test-background.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/auto-create-parent-moc.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run lint-changed"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "NODE_OPTIONS='--max-old-space-size=16384' claudekit-hooks run typecheck-changed",
            "timeout": 600
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run check-any-changed"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run test-changed",
            "timeout": 180
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run check-comment-replacement"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run check-unused-parameters"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run codebase-map-update",
            "async": true
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/context-budget.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/read-tsc-errors.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/validate-note.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/auto-commit-vault.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/schema-change-verifier.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/never-idle-while-waiting.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/wrap-claudekit-stop.sh lint-project"
          },
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/wrap-claudekit-stop.sh test-project"
          },
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/wrap-claudekit-stop.sh check-todos"
          },
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/smart-stop-gate.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "claudekit-hooks run create-checkpoint"
          },
          {
            "type": "command",
            "command": "/home/wtyler/.claude/scripts/auto-push-protopulse.sh --session-end &",
            "timeout": 60
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/session-capture.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/inject-subagent-context.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A subagent just finished. Check whether it completed its assigned task. If the subagent produced code changes: did it leave TypeScript errors or test failures? Are its file changes consistent with codebase patterns? If the subagent was read-only (exploration, research, analysis): did it actually return findings or just a trivial non-response? Flag work that is incomplete or trivially empty. Do not flag 'missing verification' when the subagent's task type doesn't warrant those checks."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/smart-stop-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/smart-stop-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/pre-compact-checkpoint.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/post-compact-memory-trim.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/check-hook-deps.sh"
          },
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/start-tsc-watch.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/session-orient.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run codebase-map"
          },
          {
            "type": "command",
            "command": "claudekit-hooks run thinking-level"
          }
        ]
      }
    ]
  }
}
