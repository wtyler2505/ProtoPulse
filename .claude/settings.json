{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|replace",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/hardware-enforcement.sh"
          }
        ]
      },
      {
        "matcher": "Read|Edit|MultiEdit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run file-guard"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/protected-files.sh"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/file-freshness.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/dangerous-bash-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/enforce-test-background.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/auto-create-parent-moc.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run lint-changed"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "NODE_OPTIONS='--max-old-space-size=16384' claudekit-hooks run typecheck-changed",
            "timeout": 600
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run check-any-changed"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run test-changed",
            "timeout": 180
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run check-comment-replacement"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run check-unused-parameters"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run codebase-map-update",
            "async": true
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/context-budget.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/read-tsc-errors.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/validate-note.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/auto-commit-vault.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/schema-change-verifier.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/never-idle-while-waiting.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/blocking-typecheck.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/wrap-claudekit-stop.sh lint-project"
          },
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/wrap-claudekit-stop.sh test-project"
          },
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/wrap-claudekit-stop.sh check-todos"
          },
          {
            "type": "prompt",
            "prompt": "Self-review before stopping. If this session produced code changes: verify TypeScript errors are fixed, relevant tests pass, and new files are integrated consistently with codebase patterns. If this session was read-only (status gathering like /resume or /status, research, analysis, /architect in plan mode, documentation): verify the deliverable actually answered the question and no speculative claims were left unverified. If this session was infrastructure or vault work: verify the target files were actually written and committed. In all cases: only raise concerns if there is a concrete issue you can name — do not produce generic 'cannot verify' responses when the criteria don't apply. If the work is complete for its type, say so and stop."
          },
          {
            "type": "command",
            "command": "claudekit-hooks run create-checkpoint"
          },
          {
            "type": "command",
            "command": "/home/wtyler/.claude/scripts/auto-push-protopulse.sh --session-end &",
            "timeout": 60
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/session-capture.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/inject-subagent-context.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A subagent just finished. Check whether it completed its assigned task. If the subagent produced code changes: did it leave TypeScript errors or test failures? Are its file changes consistent with codebase patterns? If the subagent was read-only (exploration, research, analysis): did it actually return findings or just a trivial non-response? Flag work that is incomplete or trivially empty. Do not flag 'missing verification' when the subagent's task type doesn't warrant those checks."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before marking this task complete, run checks that match the task type. If the task produced code changes: verify TypeScript compiles clean, relevant tests pass, and new files are integrated consistently with codebase patterns. If the task was read-only or informational (status, research, analysis, planning): verify the deliverable answered the question and all claims are grounded. If the task was infrastructure or documentation work: verify the target files were actually written, saved, and committed where applicable. Do NOT block completion with a generic 'cannot verify' response when the criteria don't apply to this task type — that produces noise without catching real problems. Only block if there is a concrete issue you can name."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "An agent-teams teammate just went idle. Check whether they finished all assigned tasks. If they produced code changes: did they leave TypeScript errors or untested changes? If their task was read-only or research: did they actually return findings? Send feedback if work is incomplete or trivially empty. Approve idle if the tasks are genuinely complete for their type. Do not ask for TypeScript/test verification when the teammate's work didn't touch code."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/pre-compact-checkpoint.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/post-compact-memory-trim.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/check-hook-deps.sh"
          },
          {
            "type": "command",
            "command": "/home/wtyler/Projects/ProtoPulse/.claude/hooks/start-tsc-watch.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/wtyler/Projects/ProtoPulse/.claude/hooks/session-orient.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claudekit-hooks run codebase-map"
          },
          {
            "type": "command",
            "command": "claudekit-hooks run thinking-level"
          }
        ]
      }
    ]
  }
}
