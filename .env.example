# ProtoPulse environment variables
# Copy to .env and fill in values. Never commit .env.

# ---- Required ----

# PostgreSQL connection string
DATABASE_URL=postgresql://protopulse:protopulse@localhost:5432/protopulse

# AES-256-GCM key for encrypted API-key storage (32 bytes hex)
API_KEY_ENCRYPTION_KEY=

# ---- Optional runtime ----

# Server port (default 5000)
PORT=5000

# development | production | test
NODE_ENV=development

# error | warn | info | debug
LOG_LEVEL=info

# Trust proxy hops (0 = off)
TRUST_PROXY=0

# DB pool / cache / rate-limit overrides (defaults per deployment profile)
DB_POOL_MAX=
CACHE_MAX=
RATE_LIMIT_MAX=

# Stream timeout in ms for SSE chat responses
STREAM_TIMEOUT_MS=120000

# ---- Admin ----

# Shared secret for admin maintenance routes (/api/admin/*, /api/backup/*)
ADMIN_API_KEY=

# ---- Arduino toolchain ----

# Absolute path to arduino-cli binary (default: looks on PATH)
ARDUINO_CLI_PATH=
ARDUINO_DATA_DIR=
ARDUINO_SKETCH_ROOT=

# ---- AI ----

# Disable automatic fallback between AI providers when primary fails
DISABLE_AI_FALLBACK=0

# ---- Feature flags ----

# Unified parts catalog v2 (ADR 0010, docs/plans/2026-04-10-parts-catalog-consolidation.md).
# Set to "true" to enable new canonical read paths during Phase 5 cutover.
# Default: false (legacy bomItems/componentParts/componentLibrary remain source of truth).
PARTS_CATALOG_V2=true
